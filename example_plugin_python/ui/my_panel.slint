// Python Plugin Window — loaded at runtime via slint-python.

import { Button, VerticalBox, HorizontalBox } from "std-widgets.slint";

export component MyPanel inherits Window {
    title: "Python Plugin Window";
    min-width: 360px;
    min-height: 280px;
    preferred-width: 420px;
    preferred-height: 320px;

    callback greet-clicked();
    callback clear-clicked();

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        Text {
            text: "Hello from Python plugin!";
            font-size: 20px;
            font-weight: 700;
            horizontal-alignment: center;
        }

        Text {
            text: "This window was opened by a Python plugin\nusing slint-python.";
            wrap: word-wrap;
            horizontal-alignment: center;
        }

        Rectangle {
            height: 1px;
            background: #444;
        }

        greeting-text := Text {
            text: "";
            font-size: 16px;
            horizontal-alignment: center;
            color: #4fc3f7;
        }

        HorizontalBox {
            spacing: 8px;
            alignment: center;

            Button {
                text: "Click Me";
                clicked => {
                    greeting-text.text = "Button clicked in Python plugin!";
                    root.greet-clicked();
                }
            }

            Button {
                text: "Clear";
                clicked => {
                    greeting-text.text = "";
                    root.clear-clicked();
                }
            }
        }
    }
}
