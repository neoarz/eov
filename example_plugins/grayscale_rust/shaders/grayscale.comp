#version 450

layout(local_size_x = 16, local_size_y = 16) in;

layout(set = 0, binding = 0, rgba8) uniform image2D filterImage;

void main() {
    ivec2 pos = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(filterImage);

    if (pos.x >= size.x || pos.y >= size.y) {
        return;
    }

    vec4 color = imageLoad(filterImage, pos);
    float lum = 0.299 * color.r + 0.587 * color.g + 0.114 * color.b;
    imageStore(filterImage, pos, vec4(lum, lum, lum, color.a));
}
