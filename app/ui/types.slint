// EOV WSI Viewer - shared Slint data types

export struct TabData {
    id: int,
    title: string,
    path: string,
    is-modified: bool,
    is-active: bool,
    is-home: bool,
}

export struct RecentFileData {
    path: string,
    name: string,
}

export struct ContextMenuItem {
    id: string,
    label: string,
    icon: string,
    shortcut: string,
    enabled: bool,
    separator-after: bool,
}

export struct TileInfo {
    x: int,
    y: int,
    width: int,
    height: int,
    level: int,
}

export struct MinimapRect {
    x: float,
    y: float,
    width: float,
    height: float,
}

export struct ViewportInfo {
    center-x: float,
    center-y: float,
    zoom: float,
    image-width: float,
    image-height: float,
    level: int,
}

export struct ROIRect {
    x: float,
    y: float,
    width: float,
    height: float,
    visible: bool,
    ant-offset: float,
}

export struct MeasurementLine {
    x1: float,
    y1: float,
    x2: float,
    y2: float,
    distance-um: float,
    visible: bool,
}

export struct MetadataItem {
    label: string,
    value: string,
}

export enum MeasurementUnit {
    um,
    mm,
    inches,
}

export enum StainNormalization {
    none,
    macenko,
    vahadane,
}

/// Which stain channel is currently being viewed in grayscale isolation.
/// none = normal blended mode, hematoxylin or eosin = isolated grayscale view.
export enum IsolatedChannel {
    none,
    hematoxylin,
    eosin,
}

export struct HudSettings {
    show-scale-bar: bool,
    show-hud-toolbar: bool,
    hud-dropdown-open: bool,
    sharpness: float,
    gamma: float,
    brightness: float,
    contrast: float,
    measurement-unit: MeasurementUnit,
    stain-normalization: StainNormalization,
    mpp-x: float,
    mpp-y: float,
    // Color deconvolution state
    deconv-hematoxylin-intensity: float,
    deconv-hematoxylin-visible: bool,
    deconv-eosin-intensity: float,
    deconv-eosin-visible: bool,
    deconv-isolated-channel: IsolatedChannel,
}

export struct PaneViewData {
    id: int,
    tabs: [TabData],
    content: image,
    viewport-info: ViewportInfo,
    minimap-thumbnail: image,
    minimap-rect: MinimapRect,
    metadata-items: [MetadataItem],
    is-home-tab: bool,
    zoom-slider-position: float,
    roi-rect: ROIRect,
    measurements: [MeasurementLine],
    candidate-measurement: MeasurementLine,
    is-loading: bool,
    hud: HudSettings,
}

export enum ToolType {
    navigate,
    region-of-interest,
    measure-distance,
}

export enum RenderMode {
    cpu,
    gpu,
}

export enum FilteringMode {
    bilinear,
    trilinear,
    lanczos3,
}

export enum ExportFilteringMode {
    bilinear,
    trilinear,
    lanczos,
}

export enum ExportFormat {
    jpeg,
    png,
}

export enum StrokeStyle {
    solid,
    dashed,
    dotted,
}

export enum CapStyle {
    round,
    square,
    flat,
}

export struct ExportSettings {
    dpi: int,
    filtering-mode: ExportFilteringMode,
    sharpness: float,
    gamma: float,
    brightness: float,
    contrast: float,
    stain-normalization: StainNormalization,
    // Measurement overlay
    show-measurement: bool,
    has-measurement: bool,
    measurement-color: color,
    measurement-opacity: float,
    measurement-thickness: float,
    measurement-stroke-style: StrokeStyle,
    measurement-cap-style: CapStyle,
    measurement-dash-length: float,
    measurement-dash-gap: float,
    measurement-dot-spacing: float,
    measurement-font-size: float,
    // ROI overlay
    show-roi-outline: bool,
    has-roi: bool,
    roi-color: color,
    roi-opacity: float,
    roi-thickness: float,
    roi-stroke-style: StrokeStyle,
    roi-cap-style: CapStyle,
    roi-dash-length: float,
    roi-dash-gap: float,
    roi-dot-spacing: float,
    // ROI outside overlay
    roi-outside-overlay: bool,
    roi-outside-color: color,
    roi-outside-opacity: float,
    // Format
    format: ExportFormat,
    jpeg-quality: int,
}

export struct ExportPreviewInfo {
    preview-image: image,
    estimated-size-mb: float,
    width-px: int,
    height-px: int,
    viewport-width: float,
    viewport-height: float,
}