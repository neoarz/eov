import { Theme } from "theme.slint";
import { HudSettings, MeasurementLine, MeasurementUnit, MetadataItem, MinimapRect, ROIRect, ToolType, ViewportInfo } from "types.slint";

export component Minimap inherits Rectangle {
    in property <image> thumbnail;
    in property <MinimapRect> viewport-rect;
    in property <float> image-width: 1.0;
    in property <float> image-height: 1.0;
    callback navigate(float, float);

    property <bool> is-dragging: false;
    property <length> content-x: 5px;
    property <length> content-y: 5px;
    property <length> content-width: self.width - 10px;
    property <length> content-height: self.height - 10px;
    property <float> image-aspect: image-width / max(image-height, 0.001);
    property <float> content-aspect: (content-width / 1px) / max(content-height / 1px, 0.001);
    property <length> img-display-width: image-aspect > content-aspect ? content-width : content-height * image-aspect;
    property <length> img-display-height: image-aspect > content-aspect ? content-width / image-aspect : content-height;
    property <length> img-display-x: content-x + (content-width - img-display-width) / 2;
    property <length> img-display-y: content-y + (content-height - img-display-height) / 2;

    width: 150px;
    height: 150px;
    background: Theme.minimap-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.border;

    Image {
        x: content-x;
        y: content-y;
        width: content-width;
        height: content-height;
        source: thumbnail;
        image-fit: contain;
    }

    Rectangle {
        x: img-display-x + viewport-rect.x * img-display-width;
        y: img-display-y + viewport-rect.y * img-display-height;
        width: viewport-rect.width * img-display-width;
        height: viewport-rect.height * img-display-height;
        background: transparent;
        border-width: 2px;
        border-color: Theme.minimap-rect;
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;

        pointer-event(e) => {
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.left {
                root.is-dragging = true;
                let rel-x = (self.mouse-x - root.img-display-x) / root.img-display-width;
                let rel-y = (self.mouse-y - root.img-display-y) / root.img-display-height;
                root.navigate(rel-x, rel-y);
            } else if e.kind == PointerEventKind.up {
                root.is-dragging = false;
            } else if e.kind == PointerEventKind.move && root.is-dragging {
                let rel-x = (self.mouse-x - root.img-display-x) / root.img-display-width;
                let rel-y = (self.mouse-y - root.img-display-y) / root.img-display-height;
                root.navigate(rel-x, rel-y);
            }
        }
    }
}

export component ZoomSlider inherits Rectangle {
    in property <float> value: 0.5;
    in property <float> zoom-level: 1.0;
    callback value-changed(float);

    width: 20px;
    height: 150px;
    background: Theme.minimap-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.border;

    property <float> clamped-value: max(0, min(1, value));
    property <length> track-top: 22px;
    property <length> track-bottom: 22px;
    property <length> track-height: self.height - root.track-top - root.track-bottom;
    property <length> handle-size: 10px;
    property <bool> hovered: plus-touch.has-hover || minus-touch.has-hover || slider-touch.has-hover;

    Rectangle {
        y: 0px;
        width: 100%;
        height: root.track-top;
        background: plus-touch.has-hover ? Theme.surface-hover : transparent;

        plus-touch := TouchArea {
            clicked => { root.value-changed(Math.min(1, root.clamped-value + 0.08)); }
        }

        Text {
            text: "+";
            color: Theme.text-primary;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Rectangle {
        x: root.width / 2 - 1px;
        y: root.track-top;
        width: 2px;
        height: root.track-height;
        border-radius: 2px;
        background: Theme.border;
    }

    Rectangle {
        x: root.width / 2 - root.handle-size / 2;
        y: root.track-top + (1 - root.clamped-value) * root.track-height - root.handle-size / 2;
        width: root.handle-size;
        height: root.handle-size;
        border-radius: root.handle-size / 2;
        background: Theme.accent;
        border-width: 1px;
        border-color: white;
    }

    slider-touch := TouchArea {
        y: root.track-top;
        width: 100%;
        height: root.track-height;

        pointer-event(e) => {
            if e.kind == PointerEventKind.down || (e.kind == PointerEventKind.move && self.pressed) {
                let normalized = 1 - max(0, min(1, self.mouse-y / max(root.track-height, 1px)));
                root.value-changed(normalized);
            }
        }
    }

    Rectangle {
        y: root.height - root.track-bottom;
        width: 100%;
        height: root.track-bottom;
        background: minus-touch.has-hover ? Theme.surface-hover : transparent;

        minus-touch := TouchArea {
            clicked => { root.value-changed(Math.max(0, root.clamped-value - 0.08)); }
        }

        Text {
            text: "-";
            color: Theme.text-primary;
            font-size: 14px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // Tooltip showing magnification level
    if root.hovered: Rectangle {
        x: -self.width - 6px;
        y: (root.height - self.height) / 2;
        width: zoom-tooltip-text.preferred-width + 12px;
        height: zoom-tooltip-text.preferred-height + 6px;
        background: #111111ee;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.border;

        zoom-tooltip-text := Text {
            x: 6px;
            y: 3px;
            text: root.zoom-level >= 1.0
                ? Math.round(root.zoom-level * 100) + "%"
                : Math.round(root.zoom-level * 1000) / 10 + "%";
            color: white;
            font-size: 11px;
        }
    }
}

export component MetadataHud inherits Rectangle {
    in property <[MetadataItem]> items: [];

    property <int> item-count: items.length;

    width: 292px;
    height: 52px + item-count * 22px;
    background: #101419dd;
    border-radius: 8px;
    border-width: 1px;
    border-color: #ffffff1a;
    drop-shadow-blur: 16px;
    drop-shadow-color: #00000070;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 3px;
        background: #4da3d9;
        border-top-left-radius: parent.border-radius;
        border-top-right-radius: parent.border-radius;
    }

    Text {
        x: 16px;
        y: 12px;
        text: "Slide Metadata";
        color: white;
        font-size: 12px;
        font-weight: 700;
    }

    Rectangle {
        x: 16px;
        y: 34px;
        width: parent.width - 32px;
        height: 1px;
        background: #ffffff12;
    }

    for item[index] in root.items: Rectangle {
        x: 16px;
        y: 42px + index * 22px;
        width: parent.width - 32px;
        height: 18px;
        background: transparent;

        Text {
            x: 0px;
            y: 1px;
            width: 78px;
            text: item.label;
            color: #8ea0b2;
            font-size: 11px;
            font-weight: 600;
            vertical-alignment: center;
        }

        Text {
            x: 86px;
            y: 1px;
            width: parent.width - 86px;
            text: item.value;
            color: #f3f6f8;
            font-size: 11px;
            font-weight: 500;
            overflow: elide;
            vertical-alignment: center;
        }
    }
}

export component ScaleBar inherits Rectangle {
    in property <float> zoom: 1.0;
    in property <float> mpp-x: 0.0;
    in property <float> mpp-y: 0.0;
    in property <MeasurementUnit> unit: MeasurementUnit.um;

    property <bool> has-calibration: mpp-x > 0.0 && mpp-y > 0.0;
    property <float> avg-mpp: (mpp-x + mpp-y) / 2.0;
    // pixels per um at current zoom
    property <float> px-per-um: has-calibration ? zoom / avg-mpp : 0.0;
    // target bar width in pixels (aim for 80-140px)
    property <float> target-bar-px: 110.0;
    // target distance in um
    property <float> target-um: has-calibration && px-per-um > 0.0 ? target-bar-px / px-per-um : 0.0;

    // Pick a nice round distance and compute bar width from it.
    // We use a chain of conditionals to select the nearest "nice" value.
    property <float> nice-um:
        target-um <= 0.0 ? 0.0
        : target-um < 0.15 ? 0.1
        : target-um < 0.35 ? 0.25
        : target-um < 0.75 ? 0.5
        : target-um < 1.5 ? 1.0
        : target-um < 3.5 ? 2.5
        : target-um < 7.5 ? 5.0
        : target-um < 15.0 ? 10.0
        : target-um < 35.0 ? 25.0
        : target-um < 75.0 ? 50.0
        : target-um < 150.0 ? 100.0
        : target-um < 350.0 ? 250.0
        : target-um < 750.0 ? 500.0
        : target-um < 1500.0 ? 1000.0
        : target-um < 3500.0 ? 2500.0
        : target-um < 7500.0 ? 5000.0
        : target-um < 15000.0 ? 10000.0
        : target-um < 35000.0 ? 25000.0
        : target-um < 75000.0 ? 50000.0
        : target-um < 150000.0 ? 100000.0
        : target-um < 350000.0 ? 250000.0
        : 500000.0;

    property <float> bar-width-px: has-calibration ? nice-um * px-per-um : 0.0;

    // Label: convert to appropriate unit
    property <string> label-text:
        !has-calibration ? ""
        : unit == MeasurementUnit.inches ? (nice-um >= 25400 ? Math.round(nice-um / 254) / 100 + " in" : Math.round(nice-um / 25.4 * 1000) / 1000 + " in")
        : unit == MeasurementUnit.mm ? (nice-um >= 1000 ? Math.round(nice-um / 10) / 100 + " mm" : Math.round(nice-um * 100) / 100 + " µm")
        : nice-um >= 1000 ? Math.round(nice-um / 10) / 100 + " mm"
        : Math.round(nice-um * 100) / 100 + " µm";

    width: max(60px, bar-width-px * 1px + 24px);
    height: 32px;
    background: transparent;
    visible: has-calibration && bar-width-px > 5.0;

    Rectangle {
        x: (parent.width - bar-width-px * 1px) / 2;
        y: parent.height - 12px;
        width: bar-width-px * 1px;
        height: 3px;
        background: white;
        border-radius: 1px;

        // Left tick
        Rectangle {
            x: 0px;
            y: -4px;
            width: 2px;
            height: 10px;
            background: white;
        }

        // Right tick
        Rectangle {
            x: parent.width - 2px;
            y: -4px;
            width: 2px;
            height: 10px;
            background: white;
        }
    }

    Text {
        x: 0px;
        y: 0px;
        width: 100%;
        text: root.label-text;
        color: white;
        font-size: 10px;
        font-weight: 600;
        horizontal-alignment: center;
    }
}

component HudButton inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();

    width: 38px;
    height: 38px;
    border-radius: 0px;
    background: touch.has-hover ? #ffffff22 : active ? #ffffff15 : transparent;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    Text {
        text: root.label;
        color: root.active ? white : #cccccc;
        font-size: 18px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component HudToolbar inherits Rectangle {
    in property <float> zoom-level: 1.0;
    in property <bool> show-scale-bar: true;
    in property <bool> dropdown-open: false;
    in property <bool> has-adjustments: false;

    callback fit-to-view();
    callback toggle-scale-bar();
    callback toggle-dropdown();
    callback zoom-input(float);

    property <string> zoom-text: zoom-level >= 1.0
        ? Math.round(zoom-level * 100) + "%"
        : Math.round(zoom-level * 1000) / 10 + "%";
    property <bool> editing-zoom: false;

    // Fixed width: 72px zoom area + 1px sep + 3 * 38px buttons = 187px
    width: 187px;
    height: 38px;
    background: #101419cc;
    border-radius: 8px;
    border-width: 1px;
    border-color: #ffffff12;
    clip: true;

    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        // Zoom label / text input
        Rectangle {
            width: 72px;
            height: 38px;
            border-radius: 0px;
            background: zoom-touch.has-hover || root.editing-zoom ? #ffffff15 : transparent;

            Text {
                visible: !root.editing-zoom;
                text: root.zoom-text;
                color: #e0e0e0;
                font-size: 15px;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            Rectangle {
                visible: root.editing-zoom;
                x: 4px;
                y: (parent.height - self.height) / 2;
                width: parent.width - 8px;
                height: 26px;
                background: root.editing-zoom ? #1a1f28 : transparent;
                border-radius: 4px;
                border-width: root.editing-zoom ? 1px : 0px;
                border-color: #4da3d9;

                zoom-text-input := TextInput {
                    x: 4px;
                    width: parent.width - 8px;
                    color: white;
                    font-size: 14px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    text: root.zoom-text;
                    input-type: InputType.decimal;

                    accepted => {
                        root.editing-zoom = false;
                        root.zoom-input(self.text.to-float() / 100.0);
                    }
                }
            }

            zoom-touch := TouchArea {
                enabled: !root.editing-zoom;
                clicked => {
                    root.editing-zoom = true;
                    zoom-text-input.focus();
                    zoom-text-input.select-all();
                }
            }
        }

        // Separator
        Rectangle {
            width: 1px;
            height: 26px;
            background: #ffffff20;
        }

        HudButton {
            label: "⊞";
            clicked => { root.fit-to-view(); }
        }

        HudButton {
            label: "⊡";
            active: root.show-scale-bar;
            clicked => { root.toggle-scale-bar(); }
        }

        HudButton {
            label: "⚙";
            active: root.dropdown-open || root.has-adjustments;
            clicked => { root.toggle-dropdown(); }
        }
    }
}

component HudSlider inherits Rectangle {
    in property <string> label;
    in property <float> value: 0.0;
    in property <float> min-value: 0.0;
    in property <float> max-value: 1.0;
    in property <string> display-text;
    callback changed(float);

    height: 28px;
    background: transparent;

    property <float> normalized: (value - min-value) / max(max-value - min-value, 0.001);
    property <length> track-left: 80px;
    property <length> track-right: 42px;
    property <length> track-width: self.width - track-left - track-right;

    Text {
        x: 8px;
        y: (parent.height - self.height) / 2;
        width: 68px;
        text: root.label;
        color: #8ea0b2;
        font-size: 11px;
        vertical-alignment: center;
    }

    Rectangle {
        x: root.track-left;
        y: (parent.height - 3px) / 2;
        width: root.track-width;
        height: 3px;
        border-radius: 1.5px;
        background: #ffffff20;

        Rectangle {
            width: root.normalized * parent.width;
            height: parent.height;
            border-radius: parent.border-radius;
            background: #4da3d9;
        }
    }

    // Handle
    Rectangle {
        x: root.track-left + root.normalized * root.track-width - 5px;
        y: (parent.height - 10px) / 2;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: white;
        border-width: 1px;
        border-color: #4da3d9;
    }

    slider-touch := TouchArea {
        x: root.track-left - 5px;
        y: 0px;
        width: root.track-width + 10px;
        height: root.height;

        pointer-event(e) => {
            if e.kind == PointerEventKind.down || (e.kind == PointerEventKind.move && self.pressed) {
                let norm = max(0.0, min(1.0, (self.mouse-x - 5px) / max(root.track-width, 1px)));
                root.changed(root.min-value + norm * (root.max-value - root.min-value));
            }
        }
    }

    Text {
        x: parent.width - root.track-right + 4px;
        y: (parent.height - self.height) / 2;
        width: root.track-right - 8px;
        text: root.display-text;
        color: #e0e0e0;
        font-size: 10px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
}

export component HudSettingsPanel inherits Rectangle {
    in property <float> gamma: 1.0;
    in property <float> brightness: 0.0;
    in property <float> contrast: 1.0;
    in property <MeasurementUnit> measurement-unit: MeasurementUnit.um;
    in property <bool> has-adjustments: false;

    callback gamma-changed(float);
    callback brightness-changed(float);
    callback contrast-changed(float);
    callback measurement-unit-changed(MeasurementUnit);
    callback reset-adjustments();

    width: 260px;
    height: layout.preferred-height + 8px;
    background: #101419ee;
    border-radius: 8px;
    border-width: 1px;
    border-color: #ffffff1a;
    drop-shadow-blur: 12px;
    drop-shadow-color: #00000060;

    layout := VerticalLayout {
        padding: 4px;
        spacing: 2px;

        // Header
        Rectangle {
            height: 28px;

            Text {
                x: 8px;
                text: "Image Adjustments";
                color: white;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
            }

            if root.has-adjustments: Rectangle {
                x: parent.width - self.width - 8px;
                y: (parent.height - self.height) / 2;
                width: reset-text.preferred-width + 12px;
                height: 20px;
                border-radius: 3px;
                background: reset-touch.has-hover ? #ffffff22 : transparent;

                reset-touch := TouchArea {
                    clicked => { root.reset-adjustments(); }
                }

                reset-text := Text {
                    text: "Reset";
                    color: #4da3d9;
                    font-size: 10px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #ffffff12;
        }

        HudSlider {
            label: "Gamma";
            value: root.gamma;
            min-value: 0.2;
            max-value: 3.0;
            display-text: Math.round(root.gamma * 100) / 100 + "";
            changed(v) => { root.gamma-changed(v); }
        }

        HudSlider {
            label: "Brightness";
            value: root.brightness;
            min-value: -1.0;
            max-value: 1.0;
            display-text: (root.brightness >= 0 ? "+" : "") + Math.round(root.brightness * 100) + "%";
            changed(v) => { root.brightness-changed(v); }
        }

        HudSlider {
            label: "Contrast";
            value: root.contrast;
            min-value: 0.2;
            max-value: 3.0;
            display-text: Math.round(root.contrast * 100) / 100 + "x";
            changed(v) => { root.contrast-changed(v); }
        }

        Rectangle {
            height: 1px;
            background: #ffffff12;
        }

        // Measurement unit row
        Rectangle {
            height: 28px;

            Text {
                x: 8px;
                text: "Units";
                color: #8ea0b2;
                font-size: 11px;
                vertical-alignment: center;
            }

            HorizontalLayout {
                x: 80px;
                y: (parent.height - self.height) / 2;
                width: parent.width - 88px;
                height: 22px;
                spacing: 2px;

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.measurement-unit == MeasurementUnit.um ? #4da3d940 : um-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.measurement-unit == MeasurementUnit.um ? 1px : 0px;
                    border-color: #4da3d9;

                    um-touch := TouchArea {
                        clicked => { root.measurement-unit-changed(MeasurementUnit.um); }
                    }

                    Text {
                        text: "µm";
                        color: root.measurement-unit == MeasurementUnit.um ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.measurement-unit == MeasurementUnit.mm ? #4da3d940 : mm-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.measurement-unit == MeasurementUnit.mm ? 1px : 0px;
                    border-color: #4da3d9;

                    mm-touch := TouchArea {
                        clicked => { root.measurement-unit-changed(MeasurementUnit.mm); }
                    }

                    Text {
                        text: "mm";
                        color: root.measurement-unit == MeasurementUnit.mm ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.measurement-unit == MeasurementUnit.inches ? #4da3d940 : in-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.measurement-unit == MeasurementUnit.inches ? 1px : 0px;
                    border-color: #4da3d9;

                    in-touch := TouchArea {
                        clicked => { root.measurement-unit-changed(MeasurementUnit.inches); }
                    }

                    Text {
                        text: "in";
                        color: root.measurement-unit == MeasurementUnit.inches ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}

export component Viewport inherits Rectangle {
    in property <image> content;
    in property <ViewportInfo> viewport-info;
    in property <image> minimap-thumbnail;
    in property <MinimapRect> minimap-rect;
    in property <bool> show-minimap: true;
    in property <[MetadataItem]> metadata-items: [];
    in property <bool> show-metadata: false;
    in property <string> status-text: "";
    in property <bool> is-loading: false;
    in property <bool> debug-mode: false;
    in property <float> fps: 0;
    in property <float> zoom-slider-position: 0.5;
    in property <ToolType> current-tool: ToolType.navigate;
    in property <ROIRect> roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in property <[MeasurementLine]> measurements: [];
    in property <MeasurementLine> candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    in property <HudSettings> hud;

    callback pan(float, float);
    callback zoom(float, float, float);
    callback fit-to-view();
    callback start-pan(float, float);
    callback end-pan();
    callback minimap-navigate(float, float);
    callback zoom-slider-changed(float);
    callback file-dropped(string);
    callback tool-mouse-down(float, float);
    callback tool-mouse-move(float, float);
    callback tool-mouse-up(float, float);
    callback cancel-tool();
    callback close-tab();
    callback hud-toggle-scale-bar();
    callback hud-toggle-dropdown();
    callback hud-gamma-changed(float);
    callback hud-brightness-changed(float);
    callback hud-contrast-changed(float);
    callback hud-measurement-unit-changed(MeasurementUnit);
    callback hud-reset-adjustments();
    callback hud-zoom-input(float);

    out property <length> viewport-width: self.width;
    out property <length> viewport-height: self.height;
    property <length> metadata-hud-height: show-metadata && metadata-items.length > 0 ? 52px + metadata-items.length * 22px : 0px;

    background: Theme.viewport-bg;

    Rectangle {
        clip: true;
        width: parent.width;
        height: parent.height;

        Image {
            width: 100%;
            height: 100%;
            source: content;
            image-fit: fill;
        }

        if root.roi-rect.visible: Rectangle {
            Rectangle {
                x: 0;
                y: 0;
                width: 100%;
                height: root.roi-rect.y * 1px;
                background: #00000080;
            }
            Rectangle {
                x: 0;
                y: (root.roi-rect.y + root.roi-rect.height) * 1px;
                width: 100%;
                height: parent.height - (root.roi-rect.y + root.roi-rect.height) * 1px;
                background: #00000080;
            }
            Rectangle {
                x: 0;
                y: root.roi-rect.y * 1px;
                width: root.roi-rect.x * 1px;
                height: root.roi-rect.height * 1px;
                background: #00000080;
            }
            Rectangle {
                x: (root.roi-rect.x + root.roi-rect.width) * 1px;
                y: root.roi-rect.y * 1px;
                width: parent.width - (root.roi-rect.x + root.roi-rect.width) * 1px;
                height: root.roi-rect.height * 1px;
                background: #00000080;
            }

            Rectangle {
                x: root.roi-rect.x * 1px - 1px;
                y: root.roi-rect.y * 1px - 1px;
                width: root.roi-rect.width * 1px + 2px;
                height: root.roi-rect.height * 1px + 2px;
                background: transparent;
                border-width: 1px;
                border-color: black;
            }

            Rectangle {
                x: root.roi-rect.x * 1px + 1px;
                y: root.roi-rect.y * 1px + 1px;
                width: root.roi-rect.width * 1px - 2px;
                height: root.roi-rect.height * 1px - 2px;
                background: transparent;
                border-width: 1px;
                border-color: black;
            }

            Rectangle {
                x: root.roi-rect.x * 1px;
                y: root.roi-rect.y * 1px;
                width: root.roi-rect.width * 1px;
                height: root.roi-rect.height * 1px;
                background: transparent;
                border-width: 1px;
                border-color: white;
                clip: true;

                property <length> stripe-period: 16px;
                property <length> stripe-offset: root.roi-rect.ant-offset * 1px;

                for i in 100: Rectangle {
                    x: i * parent.stripe-period - parent.stripe-offset;
                    y: -1px;
                    width: parent.stripe-period / 2;
                    height: 3px;
                    background: black;
                }

                for i in 100: Rectangle {
                    x: i * parent.stripe-period - parent.stripe-period + parent.stripe-offset;
                    y: parent.height - 2px;
                    width: parent.stripe-period / 2;
                    height: 3px;
                    background: black;
                }

                for i in 100: Rectangle {
                    x: -1px;
                    y: i * parent.stripe-period - parent.stripe-offset;
                    width: 3px;
                    height: parent.stripe-period / 2;
                    background: black;
                }

                for i in 100: Rectangle {
                    x: parent.width - 2px;
                    y: i * parent.stripe-period - parent.stripe-period + parent.stripe-offset;
                    width: 3px;
                    height: parent.stripe-period / 2;
                    background: black;
                }
            }
        }

        for measurement in root.measurements: Rectangle {
            width: 100%;
            height: 100%;

            Path {
                viewbox-width: self.width / 1px;
                viewbox-height: self.height / 1px;
                stroke: #2ECC71;
                stroke-width: 2px;
                stroke-line-cap: round;
                MoveTo { x: measurement.x1; y: measurement.y1; }
                LineTo { x: measurement.x2; y: measurement.y2; }
            }

            Rectangle {
                x: measurement.x1 * 1px - 4px;
                y: measurement.y1 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #2ECC71;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: measurement.x2 * 1px - 4px;
                y: measurement.y2 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #2ECC71;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: (measurement.x1 + measurement.x2) / 2 * 1px - self.width / 2;
                y: (measurement.y1 + measurement.y2) / 2 * 1px - self.height - 6px;
                width: measurement-text.preferred-width + 14px;
                height: measurement-text.preferred-height + 6px;
                border-radius: self.height / 2;
                background: #1a1a1aee;
                border-width: 1px;
                border-color: #2ECC7180;
                drop-shadow-blur: 4px;
                drop-shadow-color: #00000066;

                measurement-text := Text {
                    x: 7px;
                    y: 3px;
                    text: measurement.distance-um >= 1000 ? Math.round(measurement.distance-um / 10) / 100 + " mm"
                        : measurement.distance-um > 0 ? Math.round(measurement.distance-um * 100) / 100 + " µm"
                        : Math.round(Math.sqrt((measurement.x2 - measurement.x1) * (measurement.x2 - measurement.x1) + (measurement.y2 - measurement.y1) * (measurement.y2 - measurement.y1)) * 10) / 10 + " px";
                    color: white;
                    font-size: 11px;
                    font-weight: 500;
                }
            }
        }

        if root.candidate-measurement.visible: Rectangle {
            width: 100%;
            height: 100%;

            Path {
                viewbox-width: self.width / 1px;
                viewbox-height: self.height / 1px;
                stroke: #F1C40F;
                stroke-width: 2px;
                stroke-line-cap: round;
                MoveTo { x: root.candidate-measurement.x1; y: root.candidate-measurement.y1; }
                LineTo { x: root.candidate-measurement.x2; y: root.candidate-measurement.y2; }
            }

            Rectangle {
                x: root.candidate-measurement.x1 * 1px - 4px;
                y: root.candidate-measurement.y1 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #F1C40F;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: root.candidate-measurement.x2 * 1px - 4px;
                y: root.candidate-measurement.y2 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #F1C40F;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: (root.candidate-measurement.x1 + root.candidate-measurement.x2) / 2 * 1px - self.width / 2;
                y: (root.candidate-measurement.y1 + root.candidate-measurement.y2) / 2 * 1px - self.height - 6px;
                width: candidate-text.preferred-width + 14px;
                height: candidate-text.preferred-height + 6px;
                border-radius: self.height / 2;
                background: #1a1a1aee;
                border-width: 1px;
                border-color: #F1C40F80;
                drop-shadow-blur: 4px;
                drop-shadow-color: #00000066;

                candidate-text := Text {
                    x: 7px;
                    y: 3px;
                    text: root.candidate-measurement.distance-um >= 1000 ? Math.round(root.candidate-measurement.distance-um / 10) / 100 + " mm"
                        : root.candidate-measurement.distance-um > 0 ? Math.round(root.candidate-measurement.distance-um * 100) / 100 + " µm"
                        : Math.round(Math.sqrt((root.candidate-measurement.x2 - root.candidate-measurement.x1) * (root.candidate-measurement.x2 - root.candidate-measurement.x1) + (root.candidate-measurement.y2 - root.candidate-measurement.y1) * (root.candidate-measurement.y2 - root.candidate-measurement.y1)) * 10) / 10 + " px";
                    color: white;
                    font-size: 11px;
                    font-weight: 500;
                }
            }
        }

        if is-loading: Rectangle {
            x: parent.width / 2 - 40px;
            y: parent.height / 2 - 40px;
            width: 80px;
            height: 80px;
            background: Theme.surface;
            border-radius: 8px;

            Text {
                text: "Loading...";
                color: Theme.text-primary;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    touch := TouchArea {
        width: 100%;
        height: parent.height;

        property <length> drag-start-x;
        property <length> drag-start-y;
        property <bool> is-dragging: false;
        property <bool> is-tool-dragging: false;

        clicked => {
            focus-scope.focus();
        }

        pointer-event(e) => {
            if e.kind == PointerEventKind.down {
                focus-scope.focus();
            }

            if e.kind == PointerEventKind.down && (e.button == PointerEventButton.right || e.button == PointerEventButton.middle) {
                self.is-dragging = true;
                self.drag-start-x = self.mouse-x;
                self.drag-start-y = self.mouse-y;
                root.start-pan(self.mouse-x / 1px, self.mouse-y / 1px);
            } else if e.kind == PointerEventKind.up && (e.button == PointerEventButton.right || e.button == PointerEventButton.middle) {
                self.is-dragging = false;
                root.end-pan();
            } else if e.kind == PointerEventKind.down && e.button == PointerEventButton.left {
                if root.current-tool == ToolType.navigate {
                    self.is-dragging = true;
                    self.drag-start-x = self.mouse-x;
                    self.drag-start-y = self.mouse-y;
                    root.start-pan(self.mouse-x / 1px, self.mouse-y / 1px);
                } else {
                    self.is-tool-dragging = true;
                    root.tool-mouse-down(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            } else if e.kind == PointerEventKind.up && e.button == PointerEventButton.left {
                if root.current-tool == ToolType.navigate {
                    self.is-dragging = false;
                    root.end-pan();
                } else {
                    self.is-tool-dragging = false;
                    root.tool-mouse-up(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            } else if e.kind == PointerEventKind.move {
                if self.is-dragging {
                    let dx = (self.mouse-x - self.drag-start-x) / 1px;
                    let dy = (self.mouse-y - self.drag-start-y) / 1px;
                    self.drag-start-x = self.mouse-x;
                    self.drag-start-y = self.mouse-y;
                    root.pan(dx, dy);
                } else if self.is-tool-dragging || root.current-tool != ToolType.navigate {
                    root.tool-mouse-move(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            }
        }

        scroll-event(e) => {
            let factor = e.delta-y > 0 ? 1.05 : (1.0 / 1.05);
            root.zoom(factor, touch.mouse-x / 1px, touch.mouse-y / 1px);
            return accept;
        }
    }

    if show-minimap: Minimap {
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 16px;
        thumbnail: minimap-thumbnail;
        viewport-rect: minimap-rect;
        image-width: viewport-info.image-width;
        image-height: viewport-info.image-height;
        navigate(nx, ny) => { root.minimap-navigate(nx, ny); }
    }

    if show-minimap: ZoomSlider {
        x: parent.width - 16px - 150px - self.width - 8px;
        y: parent.height - self.height - 16px;
        value: root.zoom-slider-position;
        zoom-level: root.viewport-info.zoom;
        value-changed(value) => { root.zoom-slider-changed(value); }
    }

    if show-metadata && metadata-items.length > 0: MetadataHud {
        x: parent.width - self.width - 16px;
        y: 16px;
        items: root.metadata-items;
    }

    if debug-mode: Rectangle {
        x: parent.width - self.width - 8px;
        y: root.metadata-hud-height > 0px ? root.metadata-hud-height + 24px : 8px;
        width: 70px;
        height: 24px;
        background: #000000aa;
        border-radius: 4px;

        Text {
            x: 8px;
            y: 4px;
            text: Math.round(fps) + " FPS";
            color: fps >= 25 ? #00ff00 : fps >= 15 ? #ffff00 : #ff0000;
            font-size: 12px;
            font-weight: 600;
        }
    }

    // HUD toolbar (top-left)
    if root.hud.show-hud-toolbar: HudToolbar {
        x: 16px;
        y: 16px;
        zoom-level: root.viewport-info.zoom;
        show-scale-bar: root.hud.show-scale-bar;
        dropdown-open: root.hud.hud-dropdown-open;
        has-adjustments: (root.hud.gamma - 1.0) > 0.01 || (1.0 - root.hud.gamma) > 0.01
            || root.hud.brightness > 0.01 || root.hud.brightness < -0.01
            || (root.hud.contrast - 1.0) > 0.01 || (1.0 - root.hud.contrast) > 0.01;
        fit-to-view => { root.fit-to-view(); }
        toggle-scale-bar => { root.hud-toggle-scale-bar(); }
        toggle-dropdown => { root.hud-toggle-dropdown(); }
        zoom-input(v) => { root.hud-zoom-input(v); }
    }

    // HUD settings dropdown (below toolbar)
    if root.hud.show-hud-toolbar && root.hud.hud-dropdown-open: HudSettingsPanel {
        x: 16px;
        y: 60px;
        gamma: root.hud.gamma;
        brightness: root.hud.brightness;
        contrast: root.hud.contrast;
        measurement-unit: root.hud.measurement-unit;
        has-adjustments: (root.hud.gamma - 1.0) > 0.01 || (1.0 - root.hud.gamma) > 0.01
            || root.hud.brightness > 0.01 || root.hud.brightness < -0.01
            || (root.hud.contrast - 1.0) > 0.01 || (1.0 - root.hud.contrast) > 0.01;
        gamma-changed(v) => { root.hud-gamma-changed(v); }
        brightness-changed(v) => { root.hud-brightness-changed(v); }
        contrast-changed(v) => { root.hud-contrast-changed(v); }
        measurement-unit-changed(u) => { root.hud-measurement-unit-changed(u); }
        reset-adjustments => { root.hud-reset-adjustments(); }
    }

    // Scale bar (bottom-left)
    if root.hud.show-scale-bar: ScaleBar {
        x: 16px;
        y: parent.height - self.height - 16px;
        zoom: root.viewport-info.zoom;
        mpp-x: root.hud.mpp-x;
        mpp-y: root.hud.mpp-y;
        unit: root.hud.measurement-unit;
    }

    focus-scope := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(e) => {
            if e.text == "w" && e.modifiers.control {
                root.close-tab();
                return accept;
            }
            if e.text == Key.Escape {
                root.cancel-tool();
                return accept;
            }
            return reject;
        }
    }
}