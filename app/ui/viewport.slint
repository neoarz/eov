import { Theme } from "theme.slint";
import {
    HudSettings,
    MeasurementLine,
    MeasurementUnit,
    MetadataItem,
    MinimapRect,
    ROIRect,
    StainNormalization,
    ToolType,
    ViewportInfo,
} from "types.slint";
import { Minimap, ZoomSlider } from "minimap.slint";
import { MetadataHud } from "metadata-hud.slint";
import { ScaleBar } from "scale-bar.slint";
import { HudToolbar } from "hud-toolbar.slint";
import { HudSettingsPanel } from "hud-settings.slint";

export { Minimap, ZoomSlider, MetadataHud, ScaleBar, HudToolbar, HudSettingsPanel }

export component Viewport inherits Rectangle {
    in property <image> content;
    in property <ViewportInfo> viewport-info;
    in property <image> minimap-thumbnail;
    in property <MinimapRect> minimap-rect;
    in property <bool> show-minimap: true;
    in property <[MetadataItem]> metadata-items: [];
    in property <bool> show-metadata: false;
    in property <string> status-text: "";
    in property <bool> is-loading: false;
    in property <bool> debug-mode: false;
    in property <float> fps: 0;
    in property <float> zoom-slider-position: 0.5;
    in property <ToolType> current-tool: ToolType.navigate;
    in property <ROIRect> roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in property <[MeasurementLine]> measurements: [];
    in property <MeasurementLine> candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    in property <HudSettings> hud;

    callback pan(float, float);
    callback zoom(float, float, float);
    callback fit-to-view();
    callback start-pan(float, float);
    callback end-pan();
    callback minimap-navigate(float, float);
    callback zoom-slider-changed(float);
    callback file-dropped(string);
    callback tool-mouse-down(float, float);
    callback tool-mouse-move(float, float);
    callback tool-mouse-up(float, float);
    callback viewport-context-menu(length, length);
    callback cancel-tool();
    callback close-tab();
    callback hud-toggle-scale-bar();
    callback hud-toggle-dropdown();
    callback hud-sharpness-changed(float);
    callback hud-gamma-changed(float);
    callback hud-brightness-changed(float);
    callback hud-contrast-changed(float);
    callback hud-measurement-unit-changed(MeasurementUnit);
    callback hud-stain-normalization-changed(StainNormalization);
    callback hud-reset-adjustments();
    callback hud-zoom-input(float);
    callback hud-deconv-h-intensity-changed(float);
    callback hud-deconv-e-intensity-changed(float);
    callback hud-deconv-h-visibility-toggled();
    callback hud-deconv-e-visibility-toggled();
    callback hud-deconv-h-view-toggled();
    callback hud-deconv-e-view-toggled();

    out property <length> viewport-width: self.width;
    out property <length> viewport-height: self.height;
    property <length> metadata-hud-height: show-metadata && metadata-items.length > 0 ? 52px + metadata-items.length * 22px : 0px;

    background: Theme.viewport-bg;

    Rectangle {
        clip: true;
        width: parent.width;
        height: parent.height;

        Image {
            width: 100%;
            height: 100%;
            source: content;
            image-fit: fill;
        }

        if root.roi-rect.visible: Rectangle {
            Rectangle {
                x: 0;
                y: 0;
                width: 100%;
                height: root.roi-rect.y * 1px;
                background: #00000080;
            }

            Rectangle {
                x: 0;
                y: (root.roi-rect.y + root.roi-rect.height) * 1px;
                width: 100%;
                height: parent.height - (root.roi-rect.y + root.roi-rect.height) * 1px;
                background: #00000080;
            }

            Rectangle {
                x: 0;
                y: root.roi-rect.y * 1px;
                width: root.roi-rect.x * 1px;
                height: root.roi-rect.height * 1px;
                background: #00000080;
            }

            Rectangle {
                x: (root.roi-rect.x + root.roi-rect.width) * 1px;
                y: root.roi-rect.y * 1px;
                width: parent.width - (root.roi-rect.x + root.roi-rect.width) * 1px;
                height: root.roi-rect.height * 1px;
                background: #00000080;
            }

            Rectangle {
                x: root.roi-rect.x * 1px - 1px;
                y: root.roi-rect.y * 1px - 1px;
                width: root.roi-rect.width * 1px + 2px;
                height: root.roi-rect.height * 1px + 2px;
                background: transparent;
                border-width: 1px;
                border-color: black;
            }

            Rectangle {
                x: root.roi-rect.x * 1px + 1px;
                y: root.roi-rect.y * 1px + 1px;
                width: root.roi-rect.width * 1px - 2px;
                height: root.roi-rect.height * 1px - 2px;
                background: transparent;
                border-width: 1px;
                border-color: black;
            }

            Rectangle {
                x: root.roi-rect.x * 1px;
                y: root.roi-rect.y * 1px;
                width: root.roi-rect.width * 1px;
                height: root.roi-rect.height * 1px;
                background: transparent;
                border-width: 1px;
                border-color: white;
                clip: true;

                property <length> stripe-period: 16px;
                property <length> stripe-offset: root.roi-rect.ant-offset * 1px;

                for i in 100: Rectangle {
                    x: i * parent.stripe-period - parent.stripe-offset;
                    y: -1px;
                    width: parent.stripe-period / 2;
                    height: 3px;
                    background: black;
                }

                for i in 100: Rectangle {
                    x: i * parent.stripe-period - parent.stripe-period + parent.stripe-offset;
                    y: parent.height - 2px;
                    width: parent.stripe-period / 2;
                    height: 3px;
                    background: black;
                }

                for i in 100: Rectangle {
                    x: -1px;
                    y: i * parent.stripe-period - parent.stripe-offset;
                    width: 3px;
                    height: parent.stripe-period / 2;
                    background: black;
                }

                for i in 100: Rectangle {
                    x: parent.width - 2px;
                    y: i * parent.stripe-period - parent.stripe-period + parent.stripe-offset;
                    width: 3px;
                    height: parent.stripe-period / 2;
                    background: black;
                }
            }
        }

        for measurement in root.measurements: Rectangle {
            width: 100%;
            height: 100%;

            Path {
                viewbox-width: self.width / 1px;
                viewbox-height: self.height / 1px;
                stroke: #2ECC71;
                stroke-width: 2px;
                stroke-line-cap: round;
                MoveTo {
                    x: measurement.x1;
                    y: measurement.y1;
                }

                LineTo {
                    x: measurement.x2;
                    y: measurement.y2;
                }
            }

            Rectangle {
                x: measurement.x1 * 1px - 4px;
                y: measurement.y1 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #2ECC71;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: measurement.x2 * 1px - 4px;
                y: measurement.y2 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #2ECC71;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: (measurement.x1 + measurement.x2) / 2 * 1px - self.width / 2;
                y: (measurement.y1 + measurement.y2) / 2 * 1px - self.height - 6px;
                width: measurement-text.preferred-width + 14px;
                height: measurement-text.preferred-height + 6px;
                border-radius: self.height / 2;
                background: #1a1a1aee;
                border-width: 1px;
                border-color: #2ECC7180;
                drop-shadow-blur: 4px;
                drop-shadow-color: #00000066;

                measurement-text := Text {
                    x: 7px;
                    y: 3px;
                    text: measurement.distance-um >= 1000 ? Math.round(measurement.distance-um / 10) / 100 + " mm" : measurement.distance-um > 0 ? Math.round(measurement.distance-um * 100) / 100 + " µm" : Math.round(Math.sqrt((measurement.x2 - measurement.x1) * (measurement.x2 - measurement.x1) + (measurement.y2 - measurement.y1) * (measurement.y2 - measurement.y1)) * 10) / 10 + " px";
                    color: white;
                    font-size: 11px;
                    font-weight: 500;
                }
            }
        }

        if root.candidate-measurement.visible: Rectangle {
            width: 100%;
            height: 100%;

            Path {
                viewbox-width: self.width / 1px;
                viewbox-height: self.height / 1px;
                stroke: #F1C40F;
                stroke-width: 2px;
                stroke-line-cap: round;
                MoveTo {
                    x: root.candidate-measurement.x1;
                    y: root.candidate-measurement.y1;
                }

                LineTo {
                    x: root.candidate-measurement.x2;
                    y: root.candidate-measurement.y2;
                }
            }

            Rectangle {
                x: root.candidate-measurement.x1 * 1px - 4px;
                y: root.candidate-measurement.y1 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #F1C40F;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: root.candidate-measurement.x2 * 1px - 4px;
                y: root.candidate-measurement.y2 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #F1C40F;
                border-width: 1.5px;
                border-color: white;
            }

            Rectangle {
                x: (root.candidate-measurement.x1 + root.candidate-measurement.x2) / 2 * 1px - self.width / 2;
                y: (root.candidate-measurement.y1 + root.candidate-measurement.y2) / 2 * 1px - self.height - 6px;
                width: candidate-text.preferred-width + 14px;
                height: candidate-text.preferred-height + 6px;
                border-radius: self.height / 2;
                background: #1a1a1aee;
                border-width: 1px;
                border-color: #F1C40F80;
                drop-shadow-blur: 4px;
                drop-shadow-color: #00000066;

                candidate-text := Text {
                    x: 7px;
                    y: 3px;
                    text: root.candidate-measurement.distance-um >= 1000 ? Math.round(root.candidate-measurement.distance-um / 10) / 100 + " mm" : root.candidate-measurement.distance-um > 0 ? Math.round(root.candidate-measurement.distance-um * 100) / 100 + " µm" : Math.round(Math.sqrt((root.candidate-measurement.x2 - root.candidate-measurement.x1) * (root.candidate-measurement.x2 - root.candidate-measurement.x1) + (root.candidate-measurement.y2 - root.candidate-measurement.y1) * (root.candidate-measurement.y2 - root.candidate-measurement.y1)) * 10) / 10 + " px";
                    color: white;
                    font-size: 11px;
                    font-weight: 500;
                }
            }
        }

        if is-loading: Rectangle {
            x: parent.width / 2 - 40px;
            y: parent.height / 2 - 40px;
            width: 80px;
            height: 80px;
            background: Theme.surface;
            border-radius: 8px;

            Text {
                text: "Loading...";
                color: Theme.text-primary;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }

    touch := TouchArea {
        width: 100%;
        height: parent.height;

        property <bool> is-dragging: false;
        property <bool> is-tool-dragging: false;
        property <bool> drag-from-secondary: false;
        property <bool> secondary-dragged: false;

        clicked => {
            focus-scope.focus();
        }

        pointer-event(e) => {
            if e.kind == PointerEventKind.down {
                focus-scope.focus();
            }
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                self.is-dragging = true;
                self.drag-from-secondary = true;
                self.secondary-dragged = false;
                root.start-pan(self.mouse-x / 1px, self.mouse-y / 1px);
            } else if e.kind == PointerEventKind.up && e.button == PointerEventButton.right {
                let open-menu = self.drag-from-secondary && !self.secondary-dragged;
                self.is-dragging = false;
                self.drag-from-secondary = false;
                self.secondary-dragged = false;
                root.end-pan();
                if open-menu {
                    root.viewport-context-menu(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            } else if e.kind == PointerEventKind.down && e.button == PointerEventButton.middle {
                self.is-dragging = true;
                self.drag-from-secondary = false;
                root.start-pan(self.mouse-x / 1px, self.mouse-y / 1px);
            } else if e.kind == PointerEventKind.up && e.button == PointerEventButton.middle {
                self.is-dragging = false;
                self.drag-from-secondary = false;
                root.end-pan();
            } else if e.kind == PointerEventKind.down && e.button == PointerEventButton.left {
                if root.current-tool == ToolType.navigate {
                    self.is-dragging = true;
                    root.start-pan(self.mouse-x / 1px, self.mouse-y / 1px);
                } else {
                    self.is-tool-dragging = true;
                    root.tool-mouse-down(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            } else if e.kind == PointerEventKind.up && e.button == PointerEventButton.left {
                if root.current-tool == ToolType.navigate {
                    self.is-dragging = false;
                    root.end-pan();
                } else {
                    self.is-tool-dragging = false;
                    root.tool-mouse-up(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            } else if e.kind == PointerEventKind.move {
                if self.is-dragging {
                    if self.drag-from-secondary {
                        self.secondary-dragged = true;
                    }
                    root.pan(self.mouse-x / 1px, self.mouse-y / 1px);
                } else if self.is-tool-dragging || root.current-tool != ToolType.navigate {
                    root.tool-mouse-move(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            }
        }

        scroll-event(e) => {
            let factor = e.delta-y > 0 ? 1.05 : (1.0 / 1.05);
            root.zoom(factor, touch.mouse-x / 1px, touch.mouse-y / 1px);
            accept
        }
    }

    if show-minimap: Minimap {
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 16px;
        thumbnail: minimap-thumbnail;
        viewport-rect: minimap-rect;
        image-width: viewport-info.image-width;
        image-height: viewport-info.image-height;
        navigate(nx, ny) => {
            root.minimap-navigate(nx, ny);
        }
    }

    if show-minimap: ZoomSlider {
        x: parent.width - 16px - 150px - self.width - 8px;
        y: parent.height - self.height - 16px;
        value: root.zoom-slider-position;
        zoom-level: root.viewport-info.zoom;
        value-changed(value) => {
            root.zoom-slider-changed(value);
        }
    }

    if show-metadata && metadata-items.length > 0: MetadataHud {
        x: parent.width - self.width - 16px;
        y: 16px;
        items: root.metadata-items;
    }

    if debug-mode: Rectangle {
        x: parent.width - self.width - 8px;
        y: root.metadata-hud-height > 0px ? root.metadata-hud-height + 24px : 8px;
        width: 70px;
        height: 24px;
        background: #000000aa;
        border-radius: 4px;

        Text {
            x: 8px;
            y: 4px;
            text: Math.round(fps) + " FPS";
            color: fps >= 25 ? #00ff00 : fps >= 15 ? #ffff00 : #ff0000;
            font-size: 12px;
            font-weight: 600;
        }
    }

    // HUD toolbar (top-left)
    if root.hud.show-hud-toolbar: HudToolbar {
        x: 16px;
        y: 16px;
        zoom-level: root.viewport-info.zoom;
        show-scale-bar: root.hud.show-scale-bar;
        dropdown-open: root.hud.hud-dropdown-open;
        has-adjustments: root.hud.sharpness > 0.01 || (root.hud.gamma - 1.0) > 0.01 || (1.0 - root.hud.gamma) > 0.01 || root.hud.brightness > 0.01 || root.hud.brightness < -0.01 || (root.hud.contrast - 1.0) > 0.01 || (1.0 - root.hud.contrast) > 0.01;
        fit-to-view => {
            root.fit-to-view();
        }
        toggle-scale-bar => {
            root.hud-toggle-scale-bar();
        }
        toggle-dropdown => {
            root.hud-toggle-dropdown();
        }
        zoom-input(v) => {
            root.hud-zoom-input(v);
        }
    }

    // HUD settings dropdown (below toolbar)
    if root.hud.show-hud-toolbar && root.hud.hud-dropdown-open: HudSettingsPanel {
        x: 16px;
        y: 60px;
        sharpness: root.hud.sharpness;
        gamma: root.hud.gamma;
        brightness: root.hud.brightness;
        contrast: root.hud.contrast;
        measurement-unit: root.hud.measurement-unit;
        stain-normalization: root.hud.stain-normalization;
        has-adjustments: root.hud.sharpness > 0.01 || (root.hud.gamma - 1.0) > 0.01 || (1.0 - root.hud.gamma) > 0.01 || root.hud.brightness > 0.01 || root.hud.brightness < -0.01 || (root.hud.contrast - 1.0) > 0.01 || (1.0 - root.hud.contrast) > 0.01 || root.hud.stain-normalization != StainNormalization.none;
        sharpness-changed(v) => {
            root.hud-sharpness-changed(v);
        }
        gamma-changed(v) => {
            root.hud-gamma-changed(v);
        }
        brightness-changed(v) => {
            root.hud-brightness-changed(v);
        }
        contrast-changed(v) => {
            root.hud-contrast-changed(v);
        }
        measurement-unit-changed(u) => {
            root.hud-measurement-unit-changed(u);
        }
        stain-normalization-changed(s) => {
            root.hud-stain-normalization-changed(s);
        }
        reset-adjustments => {
            root.hud-reset-adjustments();
        }
        deconv-hematoxylin-intensity: root.hud.deconv-hematoxylin-intensity;
        deconv-hematoxylin-visible: root.hud.deconv-hematoxylin-visible;
        deconv-eosin-intensity: root.hud.deconv-eosin-intensity;
        deconv-eosin-visible: root.hud.deconv-eosin-visible;
        deconv-isolated-channel: root.hud.deconv-isolated-channel;
        deconv-h-intensity-changed(v) => {
            root.hud-deconv-h-intensity-changed(v);
        }
        deconv-e-intensity-changed(v) => {
            root.hud-deconv-e-intensity-changed(v);
        }
        deconv-h-visibility-toggled => {
            root.hud-deconv-h-visibility-toggled();
        }
        deconv-e-visibility-toggled => {
            root.hud-deconv-e-visibility-toggled();
        }
        deconv-h-view-toggled => {
            root.hud-deconv-h-view-toggled();
        }
        deconv-e-view-toggled => {
            root.hud-deconv-e-view-toggled();
        }
    }

    // Scale bar (bottom-left)
    if root.hud.show-scale-bar: ScaleBar {
        x: 16px;
        y: parent.height - self.height - 16px;
        zoom: root.viewport-info.zoom;
        mpp-x: root.hud.mpp-x;
        mpp-y: root.hud.mpp-y;
        unit: root.hud.measurement-unit;
    }

    focus-scope := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(e) => {
            if e.text == "w" && e.modifiers.control {
                root.close-tab();
                accept
            }
            if e.text == Key.Escape {
                root.cancel-tool();
                accept
            }
            reject
        }
    }
}
