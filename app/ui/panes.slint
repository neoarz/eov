import { Theme } from "theme.slint";
import { PaneViewData, RecentFileData, ToolType } from "types.slint";
import { HomeScreen } from "home-screen.slint";
import { TabBar } from "tab-controls.slint";
import { Viewport } from "viewport.slint";

component PaneView inherits Rectangle {
    in property <PaneViewData> pane-data;
    in property <string> status-text;
    in property <[RecentFileData]> recent-files: [];
    in property <bool> show-minimap: true;
    in property <bool> show-metadata: false;
    in property <ToolType> current-tool: ToolType.navigate;
    in property <bool> debug-mode: false;
    in property <float> fps: 0;
    in property <int> focused-pane: 0;
    in property <int> dragging-tab-id: -1;
    in property <int> drag-source-pane: -1;
    in property <int> drag-source-index: -1;
    in property <length> drag-abs-x: -1px;
    in property <int> drop-target-pane: -1;
    in property <int> split-drop-side: -1;
    in property <int> os-file-hover-pane: -1;
    in property <int> os-file-hover-side: -1;

    callback tab-activated(int, int);
    callback tab-close-requested(int, int);
    callback tab-context-menu(int, int, length, length);
    callback new-tab-requested(int);
    callback open-file-requested();
    callback open-recent-file(string);
    callback viewport-pan(float, float);
    callback viewport-zoom(float, float, float);
    callback viewport-fit-to-view();
    callback viewport-start-pan(float, float);
    callback viewport-end-pan();
    callback minimap-navigate(float, float);
    callback file-dropped(string);
    callback pane-focused(int);
    callback tab-drag-started(int, int, string, int, length, length);
    callback tab-drag-moved(length, length);
    callback tab-drag-ended(length, length);
    callback zoom-slider-changed(int, float);
    callback tool-mouse-down(float, float);
    callback tool-mouse-move(float, float);
    callback tool-mouse-up(float, float);
    callback cancel-tool();
    callback close-active-tab();
    callback tab-tooltip-changed(bool, string, length, length);

    border-width: 0px;
    border-color: transparent;
    background: dragging-tab-id != -1 && drop-target-pane == pane-data.id ? #ffffff08 : transparent;

    VerticalLayout {
        pane-tab-bar := TabBar {
            pane-id: root.pane-data.id;
            tabs: root.pane-data.tabs;
            dragging-tab-id: root.dragging-tab-id;
            drag-source-pane: root.drag-source-pane;
            drag-source-index: root.drag-source-index;
            drag-abs-x: root.drag-abs-x;
            is-drop-target: root.drop-target-pane == root.pane-data.id;
            show-drop-indicator: root.split-drop-side == -1;
            tab-activated(pane, id) => { root.tab-activated(pane, id); }
            tab-close-requested(pane, id) => { root.tab-close-requested(pane, id); }
            tab-context-menu(pane, id, x, y) => { root.tab-context-menu(pane, id, x, y); }
            new-tab-requested(pane) => { root.new-tab-requested(pane); }
            tab-drag-started(id, pane, title, index, abs-x, abs-y) => { root.tab-drag-started(id, pane, title, index, abs-x, abs-y); }
            tab-drag-moved(abs-x, abs-y) => { root.tab-drag-moved(abs-x, abs-y); }
            tab-drag-ended(abs-x, abs-y) => { root.tab-drag-ended(abs-x, abs-y); }
            tab-tooltip-changed(visible, text, cx, ty) => { root.tab-tooltip-changed(visible, text, cx, ty); }
        }

        Rectangle {
            vertical-stretch: 1;

            if root.pane-data.is-home-tab || root.pane-data.tabs.length == 0: HomeScreen {
                recent-files: root.recent-files;
                open-file-requested => { root.pane-focused(root.pane-data.id); root.open-file-requested(); }
                open-recent-file(path) => { root.pane-focused(root.pane-data.id); root.open-recent-file(path); }
            }

            if !root.pane-data.is-home-tab && root.pane-data.tabs.length > 0: Viewport {
                content: root.pane-data.content;
                viewport-info: root.pane-data.viewport-info;
                minimap-thumbnail: root.pane-data.minimap-thumbnail;
                minimap-rect: root.pane-data.minimap-rect;
                show-minimap: root.show-minimap;
                metadata-items: root.pane-data.metadata-items;
                show-metadata: root.show-metadata;
                status-text: root.status-text;
                is-loading: root.pane-data.is-loading;
                current-tool: root.current-tool;
                roi-rect: root.pane-data.roi-rect;
                measurements: root.pane-data.measurements;
                candidate-measurement: root.pane-data.candidate-measurement;
                debug-mode: root.debug-mode;
                fps: root.fps;
                zoom-slider-position: root.pane-data.zoom-slider-position;

                pan(dx, dy) => { root.pane-focused(root.pane-data.id); root.viewport-pan(dx, dy); }
                zoom(f, x, y) => { root.pane-focused(root.pane-data.id); root.viewport-zoom(f, x, y); }
                fit-to-view => { root.pane-focused(root.pane-data.id); root.viewport-fit-to-view(); }
                start-pan(x, y) => { root.pane-focused(root.pane-data.id); root.viewport-start-pan(x, y); }
                end-pan => { root.viewport-end-pan(); }
                minimap-navigate(nx, ny) => { root.pane-focused(root.pane-data.id); root.minimap-navigate(nx, ny); }
                zoom-slider-changed(value) => { root.pane-focused(root.pane-data.id); root.zoom-slider-changed(root.pane-data.id, value); }
                file-dropped(path) => { root.pane-focused(root.pane-data.id); root.file-dropped(path); }
                tool-mouse-down(x, y) => { root.pane-focused(root.pane-data.id); root.tool-mouse-down(x, y); }
                tool-mouse-move(x, y) => { root.tool-mouse-move(x, y); }
                tool-mouse-up(x, y) => { root.tool-mouse-up(x, y); }
                cancel-tool => { root.cancel-tool(); }
                close-tab => { root.close-active-tab(); }
            }
        }
    }

    if dragging-tab-id != -1 && drop-target-pane == pane-data.id: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        border-width: 2px;
        border-color: white;
    }

    // OS file drag hover: center zone (no split) - subtle highlight
    if root.os-file-hover-pane == root.pane-data.id && root.os-file-hover-side == -1: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #3794ff15;
        border-width: 2px;
        border-color: #79b8ffff;
    }

    // OS file drag hover: split overlay (left or right)
    if root.os-file-hover-pane == root.pane-data.id && root.os-file-hover-side != -1: Rectangle {
        x: 0px;
        y: 35px;
        width: parent.width;
        height: parent.height - 35px;
        background: #0b122080;

        Rectangle {
            x: root.os-file-hover-side == 0 ? 10px : parent.width / 2 + 5px;
            y: 10px;
            width: parent.width / 2 - 15px;
            height: parent.height - 20px;
            border-radius: 8px;
            background: #3794ff33;
            border-width: 2px;
            border-color: #79b8ffff;

            Text {
                text: root.os-file-hover-side == 0 ? "Open Left" : "Open Right";
                color: white;
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            x: parent.width / 2 - 1px;
            y: 10px;
            width: 2px;
            height: parent.height - 20px;
            background: #ffffff66;
        }
    }

    if root.dragging-tab-id != -1 && root.drop-target-pane == root.pane-data.id && root.split-drop-side != -1: Rectangle {
        x: 0px;
        y: 35px;
        width: parent.width;
        height: parent.height - 35px;
        background: #0b122080;

        Rectangle {
            x: root.split-drop-side == 0 ? 10px : parent.width / 2 + 5px;
            y: 10px;
            width: parent.width / 2 - 15px;
            height: parent.height - 20px;
            border-radius: 8px;
            background: #3794ff33;
            border-width: 2px;
            border-color: #79b8ffff;

            Text {
                text: root.split-drop-side == 0 ? "Create Left Pane" : "Create Right Pane";
                color: white;
                font-size: 18px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        Rectangle {
            x: parent.width / 2 - 1px;
            y: 10px;
            width: 2px;
            height: parent.height - 20px;
            background: #ffffff66;
        }
    }
}

export component SplitPaneContainer inherits Rectangle {
    in property <[PaneViewData]> panes: [];
    in property <string> status-text;
    in property <bool> show-minimap: true;
    in property <bool> show-metadata: false;
    in property <bool> split-enabled: false;
    in property <int> focused-pane: 0;
    in property <bool> debug-mode: false;
    in property <float> fps: 0;
    in property <[RecentFileData]> recent-files: [];
    in property <int> dragging-tab-id: -1;
    in property <int> drag-source-pane: -1;
    in property <int> drag-source-index: -1;
    in property <string> dragging-tab-title: "";
    in property <int> drop-target-pane: -1;
    in property <int> split-drop-side: -1;
    in property <length> drag-abs-x: -1px;
    in property <int> os-file-hover-pane: -1;
    in property <int> os-file-hover-side: -1;
    in property <ToolType> current-tool: ToolType.navigate;
    property <length> pane-gap: 6px;
    property <int> pane-count: max(1, panes.length);
    property <length> pane-width: (self.width - max(0px, (pane-count - 1) * pane-gap)) / pane-count;
    property <length> pane-stride: pane-width + pane-gap;
    property <int> target-tab-count: drop-target-pane >= 0 && drop-target-pane < panes.length
        ? panes[drop-target-pane].tabs.length
        : 0;
    property <length> target-local-x: drop-target-pane >= 0
        ? drag-abs-x - drop-target-pane * pane-stride
        : -1px;
    property <length> target-slot-width: target-tab-count > 0
        ? max(101px, (pane-width - 40px) / target-tab-count)
        : 101px;
    property <int> raw-drop-index: dragging-tab-id == -1 || split-drop-side != -1 || drop-target-pane < 0
        ? -1
        : Math.max(0, Math.min(target-tab-count, Math.round((target-local-x - 4px) / target-slot-width)));
    out property <int> active-drop-index: drag-source-pane == drop-target-pane && drag-source-index >= 0
        && (raw-drop-index == drag_source_index || raw-drop-index == drag_source_index + 1)
        ? -1
        : raw-drop-index;

    callback tab-activated(int, int);
    callback tab-close-requested(int, int);
    callback tab-context-menu(int, int, length, length);
    callback new-tab-requested(int);
    callback open-file-requested();
    callback open-recent-file(string);
    callback viewport-pan(float, float);
    callback viewport-zoom(float, float, float);
    callback viewport-fit-to-view();
    callback viewport-start-pan(float, float);
    callback viewport-end-pan();
    callback minimap-navigate(float, float);
    callback file-dropped(string);
    callback pane-focused(int);
    callback split-position-changed(float);
    callback tab-drag-started(int, int, string, int, length, length);
    callback tab-drag-moved(length, length);
    callback tab-drag-ended(length, length);
    callback move-tab-to-pane(int, int, int);
    callback split-tab-by-drop(int, int);
    callback reorder-tab(int, int, int);
    callback clear-tab-drag();
    callback zoom-slider-changed(int, float);
    callback tool-mouse-down(float, float);
    callback tool-mouse-move(float, float);
    callback tool-mouse-up(float, float);
    callback cancel-tool();
    callback close-active-tab();
    callback tab-tooltip-changed(bool, string, length, length);

    background: Theme.background;

    HorizontalLayout {
        vertical-stretch: 1;
        spacing: root.pane-gap;

        for pane[i] in panes: PaneView {
            width: root.pane-width;
            pane-data: pane;
            status-text: root.status-text;
            recent-files: root.recent-files;
            show-minimap: root.show-minimap;
            show-metadata: root.show-metadata;
            current-tool: root.current-tool;
            debug-mode: root.debug-mode;
            fps: root.fps;
            focused-pane: root.focused-pane;
            dragging-tab-id: root.dragging-tab-id;
            drag-source-pane: root.drag-source-pane;
            drag-source-index: root.drag_source_index;
            drag-abs-x: root.drag-abs-x;
            drop-target-pane: root.drop-target-pane;
            split-drop-side: root.split-drop-side;
            os-file-hover-pane: root.os-file-hover-pane;
            os-file-hover-side: root.os-file-hover-side;

            tab-activated(pane-id, id) => { root.tab-activated(pane-id, id); }
            tab-close-requested(pane-id, id) => { root.tab-close-requested(pane-id, id); }
            tab-context-menu(pane-id, id, x, y) => { root.tab-context-menu(pane-id, id, x, y); }
            new-tab-requested(pane-id) => { root.new-tab-requested(pane-id); }
            open-file-requested => { root.open-file-requested(); }
            open-recent-file(path) => { root.open-recent-file(path); }
            viewport-pan(dx, dy) => { root.viewport-pan(dx, dy); }
            viewport-zoom(f, x, y) => { root.viewport-zoom(f, x, y); }
            viewport-fit-to-view => { root.viewport-fit-to-view(); }
            viewport-start-pan(x, y) => { root.viewport-start-pan(x, y); }
            viewport-end-pan => { root.viewport-end-pan(); }
            minimap-navigate(nx, ny) => { root.minimap-navigate(nx, ny); }
            file-dropped(path) => { root.file-dropped(path); }
            pane-focused(pane-id) => { root.pane-focused(pane-id); }
            tab-drag-started(id, pane-id, title, index, abs-x, abs-y) => { root.tab-drag-started(id, pane-id, title, index, abs-x, abs-y); }
            tab-drag-moved(abs-x, abs-y) => { root.tab-drag-moved(abs-x, abs-y); }
            tab-drag-ended(abs-x, abs-y) => { root.tab-drag-ended(abs-x, abs-y); }
            zoom-slider-changed(pane-id, value) => { root.zoom-slider-changed(pane-id, value); }
            tool-mouse-down(x, y) => { root.tool-mouse-down(x, y); }
            tool-mouse-move(x, y) => { root.tool-mouse-move(x, y); }
            tool-mouse-up(x, y) => { root.tool-mouse-up(x, y); }
            cancel-tool => { root.cancel-tool(); }
            close-active-tab => { root.close-active-tab(); }
            tab-tooltip-changed(visible, text, cx, ty) => { root.tab-tooltip-changed(visible, text, cx, ty); }
        }
    }
}