import { Theme } from "theme.slint";
import { ContextMenuItem, TabData } from "types.slint";

export component ToolButton inherits Rectangle {
    in property <string> icon;
    in property <string> tooltip-text;
    in property <bool> is-active: false;
    in property <bool> enabled: true;
    out property <bool> hovered: touch.has-hover;
    callback clicked();

    width: 32px;
    height: 28px;
    border-radius: 3px;
    background: is-active ? Theme.accent : (touch.has-hover && enabled ? Theme.surface-hover : transparent);
    border-width: is-active ? 0px : 0px;

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        alignment: center;
        Text {
            text: root.icon;
            color: is-active ? white : (root.enabled ? Theme.text-primary : Theme.text-secondary);
            font-size: 14px;
            vertical-alignment: center;
        }
    }

}

export component MinimapToolButton inherits Rectangle {
    in property <string> tooltip-text;
    in property <bool> is-active: false;
    in property <bool> enabled: true;
    out property <bool> hovered: touch.has-hover;
    callback clicked();

    width: 32px;
    height: 28px;
    border-radius: 3px;
    background: is-active ? Theme.accent : (touch.has-hover && enabled ? Theme.surface-hover : transparent);

    property <color> icon-color: root.enabled ? (root.is-active ? white : Theme.text-primary) : Theme.text-secondary;
    property <color> viewport-color: root.is-active ? white : Theme.accent;

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }

    Rectangle {
        x: parent.width / 2 - 8px;
        y: parent.height / 2 - 6px;
        width: 16px;
        height: 12px;
        background: transparent;
        border-width: 1px;
        border-color: root.icon-color;
        border-radius: 2px;

        Rectangle {
            x: 5px;
            y: 1px;
            width: 1px;
            height: parent.height - 2px;
            background: root.icon-color;
            opacity: 0.6;
        }

        Rectangle {
            x: 10px;
            y: 1px;
            width: 1px;
            height: parent.height - 2px;
            background: root.icon-color;
            opacity: 0.6;
        }

        Rectangle {
            x: 6px;
            y: 4px;
            width: 5px;
            height: 4px;
            background: transparent;
            border-width: 1px;
            border-color: root.viewport-color;
        }
    }
}

export component OpenFileToolButton inherits Rectangle {
    in property <string> tooltip-text: "";
    in property <bool> enabled: true;
    out property <bool> hovered: touch.has-hover;
    callback clicked();
    callback secondary-clicked(length, length);

    width: 34px;
    height: 28px;
    border-radius: 4px;
    background: touch.has-hover && enabled ? Theme.surface-hover : transparent;

    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }

        pointer-event(e) => {
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                root.secondary-clicked(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
            }
        }
    }

    Image {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 17px;
        height: 17px;
        source: @image-url("open-file.svg");
        image-fit: contain;
        opacity: root.enabled ? 1.0 : 0.45;
    }
}

