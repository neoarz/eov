// EOV WSI Viewer - Export Image Dialog

import { Theme } from "theme.slint";
import {
    CapStyle,
    ExportFilteringMode,
    ExportFormat,
    ExportPreviewInfo,
    ExportSettings,
    IsolatedChannel,
    StainNormalization,
    StrokeStyle,
} from "types.slint";

// ---------------------------------------------------------------------------
// Reusable sub-components
// ---------------------------------------------------------------------------

component ExportSlider inherits Rectangle {
    in property <string> label;
    in property <float> value: 0.0;
    in property <float> min-value: 0.0;
    in property <float> max-value: 1.0;
    in property <string> display-text;
    in property <string> value-suffix: "";
    in property <float> display-divisor: 1.0;
    in property <bool> enabled: true;
    callback changed(float);
    callback released();

    height: 32px;
    background: transparent;
    opacity: root.enabled ? 1.0 : 0.4;

    property <float> normalized: (value - min-value) / max(max-value - min-value, 0.001);
    property <length> track-left: 0px;
    property <length> track-right: 68px;
    property <length> track-width: self.width - track-left - track-right;
    property <bool> editing: false;

    Rectangle {
        x: root.track-left;
        y: (parent.height - 3px) / 2;
        width: root.track-width;
        height: 3px;
        border-radius: 1.5px;
        background: #ffffff20;

        Rectangle {
            x: 0px;
            width: root.normalized * parent.width;
            height: parent.height;
            border-radius: parent.border-radius;
            background: #4da3d9;
        }
    }

    Rectangle {
        x: root.track-left + root.normalized * root.track-width - 6px;
        y: (parent.height - 12px) / 2;
        width: 12px;
        height: 12px;
        border-radius: 6px;
        background: white;
        border-width: 1px;
        border-color: #4da3d9;
    }

    slider-touch := TouchArea {
        enabled: root.enabled;
        x: root.track-left - 6px;
        y: 0px;
        width: root.track-width + 12px;
        height: root.height;

        pointer-event(e) => {
            if e.kind == PointerEventKind.down || (e.kind == PointerEventKind.move && self.pressed) {
                let norm = max(0.0, min(1.0, (self.mouse-x - 6px) / max(root.track-width, 1px)));
                root.changed(root.min-value + norm * (root.max-value - root.min-value));
            }
            if e.kind == PointerEventKind.up {
                root.released();
            }
        }
    }

    // Editable value field (click to edit, like zoom input)
    Rectangle {
        x: parent.width - root.track-right + 4px;
        y: (parent.height - self.height) / 2;
        width: root.track-right - 6px;
        height: 22px;
        border-radius: 3px;
        background: root.editing ? #1a1f28 : (val-touch.has-hover ? #ffffff15 : #ffffff0a);
        border-width: root.editing ? 1px : 0px;
        border-color: #4da3d9;

        Text {
            visible: !root.editing;
            text: root.display-text;
            color: #e0e0e0;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }

        val-input := TextInput {
            visible: root.editing;
            x: 4px;
            width: parent.width - 8px;
            color: white;
            font-size: 11px;
            horizontal-alignment: center;
            vertical-alignment: center;
            input-type: InputType.decimal;

            accepted => {
                root.editing = false;
                let raw = self.text.to-float() * root.display-divisor;
                root.changed(max(root.min-value, min(root.max-value, raw)));
                root.released();
            }
        }

        val-touch := TouchArea {
            enabled: root.enabled && !root.editing;
            clicked => {
                root.editing = true;
                val-input.text = root.display-text;
                val-input.focus();
                val-input.select-all();
            }
        }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> text;
    in property <image> icon-source;

    height: 34px;

    HorizontalLayout {
        padding-left: 4px;
        spacing: 8px;
        alignment: start;

        Image {
            y: (parent.height - self.height) / 2;
            width: 16px;
            height: 16px;
            source: root.icon-source;
            image-fit: contain;
            colorize: #4da3d9;
        }

        Text {
            text: root.text;
            color: white;
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
}

component SectionDivider inherits Rectangle {
    height: 1px;
    background: #ffffff12;
}

component SegmentButton inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    out property <bool> hovered: seg-touch.has-hover;
    callback clicked();

    height: 26px;
    border-radius: 3px;
    background: root.active ? #4da3d940 : seg-touch.has-hover ? #ffffff15 : transparent;
    border-width: root.active ? 1px : 0px;
    border-color: #4da3d9;

    seg-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.text;
        color: root.active ? white : #cccccc;
        font-size: 10px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component DpiChip inherits Rectangle {
    in property <int> chip-value;
    in property <bool> active: false;
    out property <bool> hovered: chip-touch.has-hover;
    callback clicked();

    width: 42px;
    height: 22px;
    border-radius: 11px;
    background: root.active ? #4da3d940 : chip-touch.has-hover ? #ffffff15 : #ffffff0a;
    border-width: root.active ? 1px : 0px;
    border-color: #4da3d9;

    chip-touch := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    Text {
        text: root.chip-value;
        color: root.active ? white : #aaaaaa;
        font-size: 10px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component LabelRow inherits Rectangle {
    in property <string> label;
    height: 28px;

    Text {
        x: 4px;
        text: root.label;
        color: #8ea0b2;
        font-size: 11px;
        vertical-alignment: center;
    }
}

component ToggleSwitch inherits Rectangle {
    in property <string> label;
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled(bool);

    height: 28px;
    opacity: root.enabled ? 1.0 : 0.4;

    HorizontalLayout {
        padding-left: 4px;
        spacing: 8px;
        alignment: start;

        Rectangle {
            y: (parent.height - self.height) / 2;
            width: 32px;
            height: 16px;
            border-radius: 8px;
            background: root.checked ? #4da3d9 : #ffffff30;
            animate background { duration: 150ms; }

            Rectangle {
                x: root.checked ? parent.width - self.width - 2px : 2px;
                y: 2px;
                width: 12px;
                height: 12px;
                border-radius: 6px;
                background: white;
                animate x { duration: 150ms; }
            }

            toggle-touch := TouchArea {
                enabled: root.enabled;
                clicked => {
                    root.checked = !root.checked;
                    root.toggled(root.checked);
                }
            }
        }

        Text {
            text: root.label;
            color: root.enabled ? Theme.text-primary : Theme.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

component PickerSwatch inherits Rectangle {
    in property <color> swatch-color;
    in property <bool> selected: false;
    callback picked(color);

    width: 24px;
    height: 24px;
    border-radius: 4px;
    background: root.swatch-color;
    border-width: root.selected ? 2px : (swatch-ta.has-hover ? 1.5px : 1px);
    border-color: root.selected ? white : (swatch-ta.has-hover ? #ffffffa0 : #ffffff30);

    swatch-ta := TouchArea {
        clicked => {
            root.picked(root.swatch-color);
        }
    }
}

component ColorField inherits Rectangle {
    in-out property <color> current-color: #2ECC71;
    in-out property <float> opacity-pct: 100;
    callback opacity-changed(float);
    callback color-changed(color);
    callback request-preview();

    height: 28px;

    HorizontalLayout {
        padding-left: 4px;
        spacing: 8px;
        alignment: start;

        // Clickable color swatch
        Rectangle {
            y: (parent.height - self.height) / 2;
            width: 22px;
            height: 22px;
            border-radius: 4px;
            background: root.current-color;
            border-width: 1px;
            border-color: swatch-touch.has-hover ? #ffffff80 : #ffffff30;

            swatch-touch := TouchArea {
                clicked => {
                    color-popup.show();
                }
            }
        }

        Text {
            text: "Opacity";
            color: #8ea0b2;
            font-size: 11px;
            vertical-alignment: center;
        }

        Rectangle {
            y: (parent.height - self.height) / 2;
            width: 48px;
            height: 22px;
            border-radius: 3px;
            background: #ffffff10;
            border-width: 1px;
            border-color: #ffffff1a;

            opacity-input := TextInput {
                x: 4px;
                width: parent.width - 20px;
                text: Math.round(root.opacity-pct);
                color: #e0e0e0;
                font-size: 10px;
                horizontal-alignment: right;
                vertical-alignment: center;

                accepted => {
                    root.opacity-changed(max(0, min(100, self.text.to-float())));
                    root.request-preview();
                }
                edited => {
                    // live feedback on typing handled via accepted
                }
            }

            Text {
                x: parent.width - 14px;
                text: "%";
                color: #8ea0b2;
                font-size: 10px;
                vertical-alignment: center;
            }
        }
    }

    color-popup := PopupWindow {
        x: 0px;
        y: root.height + 4px;

        Rectangle {
            width: 192px;
            height: 164px;
            background: #2a2a2a;
            border-radius: 8px;
            border-width: 1px;
            border-color: #ffffff20;
            drop-shadow-blur: 16px;
            drop-shadow-color: #00000080;

            VerticalLayout {
                padding: 10px;
                spacing: 6px;

                Text {
                    text: "Pick a Color";
                    color: #c0c0c0;
                    font-size: 10px;
                    font-weight: 500;
                }

                // Row 1: warm / primary
                HorizontalLayout {
                    spacing: 4px;
                    PickerSwatch {
                        swatch-color: #E74C3C;
                        selected: root.current-color == #E74C3C;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #E67E22;
                        selected: root.current-color == #E67E22;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #F1C40F;
                        selected: root.current-color == #F1C40F;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #2ECC71;
                        selected: root.current-color == #2ECC71;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #1ABC9C;
                        selected: root.current-color == #1ABC9C;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #3498DB;
                        selected: root.current-color == #3498DB;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }
                }

                // Row 2: deep / accent
                HorizontalLayout {
                    spacing: 4px;
                    PickerSwatch {
                        swatch-color: #9B59B6;
                        selected: root.current-color == #9B59B6;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #E91E8A;
                        selected: root.current-color == #E91E8A;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #C0392B;
                        selected: root.current-color == #C0392B;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #27AE60;
                        selected: root.current-color == #27AE60;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #2980B9;
                        selected: root.current-color == #2980B9;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #8E44AD;
                        selected: root.current-color == #8E44AD;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }
                }

                // Row 3: neutrals
                HorizontalLayout {
                    spacing: 4px;
                    PickerSwatch {
                        swatch-color: #FFFFFF;
                        selected: root.current-color == #FFFFFF;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #ECF0F1;
                        selected: root.current-color == #ECF0F1;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #95A5A6;
                        selected: root.current-color == #95A5A6;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #7F8C8D;
                        selected: root.current-color == #7F8C8D;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #2C3E50;
                        selected: root.current-color == #2C3E50;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }

                    PickerSwatch {
                        swatch-color: #000000;
                        selected: root.current-color == #000000;
                        picked(c) => {
                            root.current-color = c;
                            root.color-changed(c);
                            root.request-preview();
                        }
                    }
                }

                // RGB manual input row
                HorizontalLayout {
                    spacing: 4px;
                    alignment: center;

                    Text {
                        text: "R";
                        color: #8ea0b2;
                        font-size: 9px;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        width: 38px;
                        height: 20px;
                        border-radius: 3px;
                        background: #ffffff10;
                        border-width: 1px;
                        border-color: #ffffff1a;

                        rgb-r-input := TextInput {
                            x: 2px;
                            width: parent.width - 4px;
                            text: Math.round(root.current-color.red * 255);
                            color: #e0e0e0;
                            font-size: 9px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            input-type: number;

                            accepted => {
                                root.current-color = Colors.rgb(max(0, min(255, Math.round(self.text.to-float()))), root.current-color.green * 255, root.current-color.blue * 255);
                                root.color-changed(root.current-color);
                                root.request-preview();
                            }
                        }
                    }

                    Text {
                        text: "G";
                        color: #8ea0b2;
                        font-size: 9px;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        width: 38px;
                        height: 20px;
                        border-radius: 3px;
                        background: #ffffff10;
                        border-width: 1px;
                        border-color: #ffffff1a;

                        rgb-g-input := TextInput {
                            x: 2px;
                            width: parent.width - 4px;
                            text: Math.round(root.current-color.green * 255);
                            color: #e0e0e0;
                            font-size: 9px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            input-type: number;

                            accepted => {
                                root.current-color = Colors.rgb(root.current-color.red * 255, max(0, min(255, Math.round(self.text.to-float()))), root.current-color.blue * 255);
                                root.color-changed(root.current-color);
                                root.request-preview();
                            }
                        }
                    }

                    Text {
                        text: "B";
                        color: #8ea0b2;
                        font-size: 9px;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        width: 38px;
                        height: 20px;
                        border-radius: 3px;
                        background: #ffffff10;
                        border-width: 1px;
                        border-color: #ffffff1a;

                        rgb-b-input := TextInput {
                            x: 2px;
                            width: parent.width - 4px;
                            text: Math.round(root.current-color.blue * 255);
                            color: #e0e0e0;
                            font-size: 9px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            input-type: number;

                            accepted => {
                                root.current-color = Colors.rgb(root.current-color.red * 255, root.current-color.green * 255, max(0, min(255, Math.round(self.text.to-float()))));
                                root.color-changed(root.current-color);
                                root.request-preview();
                            }
                        }
                    }
                }
            }
        }
    }
}

component SmallTextInput inherits Rectangle {
    in property <string> label: "";
    in-out property <float> value: 0;
    callback value-changed(float);
    callback request-preview();

    width: 48px;
    height: 22px;
    border-radius: 3px;
    background: #ffffff10;
    border-width: 1px;
    border-color: #ffffff1a;

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;

        if root.label != "": Text {
            text: root.label;
            color: #8ea0b2;
            font-size: 9px;
            vertical-alignment: center;
        }

        small-input := TextInput {
            text: Math.round(root.value * 10) / 10;
            color: #e0e0e0;
            font-size: 10px;
            horizontal-alignment: right;
            vertical-alignment: center;

            accepted => {
                root.value-changed(self.text.to-float());
                root.request-preview();
            }
        }
    }
}

component StrokeStyleSelector inherits Rectangle {
    in-out property <StrokeStyle> stroke-style: StrokeStyle.solid;
    in-out property <float> dash-length: 8;
    in-out property <float> dash-gap: 4;
    in-out property <float> dot-spacing: 4;
    callback style-changed(StrokeStyle);
    callback dash-length-changed(float);
    callback dash-gap-changed(float);
    callback dot-spacing-changed(float);
    callback request-preview();

    height: 28px;

    HorizontalLayout {
        padding-left: 4px;
        spacing: 4px;
        alignment: start;

        Text {
            text: "Stroke";
            color: #8ea0b2;
            font-size: 11px;
            vertical-alignment: center;
            width: 46px;
        }

        SegmentButton {
            width: 52px;
            text: "Solid";
            active: root.stroke-style == StrokeStyle.solid;
            clicked => {
                root.style-changed(StrokeStyle.solid);
                root.request-preview();
            }
        }

        SegmentButton {
            width: 52px;
            text: "Dashed";
            active: root.stroke-style == StrokeStyle.dashed;
            clicked => {
                root.style-changed(StrokeStyle.dashed);
                root.request-preview();
            }
        }

        SegmentButton {
            width: 52px;
            text: "Dotted";
            active: root.stroke-style == StrokeStyle.dotted;
            clicked => {
                root.style-changed(StrokeStyle.dotted);
                root.request-preview();
            }
        }

        if root.stroke-style == StrokeStyle.dashed: SmallTextInput {
            label: "L";
            value: root.dash-length;
            value-changed(v) => {
                root.dash-length-changed(v);
            }
            request-preview => {
                root.request-preview();
            }
        }

        if root.stroke-style == StrokeStyle.dashed: SmallTextInput {
            label: "G";
            value: root.dash-gap;
            value-changed(v) => {
                root.dash-gap-changed(v);
            }
            request-preview => {
                root.request-preview();
            }
        }

        if root.stroke-style == StrokeStyle.dotted: SmallTextInput {
            label: "S";
            value: root.dot-spacing;
            value-changed(v) => {
                root.dot-spacing-changed(v);
            }
            request-preview => {
                root.request-preview();
            }
        }
    }
}

component CapStyleSelector inherits Rectangle {
    in-out property <CapStyle> cap-style: CapStyle.round;
    callback cap-changed(CapStyle);
    callback request-preview();

    height: 28px;

    HorizontalLayout {
        padding-left: 4px;
        spacing: 4px;
        alignment: start;

        Text {
            text: "Caps";
            color: #8ea0b2;
            font-size: 11px;
            vertical-alignment: center;
            width: 46px;
        }

        SegmentButton {
            width: 52px;
            text: "Round";
            active: root.cap-style == CapStyle.round;
            clicked => {
                root.cap-changed(CapStyle.round);
                root.request-preview();
            }
        }

        SegmentButton {
            width: 52px;
            text: "Square";
            active: root.cap-style == CapStyle.square;
            clicked => {
                root.cap-changed(CapStyle.square);
                root.request-preview();
            }
        }

        SegmentButton {
            width: 52px;
            text: "Flat";
            active: root.cap-style == CapStyle.flat;
            clicked => {
                root.cap-changed(CapStyle.flat);
                root.request-preview();
            }
        }
    }
}


// ---------------------------------------------------------------------------
// Main export dialog
// ---------------------------------------------------------------------------

export component ExportDialog inherits Rectangle {
    in-out property <bool> visible-state: false;
    in-out property <ExportSettings> settings;
    in-out property <ExportPreviewInfo> preview-info;
    in property <length> toolbar-height: 40px;

    callback request-preview();
    callback export-requested();
    callback cancel-requested();
    callback reset-requested();
    callback settings-changed(ExportSettings);

    // Scroll offset for the settings area (manual wheel-scroll).
    property <length> scroll-y: 0px;

    // Reactive export dimensions (update instantly when DPI changes).
    property <int> export-width: Math.max(1, Math.round(root.preview-info.viewport-width * root.settings.dpi / 96));
    property <int> export-height: Math.max(1, Math.round(root.preview-info.viewport-height * root.settings.dpi / 96));
    property <float> bytes-per-pixel: root.settings.format == ExportFormat.png ? 4.0 : (0.3 + root.settings.jpeg-quality / 100.0 * 2.5);
    property <float> estimated-mb: root.export-width * root.export-height * root.bytes-per-pixel / 1048576.0;

    // Emit settings-changed after any modification
    function notify-settings() {
        root.settings-changed(root.settings);
        root.request-preview();
    }

    // Full-window overlay, but with toolbar area unblurred
    x: 0px;
    y: 0px;
    width: 100%;
    height: 100%;
    visible: root.visible-state;

    // Dimming layer beneath the dialog (from toolbar bottom downward)
    Rectangle {
        x: 0px;
        y: root.toolbar-height;
        width: parent.width;
        height: parent.height - root.toolbar-height;
        background: #000000aa;

        // Dismiss on outside click
        TouchArea {
            clicked => {
                root.cancel-requested();
            }
        }
    }

    // Dialog card – centered, anchored below toolbar
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: root.toolbar-height + 24px;
        width: min(560px, parent.width - 48px);
        height: min(parent.height - root.toolbar-height - 48px, dialog-layout.preferred-height);
        background: #1e1e1e;
        border-radius: 10px;
        border-width: 1px;
        border-color: #ffffff1a;
        drop-shadow-blur: 32px;
        drop-shadow-color: #000000aa;

        // Block clicks from dismissing through the card
        TouchArea { }

        dialog-layout := VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // ---------------------------------------------------------------
            // Preview section (fixed, non-scrollable)
            // ---------------------------------------------------------------
            Rectangle {
                height: 240px;
                background: #141414;
                border-top-left-radius: 10px;
                border-top-right-radius: 10px;

                VerticalLayout {
                    padding: 16px;
                    spacing: 8px;
                    alignment: center;

                    Text {
                        text: "Export Preview";
                        color: white;
                        font-size: 13px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }

                    Rectangle {
                        height: 140px;
                        background: #0a0a0a;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #ffffff10;
                        clip: true;

                        Image {
                            width: parent.width;
                            height: parent.height;
                            source: @image-url("icons/crosshatch.svg");
                            horizontal-tiling: repeat;
                            vertical-tiling: repeat;
                            image-rendering: pixelated;
                        }

                        Image {
                            width: parent.width - 8px;
                            height: parent.height - 16px;
                            x: 4px;
                            y: 8px;
                            source: root.preview-info.preview-image;
                            image-fit: contain;
                        }
                    }

                    HorizontalLayout {
                        spacing: 16px;
                        alignment: center;

                        Text {
                            text: "Estimated Size: " + (Math.round(root.estimated-mb * 100) / 100) + " MB";
                            color: #8ea0b2;
                            font-size: 10px;
                        }

                        Text {
                            text: root.export-width + " × " + root.export-height + " px";
                            color: #8ea0b2;
                            font-size: 10px;
                        }
                    }
                }
            }

            SectionDivider { }

            // ---------------------------------------------------------------
            // Scrollable settings area — no Flickable (its gesture
            // recognition conflicts with slider drags). Instead, a
            // clipped Rectangle with a parent TouchArea that handles
            // only scroll-wheel events. Inner slider TouchAreas take
            // event priority over the parent TouchArea.
            // ---------------------------------------------------------------
            scroll-clip := Rectangle {
                vertical-stretch: 1;
                clip: true;
                // Report content height as preferred so the dialog card
                // allocates full available space for this area.
                preferred-height: settings-content.preferred-height;

                TouchArea {
                    scroll-event(e) => {
                        root.scroll-y = clamp(
                            root.scroll-y + e.delta-y,
                            min(0px, scroll-clip.height - settings-content.preferred-height),
                            0px);
                        accept
                    }

                    settings-content := VerticalLayout {
                        y: root.scroll-y;
                        width: parent.width;
                        padding: 16px;
                        spacing: 4px;

                        // ------- Resolution (DPI) -------
                    SectionHeader {
                            text: "Resolution (DPI)";
                            icon-source: @image-url("icons/resolution.svg");
                        }

                        HorizontalLayout {
                            spacing: 8px;

                            ExportSlider {
                                horizontal-stretch: 1;
                                value: root.settings.dpi;
                                min-value: 72;
                                max-value: 600;
                                display-text: Math.round(root.settings.dpi) + "";
                                changed(v) => {
                                    root.settings.dpi = Math.round(v);
                                    root.settings-changed(root.settings);
                                }
                                released => {
                                    root.notify-settings();
                                }
                            }
                        }

                        // Quick-select chips
                    HorizontalLayout {
                            spacing: 6px;
                            alignment: start;
                            padding-top: 2px;
                            padding-bottom: 4px;

                            DpiChip {
                                chip-value: 72;
                                active: root.settings.dpi == 72;
                                clicked => {
                                    root.settings.dpi = 72;
                                    root.notify-settings();
                                }
                            }

                            DpiChip {
                                chip-value: 96;
                                active: root.settings.dpi == 96;
                                clicked => {
                                    root.settings.dpi = 96;
                                    root.notify-settings();
                                }
                            }

                            DpiChip {
                                chip-value: 150;
                                active: root.settings.dpi == 150;
                                clicked => {
                                    root.settings.dpi = 150;
                                    root.notify-settings();
                                }
                            }

                            DpiChip {
                                chip-value: 300;
                                active: root.settings.dpi == 300;
                                clicked => {
                                    root.settings.dpi = 300;
                                    root.notify-settings();
                                }
                            }
                        }

                        SectionDivider { }

                        // ------- Filtering Mode -------
                    SectionHeader {
                            text: "Filtering Mode";
                            icon-source: @image-url("icons/sample-mode.svg");
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            padding-bottom: 4px;

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "Bilinear";
                                active: root.settings.filtering-mode == ExportFilteringMode.bilinear;
                                clicked => {
                                    root.settings.filtering-mode = ExportFilteringMode.bilinear;
                                    root.notify-settings();
                                }
                            }

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "Trilinear";
                                active: root.settings.filtering-mode == ExportFilteringMode.trilinear;
                                clicked => {
                                    root.settings.filtering-mode = ExportFilteringMode.trilinear;
                                    root.notify-settings();
                                }
                            }

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "Lanczos";
                                active: root.settings.filtering-mode == ExportFilteringMode.lanczos;
                                clicked => {
                                    root.settings.filtering-mode = ExportFilteringMode.lanczos;
                                    root.notify-settings();
                                }
                            }
                        }

                        SectionDivider { }

                        // ------- Image Adjustment -------
                    SectionHeader {
                            text: "Image Adjustment";
                            icon-source: @image-url("icons/settings.svg");
                        }

                        LabelRow {
                            label: "Sharpness";
                        }

                        ExportSlider {
                            value: root.settings.sharpness;
                            min-value: 0.0;
                            max-value: 1.0;
                            display-text: Math.round(root.settings.sharpness * 100) + "%";
                            changed(v) => {
                                root.settings.sharpness = v;
                                root.settings-changed(root.settings);
                            }
                            released => {
                                root.notify-settings();
                            }
                        }

                        LabelRow {
                            label: "Gamma";
                        }

                        ExportSlider {
                            value: root.settings.gamma;
                            min-value: 0.2;
                            max-value: 3.0;
                            display-text: Math.round(root.settings.gamma * 100) / 100 + "";
                            changed(v) => {
                                root.settings.gamma = v;
                                root.settings-changed(root.settings);
                            }
                            released => {
                                root.notify-settings();
                            }
                        }

                        LabelRow {
                            label: "Brightness";
                        }

                        ExportSlider {
                            value: root.settings.brightness;
                            min-value: -1.0;
                            max-value: 1.0;
                            display-text: (root.settings.brightness >= 0 ? "+" : "") + Math.round(root.settings.brightness * 100) + "%";
                            changed(v) => {
                                root.settings.brightness = v;
                                root.settings-changed(root.settings);
                            }
                            released => {
                                root.notify-settings();
                            }
                        }

                        LabelRow {
                            label: "Contrast";
                        }

                        ExportSlider {
                            value: root.settings.contrast;
                            min-value: 0.2;
                            max-value: 3.0;
                            display-text: Math.round(root.settings.contrast * 100) / 100 + "x";
                            changed(v) => {
                                root.settings.contrast = v;
                                root.settings-changed(root.settings);
                            }
                            released => {
                                root.notify-settings();
                            }
                        }

                        SectionDivider { }

                        // ------- Stain Normalization -------
                    SectionHeader {
                            text: "Stain Normalization";
                            icon-source: @image-url("icons/settings.svg");
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            padding-bottom: 4px;

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "None";
                                active: root.settings.stain-normalization == StainNormalization.none;
                                clicked => {
                                    root.settings.stain-normalization = StainNormalization.none;
                                    root.notify-settings();
                                }
                            }

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "Macenko";
                                active: root.settings.stain-normalization == StainNormalization.macenko;
                                clicked => {
                                    root.settings.stain-normalization = StainNormalization.macenko;
                                    root.notify-settings();
                                }
                            }

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "Vahadane";
                                active: root.settings.stain-normalization == StainNormalization.vahadane;
                                clicked => {
                                    root.settings.stain-normalization = StainNormalization.vahadane;
                                    root.notify-settings();
                                }
                            }
                        }

                        SectionDivider { }

                        // ------- Color Deconvolution -------
                    SectionHeader {
                            text: "Color Deconvolution";
                            icon-source: @image-url("icons/settings.svg");
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            padding-left: 4px;
                            height: 28px;

                            ToggleSwitch {
                                label: "Hematoxylin";
                                checked: root.settings.deconv-hematoxylin-visible;
                                toggled(v) => {
                                    root.settings.deconv-hematoxylin-visible = v;
                                    root.notify-settings();
                                }
                            }
                        }

                        LabelRow {
                            label: "H Intensity";
                        }

                        ExportSlider {
                            value: root.settings.deconv-hematoxylin-intensity;
                            min-value: 0.0;
                            max-value: 3.0;
                            display-text: Math.round(root.settings.deconv-hematoxylin-intensity * 100) / 100 + "x";
                            changed(v) => {
                                root.settings.deconv-hematoxylin-intensity = v;
                                root.settings-changed(root.settings);
                            }
                            released => {
                                root.notify-settings();
                            }
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            padding-left: 4px;
                            height: 28px;

                            ToggleSwitch {
                                label: "Eosin";
                                checked: root.settings.deconv-eosin-visible;
                                toggled(v) => {
                                    root.settings.deconv-eosin-visible = v;
                                    root.notify-settings();
                                }
                            }
                        }

                        LabelRow {
                            label: "E Intensity";
                        }

                        ExportSlider {
                            value: root.settings.deconv-eosin-intensity;
                            min-value: 0.0;
                            max-value: 3.0;
                            display-text: Math.round(root.settings.deconv-eosin-intensity * 100) / 100 + "x";
                            changed(v) => {
                                root.settings.deconv-eosin-intensity = v;
                                root.settings-changed(root.settings);
                            }
                            released => {
                                root.notify-settings();
                            }
                        }

                        LabelRow {
                            label: "Isolated Channel";
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            padding-bottom: 4px;

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "None";
                                active: root.settings.deconv-isolated-channel == IsolatedChannel.none;
                                clicked => {
                                    root.settings.deconv-isolated-channel = IsolatedChannel.none;
                                    root.notify-settings();
                                }
                            }

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "Hematoxylin";
                                active: root.settings.deconv-isolated-channel == IsolatedChannel.hematoxylin;
                                clicked => {
                                    root.settings.deconv-isolated-channel = IsolatedChannel.hematoxylin;
                                    root.notify-settings();
                                }
                            }

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "Eosin";
                                active: root.settings.deconv-isolated-channel == IsolatedChannel.eosin;
                                clicked => {
                                    root.settings.deconv-isolated-channel = IsolatedChannel.eosin;
                                    root.notify-settings();
                                }
                            }
                        }

                        SectionDivider { }

                        // ------- Measurement -------
                    SectionHeader {
                            text: "Measurement";
                            icon-source: @image-url("icons/measure.svg");
                        }

                        if !root.settings.has-measurement: Rectangle {
                            height: 32px;
                            Text {
                                x: 8px;
                                text: "Measure a distance in the viewport to enable these settings.";
                                color: #8ea0b260;
                                font-size: 10px;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }
                        }

                        if root.settings.has-measurement: ToggleSwitch {
                            label: "Show Measurement";
                            checked: root.settings.show-measurement;
                            enabled: root.settings.has-measurement;
                            toggled(v) => {
                                root.settings.show-measurement = v;
                                root.notify-settings();
                            }
                        }

                        if root.settings.show-measurement && root.settings.has-measurement: VerticalLayout {
                            spacing: 4px;

                            LabelRow {
                                label: "Color";
                            }

                            ColorField {
                                current-color: root.settings.measurement-color;
                                opacity-pct: root.settings.measurement-opacity;
                                color-changed(c) => {
                                    root.settings.measurement-color = c;
                                    root.notify-settings();
                                }
                                opacity-changed(v) => {
                                    root.settings.measurement-opacity = v;
                                }
                                request-preview => {
                                    root.notify-settings();
                                }
                            }

                            LabelRow {
                                label: "Thickness";
                            }

                            ExportSlider {
                                value: root.settings.measurement-thickness;
                                min-value: 0.5;
                                max-value: 10.0;
                                display-text: Math.round(root.settings.measurement-thickness * 10) / 10 + "px";
                                changed(v) => {
                                    root.settings.measurement-thickness = v;
                                    root.settings-changed(root.settings);
                                }
                                released => {
                                    root.notify-settings();
                                }
                            }

                            StrokeStyleSelector {
                                stroke-style: root.settings.measurement-stroke-style;
                                dash-length: root.settings.measurement-dash-length;
                                dash-gap: root.settings.measurement-dash-gap;
                                dot-spacing: root.settings.measurement-dot-spacing;
                                style-changed(s) => {
                                    root.settings.measurement-stroke-style = s;
                                }
                                dash-length-changed(v) => {
                                    root.settings.measurement-dash-length = v;
                                }
                                dash-gap-changed(v) => {
                                    root.settings.measurement-dash-gap = v;
                                }
                                dot-spacing-changed(v) => {
                                    root.settings.measurement-dot-spacing = v;
                                }
                                request-preview => {
                                    root.notify-settings();
                                }
                            }

                            CapStyleSelector {
                                cap-style: root.settings.measurement-cap-style;
                                cap-changed(c) => {
                                    root.settings.measurement-cap-style = c;
                                }
                                request-preview => {
                                    root.notify-settings();
                                }
                            }

                            LabelRow {
                                label: "Font Size";
                            }

                            ExportSlider {
                                value: root.settings.measurement-font-size;
                                min-value: 6;
                                max-value: 32;
                                display-text: Math.round(root.settings.measurement-font-size) + "pt";
                                changed(v) => {
                                    root.settings.measurement-font-size = v;
                                    root.settings-changed(root.settings);
                                }
                                released => {
                                    root.notify-settings();
                                }
                            }
                        }

                        SectionDivider { }

                        // ------- Region of Interest -------
                    SectionHeader {
                            text: "Region of Interest";
                        // ROI icon drawn inline (matches toolbar icon)
                        icon-source: @image-url("icons/navigate.svg");
                        }

                        if !root.settings.has-roi: Rectangle {
                            height: 32px;
                            Text {
                                x: 8px;
                                text: "Select a region of interest in the viewport to enable these settings.";
                                color: #8ea0b260;
                                font-size: 10px;
                                vertical-alignment: center;
                                wrap: word-wrap;
                            }
                        }

                        if root.settings.has-roi: ToggleSwitch {
                            label: "Show Outline";
                            checked: root.settings.show-roi-outline;
                            enabled: root.settings.has-roi;
                            toggled(v) => {
                                root.settings.show-roi-outline = v;
                                root.notify-settings();
                            }
                        }

                        if root.settings.show-roi-outline && root.settings.has-roi: VerticalLayout {
                            spacing: 4px;

                            LabelRow {
                                label: "Color";
                            }

                            ColorField {
                                current-color: root.settings.roi-color;
                                opacity-pct: root.settings.roi-opacity;
                                color-changed(c) => {
                                    root.settings.roi-color = c;
                                    root.notify-settings();
                                }
                                opacity-changed(v) => {
                                    root.settings.roi-opacity = v;
                                }
                                request-preview => {
                                    root.notify-settings();
                                }
                            }

                            LabelRow {
                                label: "Thickness";
                            }

                            ExportSlider {
                                value: root.settings.roi-thickness;
                                min-value: 0.5;
                                max-value: 10.0;
                                display-text: Math.round(root.settings.roi-thickness * 10) / 10 + "px";
                                changed(v) => {
                                    root.settings.roi-thickness = v;
                                    root.settings-changed(root.settings);
                                }
                                released => {
                                    root.notify-settings();
                                }
                            }

                            StrokeStyleSelector {
                                stroke-style: root.settings.roi-stroke-style;
                                dash-length: root.settings.roi-dash-length;
                                dash-gap: root.settings.roi-dash-gap;
                                dot-spacing: root.settings.roi-dot-spacing;
                                style-changed(s) => {
                                    root.settings.roi-stroke-style = s;
                                }
                                dash-length-changed(v) => {
                                    root.settings.roi-dash-length = v;
                                }
                                dash-gap-changed(v) => {
                                    root.settings.roi-dash-gap = v;
                                }
                                dot-spacing-changed(v) => {
                                    root.settings.roi-dot-spacing = v;
                                }
                                request-preview => {
                                    root.notify-settings();
                                }
                            }

                            CapStyleSelector {
                                cap-style: root.settings.roi-cap-style;
                                cap-changed(c) => {
                                    root.settings.roi-cap-style = c;
                                }
                                request-preview => {
                                    root.notify-settings();
                                }
                            }
                        }

                        // Outside Overlay subsection
                    if root.settings.has-roi: VerticalLayout {
                            spacing: 4px;
                            padding-top: 4px;

                            SectionDivider { }

                            LabelRow {
                                label: "Outside Overlay";
                            }

                            ToggleSwitch {
                                label: "Enable Overlay";
                                checked: root.settings.roi-outside-overlay;
                                toggled(v) => {
                                    root.settings.roi-outside-overlay = v;
                                    root.notify-settings();
                                }
                            }

                            if root.settings.roi-outside-overlay: ColorField {
                                current-color: root.settings.roi-outside-color;
                                opacity-pct: root.settings.roi-outside-opacity;
                                color-changed(c) => {
                                    root.settings.roi-outside-color = c;
                                    root.notify-settings();
                                }
                                opacity-changed(v) => {
                                    root.settings.roi-outside-opacity = v;
                                }
                                request-preview => {
                                    root.notify-settings();
                                }
                            }
                        }

                        SectionDivider { }

                        // ------- Format -------
                    SectionHeader {
                            text: "Format";
                            icon-source: @image-url("icons/export.svg");
                        }

                        HorizontalLayout {
                            spacing: 4px;
                            padding-bottom: 4px;

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "JPEG (Smaller)";
                                active: root.settings.format == ExportFormat.jpeg;
                                clicked => {
                                    root.settings.format = ExportFormat.jpeg;
                                    root.notify-settings();
                                }
                            }

                            SegmentButton {
                                horizontal-stretch: 1;
                                text: "PNG (Lossless)";
                                active: root.settings.format == ExportFormat.png;
                                clicked => {
                                    root.settings.format = ExportFormat.png;
                                    root.notify-settings();
                                }
                            }
                        }

                        VerticalLayout {
                            spacing: 4px;

                            LabelRow {
                                label: "Quality";
                            }

                            ExportSlider {
                                enabled: root.settings.format == ExportFormat.jpeg;
                                value: root.settings.jpeg-quality;
                                min-value: 1;
                                max-value: 100;
                                display-text: root.settings.jpeg-quality + "%";
                                changed(v) => {
                                    root.settings.jpeg-quality = Math.round(v);
                                    root.settings-changed(root.settings);
                                }
                                released => {
                                    root.notify-settings();
                                }
                            }
                        }

                        // Bottom padding for scroll area
                    Rectangle {
                            height: 8px;
                        }
                    }
                }
            }

            SectionDivider { }

            // ---------------------------------------------------------------
            // Bottom action bar (fixed, non-scrollable)
            // ---------------------------------------------------------------
            Rectangle {
                height: 56px;
                background: #141414;
                border-bottom-left-radius: 10px;
                border-bottom-right-radius: 10px;

                HorizontalLayout {
                    padding: 12px;
                    padding-left: 16px;
                    padding-right: 16px;
                    spacing: 8px;

                    // Reset (left-aligned)
                    Rectangle {
                        width: reset-text.preferred-width + 20px;
                        height: 32px;
                        border-radius: 4px;
                        background: reset-touch.has-hover ? #ffffff15 : transparent;
                        border-width: 1px;
                        border-color: #ffffff1a;

                        reset-touch := TouchArea {
                            clicked => {
                                root.reset-requested();
                            }
                        }

                        reset-text := Text {
                            text: "Reset";
                            color: Theme.error;
                            font-size: 12px;
                            font-weight: 500;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Spacer
                    Rectangle {
                        horizontal-stretch: 1;
                    }

                    // Cancel
                    Rectangle {
                        width: cancel-text.preferred-width + 20px;
                        height: 32px;
                        border-radius: 4px;
                        background: cancel-touch.has-hover ? Theme.surface-hover : transparent;
                        border-width: 1px;
                        border-color: Theme.border;

                        cancel-touch := TouchArea {
                            clicked => {
                                root.cancel-requested();
                            }
                        }

                        cancel-text := Text {
                            text: "Cancel";
                            color: Theme.text-primary;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // Export
                    Rectangle {
                        width: export-row.preferred-width + 20px;
                        height: 32px;
                        border-radius: 4px;
                        background: export-touch.has-hover ? #1177bb : Theme.accent;

                        export-touch := TouchArea {
                            clicked => {
                                root.export-requested();
                            }
                        }

                        export-row := HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            spacing: 6px;
                            alignment: center;

                            Image {
                                y: (parent.height - self.height) / 2;
                                width: 14px;
                                height: 14px;
                                source: @image-url("icons/export.svg");
                                image-fit: contain;
                                colorize: white;
                            }

                            Text {
                                text: "Export";
                                color: white;
                                font-size: 12px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
