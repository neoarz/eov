import { Theme } from "theme.slint";
import {
    MeasurementUnit,
    StainNormalization,
    IsolatedChannel,
} from "types.slint";

component HudSlider inherits Rectangle {
    in property <string> label;
    in property <float> value: 0.0;
    in property <float> min-value: 0.0;
    in property <float> max-value: 1.0;
    in property <string> display-text;
    callback changed(float);

    height: 28px;
    background: transparent;

    property <float> normalized: (value - min-value) / max(max-value - min-value, 0.001);
    property <length> track-left: 80px;
    property <length> track-right: 42px;
    property <length> track-width: self.width - track-left - track-right;

    Text {
        x: 8px;
        y: (parent.height - self.height) / 2;
        width: 68px;
        text: root.label;
        color: #8ea0b2;
        font-size: 11px;
        vertical-alignment: center;
    }

    Rectangle {
        x: root.track-left;
        y: (parent.height - 3px) / 2;
        width: root.track-width;
        height: 3px;
        border-radius: 1.5px;
        background: #ffffff20;

        Rectangle {
            x: 0px;
            width: root.normalized * parent.width;
            height: parent.height;
            border-radius: parent.border-radius;
            background: #4da3d9;
        }
    }

    // Handle
    Rectangle {
        x: root.track-left + root.normalized * root.track-width - 5px;
        y: (parent.height - 10px) / 2;
        width: 10px;
        height: 10px;
        border-radius: 5px;
        background: white;
        border-width: 1px;
        border-color: #4da3d9;
    }

    slider-touch := TouchArea {
        x: root.track-left - 5px;
        y: 0px;
        width: root.track-width + 10px;
        height: root.height;

        pointer-event(e) => {
            if e.kind == PointerEventKind.down || (e.kind == PointerEventKind.move && self.pressed) {
                let norm = max(0.0, min(1.0, (self.mouse-x - 5px) / max(root.track-width, 1px)));
                root.changed(root.min-value + norm * (root.max-value - root.min-value));
            }
        }
    }

    Text {
        x: parent.width - root.track-right + 4px;
        y: (parent.height - self.height) / 2;
        width: root.track-right - 8px;
        text: root.display-text;
        color: #e0e0e0;
        font-size: 10px;
        horizontal-alignment: right;
        vertical-alignment: center;
    }
}

export component HudSettingsPanel inherits Rectangle {
    in property <float> sharpness: 0.0;
    in property <float> gamma: 1.0;
    in property <float> brightness: 0.0;
    in property <float> contrast: 1.0;
    in property <MeasurementUnit> measurement-unit: MeasurementUnit.um;
    in property <StainNormalization> stain-normalization: StainNormalization.none;
    in property <bool> has-adjustments: false;
    in property <float> deconv-hematoxylin-intensity: 1.0;
    in property <bool> deconv-hematoxylin-visible: true;
    in property <float> deconv-eosin-intensity: 1.0;
    in property <bool> deconv-eosin-visible: true;
    in property <IsolatedChannel> deconv-isolated-channel: IsolatedChannel.none;

    callback sharpness-changed(float);
    callback gamma-changed(float);
    callback brightness-changed(float);
    callback contrast-changed(float);
    callback measurement-unit-changed(MeasurementUnit);
    callback stain-normalization-changed(StainNormalization);
    callback reset-adjustments();
    callback deconv-h-intensity-changed(float);
    callback deconv-e-intensity-changed(float);
    callback deconv-h-visibility-toggled();
    callback deconv-e-visibility-toggled();
    callback deconv-h-view-toggled();
    callback deconv-e-view-toggled();

    width: 260px;
    height: layout.preferred-height + 33px;
    background: #101419dd;
    border-radius: 8px;
    border-width: 1px;
    border-color: #ffffff1a;
    drop-shadow-blur: 16px;
    drop-shadow-color: #00000070;

    layout := VerticalLayout {
        padding: 4px;
        spacing: 2px;

        // Header
        Rectangle {
            height: 28px;

            Text {
                x: 8px;
                text: "Image Adjustments";
                color: white;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        Rectangle {
            height: 1px;
            background: #ffffff12;
        }

        HudSlider {
            label: "Sharpness";
            value: root.sharpness;
            min-value: 0.0;
            max-value: 1.0;
            display-text: Math.round(root.sharpness * 100) + "%";
            changed(v) => {
                root.sharpness-changed(v);
            }
        }

        Rectangle {
            height: 1px;
            background: #ffffff12;
        }

        HudSlider {
            label: "Gamma";
            value: root.gamma;
            min-value: 0.2;
            max-value: 3.0;
            display-text: Math.round(root.gamma * 100) / 100 + "";
            changed(v) => {
                root.gamma-changed(v);
            }
        }

        HudSlider {
            label: "Brightness";
            value: root.brightness;
            min-value: -1.0;
            max-value: 1.0;
            display-text: (root.brightness >= 0 ? "+" : "") + Math.round(root.brightness * 100) + "%";
            changed(v) => {
                root.brightness-changed(v);
            }
        }

        HudSlider {
            label: "Contrast";
            value: root.contrast;
            min-value: 0.2;
            max-value: 3.0;
            display-text: Math.round(root.contrast * 100) / 100 + "x";
            changed(v) => {
                root.contrast-changed(v);
            }
        }

        Rectangle {
            height: 1px;
            background: #ffffff12;
        }

        // Measurement unit row
        Rectangle {
            height: 28px;

            Text {
                x: 8px;
                text: "Units";
                color: #8ea0b2;
                font-size: 11px;
                vertical-alignment: center;
            }

            HorizontalLayout {
                x: 80px;
                y: (parent.height - self.height) / 2;
                width: parent.width - 88px;
                height: 22px;
                spacing: 2px;

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.measurement-unit == MeasurementUnit.um ? #4da3d940 : um-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.measurement-unit == MeasurementUnit.um ? 1px : 0px;
                    border-color: #4da3d9;

                    um-touch := TouchArea {
                        clicked => {
                            root.measurement-unit-changed(MeasurementUnit.um);
                        }
                    }

                    Text {
                        text: "µm";
                        color: root.measurement-unit == MeasurementUnit.um ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.measurement-unit == MeasurementUnit.mm ? #4da3d940 : mm-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.measurement-unit == MeasurementUnit.mm ? 1px : 0px;
                    border-color: #4da3d9;

                    mm-touch := TouchArea {
                        clicked => {
                            root.measurement-unit-changed(MeasurementUnit.mm);
                        }
                    }

                    Text {
                        text: "mm";
                        color: root.measurement-unit == MeasurementUnit.mm ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.measurement-unit == MeasurementUnit.inches ? #4da3d940 : in-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.measurement-unit == MeasurementUnit.inches ? 1px : 0px;
                    border-color: #4da3d9;

                    in-touch := TouchArea {
                        clicked => {
                            root.measurement-unit-changed(MeasurementUnit.inches);
                        }
                    }

                    Text {
                        text: "in/mil";
                        color: root.measurement-unit == MeasurementUnit.inches ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #ffffff12;
        }

        // Stain normalization row
        Rectangle {
            height: 28px;

            Text {
                x: 8px;
                text: "Stain Norm";
                color: #8ea0b2;
                font-size: 11px;
                vertical-alignment: center;
            }

            HorizontalLayout {
                x: 80px;
                y: (parent.height - self.height) / 2;
                width: parent.width - 88px;
                height: 22px;
                spacing: 2px;

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.stain-normalization == StainNormalization.none ? #4da3d940 : sn-none-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.stain-normalization == StainNormalization.none ? 1px : 0px;
                    border-color: #4da3d9;

                    sn-none-touch := TouchArea {
                        clicked => {
                            root.stain-normalization-changed(StainNormalization.none);
                        }
                    }

                    Text {
                        text: "None";
                        color: root.stain-normalization == StainNormalization.none ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.stain-normalization == StainNormalization.macenko ? #4da3d940 : sn-macenko-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.stain-normalization == StainNormalization.macenko ? 1px : 0px;
                    border-color: #4da3d9;

                    sn-macenko-touch := TouchArea {
                        clicked => {
                            root.stain-normalization-changed(StainNormalization.macenko);
                        }
                    }

                    Text {
                        text: "Macenko";
                        color: root.stain-normalization == StainNormalization.macenko ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: (parent.width - 4px) / 3;
                    height: 22px;
                    border-radius: 3px;
                    background: root.stain-normalization == StainNormalization.vahadane ? #4da3d940 : sn-vahadane-touch.has-hover ? #ffffff15 : transparent;
                    border-width: root.stain-normalization == StainNormalization.vahadane ? 1px : 0px;
                    border-color: #4da3d9;

                    sn-vahadane-touch := TouchArea {
                        clicked => {
                            root.stain-normalization-changed(StainNormalization.vahadane);
                        }
                    }

                    Text {
                        text: "Vahadane";
                        color: root.stain-normalization == StainNormalization.vahadane ? white : #cccccc;
                        font-size: 10px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Rectangle {
            height: 1px;
            background: #ffffff12;
        }

        // Color Deconvolution header
        Rectangle {
            height: 24px;

            Text {
                x: 8px;
                text: "Color Deconvolution";
                color: white;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
            }
        }

        // Hematoxylin row
        Rectangle {
            height: 28px;

            Text {
                x: 8px;
                y: (parent.height - self.height) / 2;
                width: 24px;
                text: "H";
                color: #6a5acd;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
            }

            // Slider area
            h-slider-area := Rectangle {
                property <float> normalized: (root.deconv-hematoxylin-intensity - 0.0) / 1.0;
                property <length> track-left: 24px;
                property <length> track-right: 52px;
                property <length> track-width: parent.width - self.track-left - self.track-right;

                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;

                Rectangle {
                    x: parent.track-left;
                    y: (parent.height - 3px) / 2;
                    width: parent.track-width;
                    height: 3px;
                    border-radius: 1.5px;
                    background: #ffffff20;

                    Rectangle {
                        x: 0px;
                        width: h-slider-area.normalized * parent.width;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: #6a5acd;
                    }
                }

                Rectangle {
                    x: parent.track-left + parent.normalized * parent.track-width - 5px;
                    y: (parent.height - 10px) / 2;
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: white;
                    border-width: 1px;
                    border-color: #6a5acd;
                }

                h-slider-touch := TouchArea {
                    x: parent.track-left - 5px;
                    y: 0px;
                    width: parent.track-width + 10px;
                    height: parent.height;

                    pointer-event(e) => {
                        if e.kind == PointerEventKind.down || (e.kind == PointerEventKind.move && self.pressed) {
                            let norm = max(0.0, min(1.0, (self.mouse-x - 5px) / max(parent.track-width, 1px)));
                            root.deconv-h-intensity-changed(norm);
                        }
                    }
                }

                Text {
                    x: parent.width - parent.track-right + 4px;
                    y: (parent.height - self.height) / 2;
                    width: 28px;
                    text: Math.round(root.deconv-hematoxylin-intensity * 100) + "%";
                    color: #e0e0e0;
                    font-size: 10px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }

            // View/isolate button
            Rectangle {
                x: parent.width - 16px;
                y: (parent.height - 16px) / 2;
                width: 16px;
                height: 16px;
                border-radius: 8px;
                background: root.deconv-isolated-channel == IsolatedChannel.hematoxylin ? #6a5acd : h-view-touch.has-hover ? #ffffff15 : transparent;
                border-width: 1px;
                border-color: root.deconv-isolated-channel == IsolatedChannel.hematoxylin ? #6a5acd : #666666;

                h-view-touch := TouchArea {
                    clicked => {
                        root.deconv-h-view-toggled();
                    }
                }
            }
        }

        // Eosin row
        Rectangle {
            height: 28px;

            Text {
                x: 8px;
                y: (parent.height - self.height) / 2;
                width: 24px;
                text: "E";
                color: #e05070;
                font-size: 11px;
                font-weight: 700;
                vertical-alignment: center;
            }

            // Slider area
            e-slider-area := Rectangle {
                property <float> normalized: (root.deconv-eosin-intensity - 0.0) / 1.0;
                property <length> track-left: 24px;
                property <length> track-right: 52px;
                property <length> track-width: parent.width - self.track-left - self.track-right;

                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;

                Rectangle {
                    x: parent.track-left;
                    y: (parent.height - 3px) / 2;
                    width: parent.track-width;
                    height: 3px;
                    border-radius: 1.5px;
                    background: #ffffff20;

                    Rectangle {
                        x: 0px;
                        width: e-slider-area.normalized * parent.width;
                        height: parent.height;
                        border-radius: parent.border-radius;
                        background: #e05070;
                    }
                }

                Rectangle {
                    x: parent.track-left + parent.normalized * parent.track-width - 5px;
                    y: (parent.height - 10px) / 2;
                    width: 10px;
                    height: 10px;
                    border-radius: 5px;
                    background: white;
                    border-width: 1px;
                    border-color: #e05070;
                }

                e-slider-touch := TouchArea {
                    x: parent.track-left - 5px;
                    y: 0px;
                    width: parent.track-width + 10px;
                    height: parent.height;

                    pointer-event(e) => {
                        if e.kind == PointerEventKind.down || (e.kind == PointerEventKind.move && self.pressed) {
                            let norm = max(0.0, min(1.0, (self.mouse-x - 5px) / max(parent.track-width, 1px)));
                            root.deconv-e-intensity-changed(norm);
                        }
                    }
                }

                Text {
                    x: parent.width - parent.track-right + 4px;
                    y: (parent.height - self.height) / 2;
                    width: 28px;
                    text: Math.round(root.deconv-eosin-intensity * 100) + "%";
                    color: #e0e0e0;
                    font-size: 10px;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                }
            }

            // View/isolate button
            Rectangle {
                x: parent.width - 16px;
                y: (parent.height - 16px) / 2;
                width: 16px;
                height: 16px;
                border-radius: 8px;
                background: root.deconv-isolated-channel == IsolatedChannel.eosin ? #e05070 : e-view-touch.has-hover ? #ffffff15 : transparent;
                border-width: 1px;
                border-color: root.deconv-isolated-channel == IsolatedChannel.eosin ? #e05070 : #666666;

                e-view-touch := TouchArea {
                    clicked => {
                        root.deconv-e-view-toggled();
                    }
                }
            }
        }
    }

    // Divider above reset button
    Rectangle {
        x: 0px;
        y: layout.preferred-height;
        width: 100%;
        height: 1px;
        background: #ffffff12;
    }

    // Reset to Defaults button
    Rectangle {
        x: 0px;
        y: layout.preferred-height + 1px;
        width: 100%;
        height: 32px;
        background: defaults-touch.has-hover ? #ffffff15 : transparent;
        border-bottom-left-radius: root.border-radius;
        border-bottom-right-radius: root.border-radius;

        defaults-touch := TouchArea {
            clicked => {
                root.reset-adjustments();
            }
        }

        Text {
            text: "Reset to Defaults";
            color: Theme.error;
            font-size: 11px;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
