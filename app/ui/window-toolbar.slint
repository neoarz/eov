import { Theme } from "theme.slint";
import { RenderMode, ToolType } from "types.slint";
import { IconButton, MetadataToolButton, MinimapToolButton, RoiToolButton, ToolButton } from "tab-controls.slint";

export component WindowToolbar inherits Rectangle {
    in property <ToolType> current-tool: ToolType.navigate;
    in property <RenderMode> render-mode: RenderMode.cpu;
    in property <bool> gpu-rendering-available: false;
    in property <bool> show-minimap: true;
    in property <bool> show-metadata: false;

    callback open-file-requested();
    callback open-recent-menu-requested(length, length);
    callback frame-requested();
    callback zoom-in-requested();
    callback zoom-out-requested();
    callback toggle-minimap-requested();
    callback toggle-metadata-requested();
    callback tool-selected(ToolType);
    callback render-backend-selected(RenderMode);
    callback window-minimize();
    callback window-maximize();
    callback window-close();

    out property <float> action-cluster-width: (action-cluster.x + action-cluster.width) / 1px;
    out property <bool> hovered-tooltip-visible: hovered-tooltip-text != "";
    out property <string> hovered-tooltip-text:
        open-button.hovered ? open-button.tooltip-text
        : frame-button.hovered ? frame-button.tooltip-text
        : zoom-in-button.hovered ? zoom-in-button.tooltip-text
        : zoom-out-button.hovered ? zoom-out-button.tooltip-text
        : minimap-button.hovered ? minimap-button.tooltip-text
        : navigate-button.hovered ? navigate-button.tooltip-text
        : roi-button.hovered ? roi-button.tooltip-text
        : measure-button.hovered ? measure-button.tooltip-text
        : cpu-button.hovered ? cpu-button.tooltip-text
        : gpu-button.hovered ? gpu-button.tooltip-text
        : metadata-button.hovered ? metadata-button.tooltip-text
        : minimize-touch.has-hover ? "Minimize window"
        : maximize-touch.has-hover ? "Maximize window"
        : close-win-touch.has-hover ? "Close window"
        : "";
    out property <length> hovered-tooltip-center-x:
        open-button.hovered ? open-button.absolute-position.x + open-button.width / 2
        : frame-button.hovered ? frame-button.absolute-position.x + frame-button.width / 2
        : zoom-in-button.hovered ? zoom-in-button.absolute-position.x + zoom-in-button.width / 2
        : zoom-out-button.hovered ? zoom-out-button.absolute-position.x + zoom-out-button.width / 2
        : minimap-button.hovered ? minimap-button.absolute-position.x + minimap-button.width / 2
        : navigate-button.hovered ? navigate-button.absolute-position.x + navigate-button.width / 2
        : roi-button.hovered ? roi-button.absolute-position.x + roi-button.width / 2
        : measure-button.hovered ? measure-button.absolute-position.x + measure-button.width / 2
        : cpu-button.hovered ? cpu-button.absolute-position.x + cpu-button.width / 2
        : gpu-button.hovered ? gpu-button.absolute-position.x + gpu-button.width / 2
        : metadata-button.hovered ? metadata-button.absolute-position.x + metadata-button.width / 2
        : minimize-touch.has-hover ? minimize-control.absolute-position.x + minimize-control.width / 2
        : maximize-touch.has-hover ? maximize-control.absolute-position.x + maximize-control.width / 2
        : close-win-touch.has-hover ? close-control.absolute-position.x + close-control.width / 2
        : 0px;
    out property <length> hovered-tooltip-top-y:
        open-button.hovered ? open-button.absolute-position.y + open-button.height + 6px
        : frame-button.hovered ? frame-button.absolute-position.y + frame-button.height + 6px
        : zoom-in-button.hovered ? zoom-in-button.absolute-position.y + zoom-in-button.height + 6px
        : zoom-out-button.hovered ? zoom-out-button.absolute-position.y + zoom-out-button.height + 6px
        : minimap-button.hovered ? minimap-button.absolute-position.y + minimap-button.height + 6px
        : navigate-button.hovered ? navigate-button.absolute-position.y + navigate-button.height + 6px
        : roi-button.hovered ? roi-button.absolute-position.y + roi-button.height + 6px
        : measure-button.hovered ? measure-button.absolute-position.y + measure-button.height + 6px
        : cpu-button.hovered ? cpu-button.absolute-position.y + cpu-button.height + 6px
        : gpu-button.hovered ? gpu-button.absolute-position.y + gpu-button.height + 6px
        : metadata-button.hovered ? metadata-button.absolute-position.y + metadata-button.height + 6px
        : minimize-touch.has-hover ? minimize-control.absolute-position.y + minimize-control.height + 6px
        : maximize-touch.has-hover ? maximize-control.absolute-position.y + maximize-control.height + 6px
        : close-win-touch.has-hover ? close-control.absolute-position.y + close-control.height + 6px
        : 0px;

    height: 40px;
    background: Theme.toolbar-bg;
    border-width: 0px;

    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: Theme.border-subtle;
    }

    HorizontalLayout {
        padding: 4px;
        spacing: 4px;

        action-cluster := HorizontalLayout {
            spacing: 4px;

            open-button := IconButton {
                text: "📂";
                tooltip-text: "Open file (right-click for recent)";
                clicked => { root.open-file-requested(); }
                secondary-clicked(x, y) => { root.open-recent-menu-requested(x, y); }
            }

            frame-button := IconButton {
                text: "⛶";
                tooltip-text: "Frame ROI or full slide";
                clicked => { root.frame-requested(); }
            }

            zoom-in-button := IconButton {
                text: "+";
                tooltip-text: "Zoom in";
                clicked => { root.zoom-in-requested(); }
            }

            zoom-out-button := IconButton {
                text: "−";
                tooltip-text: "Zoom out";
                text-offset-y: 1px;
                clicked => { root.zoom-out-requested(); }
            }

            minimap-button := MinimapToolButton {
                tooltip-text: "Toggle minimap";
                is-active: root.show-minimap;
                clicked => { root.toggle-minimap-requested(); }
            }

            Rectangle {
                width: 1px;
                height: 24px;
                background: Theme.border;
            }

            navigate-button := ToolButton {
                icon: "✥";
                tooltip-text: "Navigate (Pan)";
                is-active: root.current-tool == ToolType.navigate;
                clicked => { root.tool-selected(ToolType.navigate); }
            }

            roi-button := RoiToolButton {
                tooltip-text: "Region of interest";
                is-active: root.current-tool == ToolType.region-of-interest;
                clicked => { root.tool-selected(ToolType.region-of-interest); }
            }

            measure-button := ToolButton {
                icon: "📏";
                tooltip-text: "Measure distance";
                is-active: root.current-tool == ToolType.measure-distance;
                clicked => { root.tool-selected(ToolType.measure-distance); }
            }

            Rectangle {
                width: 1px;
                height: 24px;
                background: Theme.border;
            }

            cpu-button := ToolButton {
                width: 40px;
                icon: "CPU";
                tooltip-text: "Use CPU renderer";
                is-active: root.render-mode == RenderMode.cpu;
                clicked => { root.render-backend-selected(RenderMode.cpu); }
            }

            gpu-button := ToolButton {
                width: 40px;
                icon: "GPU";
                tooltip-text: root.gpu-rendering-available ? "Use GPU renderer" : "GPU renderer unavailable";
                enabled: root.gpu-rendering-available;
                is-active: root.render-mode == RenderMode.gpu;
                clicked => {
                    if root.gpu-rendering-available {
                        root.render-backend-selected(RenderMode.gpu);
                    }
                }
            }

            metadata-button := MetadataToolButton {
                tooltip-text: "Toggle metadata HUD";
                is-active: root.show-metadata;
                clicked => { root.toggle-metadata-requested(); }
            }
        }

        Rectangle { horizontal-stretch: 1; }

        Text {
            text: "eov";
            color: Theme.text-secondary;
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
        }

        Rectangle { horizontal-stretch: 1; }

        minimize-control := Rectangle {
            width: 46px;
            height: 32px;
            background: minimize-touch.has-hover ? Theme.surface-hover : transparent;
            border-radius: 0px;

            minimize-touch := TouchArea {
                clicked => { root.window-minimize(); }
            }

            Text {
                text: "─";
                color: Theme.text-primary;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        maximize-control := Rectangle {
            width: 46px;
            height: 32px;
            background: maximize-touch.has-hover ? Theme.surface-hover : transparent;
            border-radius: 0px;

            maximize-touch := TouchArea {
                clicked => { root.window-maximize(); }
            }

            Text {
                text: "☐";
                color: Theme.text-primary;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        close-control := Rectangle {
            width: 46px;
            height: 32px;
            background: close-win-touch.has-hover ? #e81123 : transparent;
            border-radius: 0px;

            close-win-touch := TouchArea {
                clicked => { root.window-close(); }
            }

            Path {
                width: 10px;
                height: 10px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                stroke: close-win-touch.has-hover ? white : Theme.text-primary;
                stroke-width: 1.2px;
                commands: "M 0 0 L 10 10 M 10 0 L 0 10";
            }
        }
    }
}