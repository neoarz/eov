// EosMol WSI Viewer - Main Application Window

import { Button, VerticalBox, HorizontalBox, ScrollView, ComboBox, LineEdit, Palette, StyleMetrics } from "std-widgets.slint";

// Color scheme for professional look
global Theme {
    out property <color> background: #1e1e1e;
    out property <color> surface: #252526;
    out property <color> surface-hover: #2a2d2e;
    out property <color> border: #3e3e42;
    out property <color> border-subtle: #00000066;
    out property <color> text-primary: #cccccc;
    out property <color> text-secondary: #969696;
    out property <color> accent: #0e639c;
    out property <color> accent-hover: #1177bb;
    out property <color> tab-active: #1e1e1e;
    out property <color> tab-inactive: #2d2d30;
    out property <color> minimap-bg: #1e1e1ecc;
    out property <color> minimap-rect: #3794ffaa;
    out property <color> context-menu-bg: #252526;
    out property <color> context-menu-hover: #094771;
    out property <color> toolbar-bg: #181818;
    out property <color> viewport-bg: #1e1e1e;
    out property <color> error: #f44336;
    out property <color> success: #4caf50;
}

// Tab data structure
export struct TabData {
    id: int,
    title: string,
    path: string,
    is-modified: bool,
    is-active: bool,
    is-home: bool,  // True if this is a home tab (no file)
}

// Recently opened file entry
export struct RecentFileData {
    path: string,
    name: string,
}

// Context menu item
export struct ContextMenuItem {
    id: string,
    label: string,
    shortcut: string,
    enabled: bool,
    separator-after: bool,
}

// Tile data for rendering
export struct TileInfo {
    x: int,
    y: int,
    width: int,
    height: int,
    level: int,
}

// Minimap rectangle
export struct MinimapRect {
    x: float,
    y: float,
    width: float,
    height: float,
}

// Viewport state for rendering
export struct ViewportInfo {
    center-x: float,
    center-y: float,
    zoom: float,
    image-width: float,
    image-height: float,
    level: int,
}

// Region of Interest
export struct ROIRect {
    x: float,
    y: float,
    width: float,
    height: float,
    visible: bool,
    ant-offset: float,  // For marching ants animation (0-16)
}

// Measurement line
export struct MeasurementLine {
    x1: float,
    y1: float,
    x2: float,
    y2: float,
    distance-um: float,
    visible: bool,
}

// Tool types
export enum ToolType {
    navigate,
    region-of-interest,
    measure-distance,
}

export enum RenderMode {
    cpu,
    gpu,
}

// ============ Custom Components ============

// Tool button with active state
component ToolButton inherits Rectangle {
    in property <string> icon;
    in property <string> tooltip-text;
    in property <bool> is-active: false;
    in property <bool> enabled: true;
    callback clicked();
    
    width: 32px;
    height: 28px;
    border-radius: 3px;
    background: is-active ? Theme.accent : (touch.has-hover && enabled ? Theme.surface-hover : transparent);
    border-width: is-active ? 0px : 0px;
    
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    
    HorizontalLayout {
        alignment: center;
        Text {
            text: root.icon;
            color: is-active ? white : (root.enabled ? Theme.text-primary : Theme.text-secondary);
            font-size: 14px;
            vertical-alignment: center;
        }
    }
}

// Icon button with hover effect
component IconButton inherits Rectangle {
    in property <string> text;
    in property <bool> enabled: true;
    callback clicked();
    callback secondary-clicked(length, length);
    
    width: 32px;
    height: 28px;
    border-radius: 3px;
    background: touch.has-hover && enabled ? Theme.surface-hover : transparent;
    
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }

        pointer-event(e) => {
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                root.secondary-clicked(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
            }
        }
    }
    
    HorizontalLayout {
        alignment: center;
        Text {
            text: root.text;
            color: root.enabled ? Theme.text-primary : Theme.text-secondary;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
}

// Tab component
component Tab inherits Rectangle {
    in property <TabData> data;
    in property <int> pane-id: 0;
    in property <bool> is-dragging: false;
    callback close-requested(int);
    callback activated(int);
    callback context-menu(int, length, length);
    callback drag-started(int, int, string, length, length); // id, pane, title, abs-x, abs-y
    callback drag-moved(length, length);  // abs-x, abs-y
    callback drag-ended(length, length);  // abs-x, abs-y
    
    min-width: 100px;
    max-width: 200px;
    height: 35px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    background: is-dragging ? Theme.accent : (data.is-active ? Theme.tab-active : Theme.tab-inactive);
    border-width: 0px;
    border-color: transparent;
    opacity: is-dragging ? 0.35 : 1.0;
    
    // Active tab indicator (top border accent)
    if data.is-active: Rectangle {
        x: 0px;
        y: 0px;
        width: 100%;
        height: 2px;
        background: Theme.accent;
        border-top-left-radius: 4px;
        border-top-right-radius: 4px;
    }
    
    states [
        hovered when touch.has-hover && !data.is-active: {
            background: Theme.surface-hover;
        }
    ]
    
    touch := TouchArea {
        property <length> press-x;
        property <length> press-y;
        property <bool> drag-armed: false;
        property <bool> lmb-down: false;

        pointer-event(e) => {
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.left {
                self.press-x = self.mouse-x;
                self.press-y = self.mouse-y;
                self.drag-armed = false;
                self.lmb-down = true;
            }
            if e.kind == PointerEventKind.move && self.lmb-down {
                if !self.drag-armed {
                    let dx = self.mouse-x - self.press-x;
                    let dy = self.mouse-y - self.press-y;
                    if abs(dx) > 6px || abs(dy) > 6px {
                        self.drag-armed = true;
                        root.drag-started(data.id, root.pane-id, data.title, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                    }
                }
                if self.drag-armed {
                    root.drag-moved(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                }
            }
            if e.kind == PointerEventKind.up && e.button == PointerEventButton.left {
                if self.drag-armed {
                    root.drag-ended(self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
                } else if self.lmb-down {
                    root.activated(data.id);
                }
                self.drag-armed = false;
                self.lmb-down = false;
            }
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                root.context-menu(
                    data.id,
                    self.absolute-position.x + self.mouse-x,
                    self.absolute-position.y + self.mouse-y,
                );
            }
        }
    }
    
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        padding-top: 2px;
        spacing: 6px;
        alignment: center;
        
        // Home icon for home tabs
        if data.is-home: Text {
            text: "🏠";
            font-size: 12px;
            vertical-alignment: center;
        }
        
        Text {
            text: data.title + (data.is-modified ? " •" : "");
            color: data.is-active ? Theme.text-primary : Theme.text-secondary;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
        
        Rectangle {
            width: 18px;
            height: 18px;
            border-radius: 3px;
            background: close-touch.has-hover ? Theme.surface-hover : transparent;
            
            close-touch := TouchArea {
                clicked => { root.close-requested(data.id); }
            }
            
            Text {
                text: "×";
                color: close-touch.has-hover ? Theme.text-primary : Theme.text-secondary;
                font-size: 14px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

// Tab bar component with scrollable tabs and new tab button
component TabBar inherits Rectangle {
    in property <int> pane-id: 0;
    in property <[TabData]> tabs;
    in property <int> dragging-tab-id: -1;
    in property <int> drag-source-pane: -1;
    in property <int> drag-source-index: -1;
    in property <length> drag-abs-x: -1px;
    in property <bool> is-drop-target: false;
    in property <bool> show-drop-indicator: true;
    property <length> estimated-tabs-width: tabs.length * 101px;  // conservative min-width + spacing
    // Compute drop indicator position from actual tab layout width
    property <length> tabs-content-width: tabs-overflow
        ? tabs-inline-layout.preferred-width
        : max(1px, tabs-inline-layout.preferred-width - 36px);  // subtract + button (35px) and spacing (1px)
    property <length> avg-slot: tabs.length > 0
        ? (tabs-content-width + 1px) / tabs.length
        : 101px;
    property <int> raw-drop-index: !show-drop-indicator || !is-drop-target || drag-abs-x < 0px
        ? -1
        : Math.max(0, Math.min(tabs.length, Math.round((drag-abs-x - abs-tracker.absolute-position.x) / avg-slot)));
    out property <int> computed-drop-index: drag-source-pane == pane-id && drag-source-index >= 0
        && (raw-drop-index == drag-source-index || raw-drop-index == drag-source-index + 1)
        ? -1
        : raw-drop-index;
    property <bool> tabs-overflow: estimated-tabs-width + 35px > self.width - 8px;
    callback tab-activated(int, int);
    callback tab-close-requested(int, int);
    callback tab-context-menu(int, int, length, length);
    callback new-tab-requested(int);
    callback tab-drag-started(int, int, string, int, length, length); // id, pane, title, index, abs-x, abs-y
    callback tab-drag-moved(length, length);  // abs-x, abs-y
    callback tab-drag-ended(length, length);  // abs-x, abs-y
    
    height: 35px;
    background: Theme.surface;

    Rectangle {
        y: 0px;
        width: 100%;
        height: 1px;
        background: Theme.border-subtle;
    }
    
    // Bottom border line
    Rectangle {
        y: parent.height - 1px;
        width: 100%;
        height: 1px;
        background: Theme.border;
    }
    
    Flickable {
        x: 4px;
        y: 0px;
        width: root.tabs-overflow ? root.width - 39px : root.width - 4px;
        height: 35px;
        viewport-width: tabs-inline-layout.preferred-width;
        interactive: root.tabs-overflow;

        // Absolute position tracker for drop index computation
        abs-tracker := Rectangle { width: 0px; height: 0px; }

        tabs-inline-layout := HorizontalLayout {
            alignment: start;
            spacing: 1px;

            for tab[i] in tabs: Tab {
                pane-id: root.pane-id;
                data: tab;
                is-dragging: root.dragging-tab-id == tab.id;
                close-requested(id) => { root.tab-close-requested(root.pane-id, id); }
                activated(id) => { root.tab-activated(root.pane-id, id); }
                context-menu(id, x, y) => { root.tab-context-menu(root.pane-id, id, x, y); }
                drag-started(id, pane, title, abs-x, abs-y) => { root.tab-drag-started(id, pane, title, i, abs-x, abs-y); }
                drag-moved(abs-x, abs-y) => { root.tab-drag-moved(abs-x, abs-y); }
                drag-ended(abs-x, abs-y) => { root.tab-drag-ended(abs-x, abs-y); }
            }

            if !root.tabs-overflow: Rectangle {
                width: 35px;
                height: 35px;
                background: inline-new-tab-touch.has-hover ? Theme.surface-hover : transparent;

                inline-new-tab-touch := TouchArea {
                    clicked => { root.new-tab-requested(root.pane-id); }
                }

                Text {
                    text: "+";
                    color: inline-new-tab-touch.has-hover ? Theme.text-primary : Theme.text-secondary;
                    font-size: 20px;
                    font-weight: 400;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        
        // Drop position indicator (vertical line between tabs)
        if root.computed-drop-index >= 0: Rectangle {
            x: root.computed-drop-index * root.avg-slot - 1px;
            y: 4px;
            width: 2px;
            height: 27px;
            border-radius: 1px;
            background: Theme.accent;
        }
    }

    if root.tabs-overflow: Rectangle {
        x: root.width - self.width;
        y: 0px;
        width: 35px;
        height: 35px;
        background: new-tab-touch.has-hover ? Theme.surface-hover : transparent;

        new-tab-touch := TouchArea {
            clicked => { root.new-tab-requested(root.pane-id); }
        }

        Text {
            text: "+";
            color: new-tab-touch.has-hover ? Theme.text-primary : Theme.text-secondary;
            font-size: 20px;
            font-weight: 400;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// Context menu
component ContextMenu inherits Rectangle {
    in property <[ContextMenuItem]> items;
    in property <bool> is-visible: false;
    in property <length> menu-x: 0px;
    in property <length> menu-y: 0px;
    callback item-clicked(string);
    
    x: menu-x;
    y: menu-y;
    width: root.is-visible ? 200px : 0px;
    height: root.is-visible ? items.length * 28px : 0px;
    background: Theme.context-menu-bg;
    border-radius: 4px;
    drop-shadow-blur: 8px;
    drop-shadow-color: #00000066;
    opacity: root.is-visible ? 1 : 0;
    
    // Backdrop to close menu on click outside
    if root.is-visible: Rectangle {
        x: -10000px;
        y: -10000px;
        width: 20000px;
        height: 20000px;
        
        TouchArea {
            clicked => { root.item-clicked("dismiss"); }
        }
    }
    
    VerticalLayout {
        for item in items: Rectangle {
            height: 28px;
            background: item-touch.has-hover && item.enabled ? Theme.context-menu-hover : transparent;
            
            item-touch := TouchArea {
                enabled: item.enabled;
                clicked => { root.item-clicked(item.id); }
            }
            
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                
                Text {
                    text: item.label;
                    color: item.enabled ? Theme.text-primary : Theme.text-secondary;
                    font-size: 12px;
                    vertical-alignment: center;
                }
                
                Rectangle { horizontal-stretch: 1; }
                
                Text {
                    text: item.shortcut;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
    }
}

// Minimap component
component Minimap inherits Rectangle {
    in property <image> thumbnail;
    in property <MinimapRect> viewport-rect;
    // Image dimensions for calculating contain fit
    in property <float> image-width: 1.0;
    in property <float> image-height: 1.0;
    callback navigate(float, float);
    
    // Track if we're in a drag operation
    property <bool> is-dragging: false;
    
    // Minimap drawing area (padding of 5px on each side)
    property <length> content-x: 5px;
    property <length> content-y: 5px;
    property <length> content-width: self.width - 10px;
    property <length> content-height: self.height - 10px;
    
    // Calculate actual image display area within content (accounting for contain fit)
    // When image-fit: contain is used, the image is scaled to fit while preserving aspect ratio
    property <float> image-aspect: image-width / max(image-height, 0.001);
    property <float> content-aspect: (content-width / 1px) / max(content-height / 1px, 0.001);
    
    // If image is wider than container (relative to aspect), it fills width and has vertical padding
    // If image is taller than container (relative to aspect), it fills height and has horizontal padding
    property <length> img-display-width: image-aspect > content-aspect 
        ? content-width 
        : content-height * image-aspect;
    property <length> img-display-height: image-aspect > content-aspect 
        ? content-width / image-aspect 
        : content-height;
    property <length> img-display-x: content-x + (content-width - img-display-width) / 2;
    property <length> img-display-y: content-y + (content-height - img-display-height) / 2;
    
    width: 150px;
    height: 150px;
    background: Theme.minimap-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.border;
    
    // Thumbnail - uses contain so aspect ratio is preserved
    Image {
        x: content-x;
        y: content-y;
        width: content-width;
        height: content-height;
        source: thumbnail;
        image-fit: contain;
    }
    
    // Viewport indicator rectangle
    // Maps normalized 0-1 coordinates to the actual displayed image area
    Rectangle {
        x: img-display-x + viewport-rect.x * img-display-width;
        y: img-display-y + viewport-rect.y * img-display-height;
        width: viewport-rect.width * img-display-width;
        height: viewport-rect.height * img-display-height;
        background: transparent;
        border-width: 2px;
        border-color: Theme.minimap-rect;
    }
    
    // Touch handling for navigation - covers entire minimap
    touch := TouchArea {
        width: 100%;
        height: 100%;
        
        pointer-event(e) => {
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.left {
                root.is-dragging = true;
                // Convert click to normalized coordinates (0-1) within the actual image area
                let rel-x = (self.mouse-x - root.img-display-x) / root.img-display-width;
                let rel-y = (self.mouse-y - root.img-display-y) / root.img-display-height;
                root.navigate(rel-x, rel-y);
            } else if e.kind == PointerEventKind.up {
                root.is-dragging = false;
            } else if e.kind == PointerEventKind.move && root.is-dragging {
                let rel-x = (self.mouse-x - root.img-display-x) / root.img-display-width;
                let rel-y = (self.mouse-y - root.img-display-y) / root.img-display-height;
                root.navigate(rel-x, rel-y);
            }
        }
    }
}

component ZoomSlider inherits Rectangle {
    in property <float> value: 0.5;
    callback value-changed(float);

    width: 20px;
    height: 150px;
    background: Theme.minimap-bg;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.border;

    property <float> clamped-value: max(0, min(1, value));
    property <length> track-top: 22px;
    property <length> track-bottom: 22px;
    property <length> track-height: self.height - root.track-top - root.track-bottom;
    property <length> handle-size: 10px;

    Rectangle {
        y: 0px;
        width: 100%;
        height: root.track-top;
        background: plus-touch.has-hover ? Theme.surface-hover : transparent;

        plus-touch := TouchArea {
            clicked => { root.value-changed(Math.min(1, root.clamped-value + 0.08)); }
        }

        Text {
            text: "+";
            color: Theme.text-primary;
            font-size: 13px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    Rectangle {
        x: root.width / 2 - 1px;
        y: root.track-top;
        width: 2px;
        height: root.track-height;
        border-radius: 2px;
        background: Theme.border;
    }

    Rectangle {
        x: root.width / 2 - root.handle-size / 2;
        y: root.track-top + (1 - root.clamped-value) * root.track-height - root.handle-size / 2;
        width: root.handle-size;
        height: root.handle-size;
        border-radius: root.handle-size / 2;
        background: Theme.accent;
        border-width: 1px;
        border-color: white;
    }

    slider-touch := TouchArea {
        y: root.track-top;
        width: 100%;
        height: root.track-height;

        pointer-event(e) => {
            if e.kind == PointerEventKind.down || (e.kind == PointerEventKind.move && self.pressed) {
                let normalized = 1 - max(0, min(1, self.mouse-y / max(root.track-height, 1px)));
                root.value-changed(normalized);
            }
        }
    }

    Rectangle {
        y: root.height - root.track-bottom;
        width: 100%;
        height: root.track-bottom;
        background: minus-touch.has-hover ? Theme.surface-hover : transparent;

        minus-touch := TouchArea {
            clicked => { root.value-changed(Math.max(0, root.clamped-value - 0.08)); }
        }

        Text {
            text: "-";
            color: Theme.text-primary;
            font-size: 14px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}

// Viewport component for WSI rendering
component Viewport inherits Rectangle {
    in property <image> content;
    in property <ViewportInfo> viewport-info;
    in property <image> minimap-thumbnail;
    in property <MinimapRect> minimap-rect;
    in property <bool> show-minimap: true;
    in property <string> status-text: "";
    in property <bool> is-loading: false;
    in property <bool> debug-mode: false;
    in property <float> fps: 0;
    in property <float> zoom-slider-position: 0.5;
    
    // Tool system properties
    in property <ToolType> current-tool: ToolType.navigate;
    in property <ROIRect> roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in property <[MeasurementLine]> measurements: [];
    in property <MeasurementLine> candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    
    callback pan(float, float);
    callback zoom(float, float, float);
    callback fit-to-view();
    callback start-pan(float, float);
    callback end-pan();
    callback minimap-navigate(float, float);
    callback zoom-slider-changed(float);
    callback file-dropped(string);
    
    // Tool callbacks
    callback tool-mouse-down(float, float);
    callback tool-mouse-move(float, float);
    callback tool-mouse-up(float, float);
    callback cancel-tool();
    callback close-tab();
    
    // Export viewport dimensions for rendering
    out property <length> viewport-width: self.width;
    out property <length> viewport-height: self.height;
    
    background: Theme.viewport-bg;
    
    // Main content area (visual only - declared first so it's at the back)
    Rectangle {
        clip: true;
        width: parent.width;
        height: parent.height;
        
        // Rendered image - use fill to match buffer size exactly
        Image {
            width: 100%;
            height: 100%;
            source: content;
            image-fit: fill;
        }
        
        // ROI overlay - dim area OUTSIDE the selected rectangle
        if root.roi-rect.visible: Rectangle {
            // We create 4 rectangles to dim around the ROI (letterbox effect)
            // Top dim bar
            Rectangle {
                x: 0;
                y: 0;
                width: 100%;
                height: root.roi-rect.y * 1px;
                background: #00000080;
            }
            // Bottom dim bar  
            Rectangle {
                x: 0;
                y: (root.roi-rect.y + root.roi-rect.height) * 1px;
                width: 100%;
                height: parent.height - (root.roi-rect.y + root.roi-rect.height) * 1px;
                background: #00000080;
            }
            // Left dim bar (between top and bottom)
            Rectangle {
                x: 0;
                y: root.roi-rect.y * 1px;
                width: root.roi-rect.x * 1px;
                height: root.roi-rect.height * 1px;
                background: #00000080;
            }
            // Right dim bar (between top and bottom)
            Rectangle {
                x: (root.roi-rect.x + root.roi-rect.width) * 1px;
                y: root.roi-rect.y * 1px;
                width: parent.width - (root.roi-rect.x + root.roi-rect.width) * 1px;
                height: root.roi-rect.height * 1px;
                background: #00000080;
            }
            
            // Marching ants border - outer black ring
            Rectangle {
                x: root.roi-rect.x * 1px - 1px;
                y: root.roi-rect.y * 1px - 1px;
                width: root.roi-rect.width * 1px + 2px;
                height: root.roi-rect.height * 1px + 2px;
                background: transparent;
                border-width: 1px;
                border-color: black;
            }
            
            // Marching ants border - inner black ring (creates contrast)
            Rectangle {
                x: root.roi-rect.x * 1px + 1px;
                y: root.roi-rect.y * 1px + 1px;
                width: root.roi-rect.width * 1px - 2px;
                height: root.roi-rect.height * 1px - 2px;
                background: transparent;
                border-width: 1px;
                border-color: black;
            }
            
            // Animated white center border
            Rectangle {
                x: root.roi-rect.x * 1px;
                y: root.roi-rect.y * 1px;
                width: root.roi-rect.width * 1px;
                height: root.roi-rect.height * 1px;
                background: transparent;
                border-width: 1px;
                border-color: white;
                clip: true;
                
                // Create animated stripe pattern (ant-offset cycles 0-16 from Rust)
                property <length> stripe-period: 16px;
                property <length> stripe-offset: root.roi-rect.ant-offset * 1px;
                
                // Top edge stripes
                for i in 100: Rectangle {
                    x: i * parent.stripe-period - parent.stripe-offset;
                    y: -1px;
                    width: parent.stripe-period / 2;
                    height: 3px;
                    background: black;
                }
                
                // Bottom edge stripes
                for i in 100: Rectangle {
                    x: i * parent.stripe-period - parent.stripe-period + parent.stripe-offset;
                    y: parent.height - 2px;
                    width: parent.stripe-period / 2;
                    height: 3px;
                    background: black;
                }
                
                // Left edge stripes  
                for i in 100: Rectangle {
                    x: -1px;
                    y: i * parent.stripe-period - parent.stripe-offset;
                    width: 3px;
                    height: parent.stripe-period / 2;
                    background: black;
                }
                
                // Right edge stripes
                for i in 100: Rectangle {
                    x: parent.width - 2px;
                    y: i * parent.stripe-period - parent.stripe-period + parent.stripe-offset;
                    width: 3px;
                    height: parent.stripe-period / 2;
                    background: black;
                }
            }
        }
        
        // Measurement lines overlay
        for measurement in root.measurements: Rectangle {
            width: 100%;
            height: 100%;

            // Line between endpoints
            Path {
                viewbox-width: self.width / 1px;
                viewbox-height: self.height / 1px;
                stroke: #2ECC71;
                stroke-width: 2px;
                stroke-line-cap: round;
                MoveTo { x: measurement.x1; y: measurement.y1; }
                LineTo { x: measurement.x2; y: measurement.y2; }
            }
            // Start point circle
            Rectangle {
                x: measurement.x1 * 1px - 4px;
                y: measurement.y1 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #2ECC71;
                border-width: 1.5px;
                border-color: white;
            }
            // End point circle
            Rectangle {
                x: measurement.x2 * 1px - 4px;
                y: measurement.y2 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #2ECC71;
                border-width: 1.5px;
                border-color: white;
            }
            // Distance label at midpoint
            Rectangle {
                x: (measurement.x1 + measurement.x2) / 2 * 1px - self.width / 2;
                y: (measurement.y1 + measurement.y2) / 2 * 1px - self.height - 6px;
                width: measurement-text.preferred-width + 14px;
                height: measurement-text.preferred-height + 6px;
                border-radius: self.height / 2;
                background: #1a1a1aee;
                border-width: 1px;
                border-color: #2ECC7180;
                drop-shadow-blur: 4px;
                drop-shadow-color: #00000066;

                measurement-text := Text {
                    x: 7px;
                    y: 3px;
                    text: measurement.distance-um >= 1000 ? Math.round(measurement.distance-um / 10) / 100 + " mm"
                        : measurement.distance-um > 0 ? Math.round(measurement.distance-um * 100) / 100 + " µm"
                        : Math.round(Math.sqrt((measurement.x2 - measurement.x1) * (measurement.x2 - measurement.x1) + (measurement.y2 - measurement.y1) * (measurement.y2 - measurement.y1)) * 10) / 10 + " px";
                    color: white;
                    font-size: 11px;
                    font-weight: 500;
                }
            }
        }
        
        // Candidate measurement line (while drawing)
        if root.candidate-measurement.visible: Rectangle {
            width: 100%;
            height: 100%;

            // Line between endpoints
            Path {
                viewbox-width: self.width / 1px;
                viewbox-height: self.height / 1px;
                stroke: #F1C40F;
                stroke-width: 2px;
                stroke-line-cap: round;
                MoveTo { x: root.candidate-measurement.x1; y: root.candidate-measurement.y1; }
                LineTo { x: root.candidate-measurement.x2; y: root.candidate-measurement.y2; }
            }
            // Start point circle
            Rectangle {
                x: root.candidate-measurement.x1 * 1px - 4px;
                y: root.candidate-measurement.y1 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #F1C40F;
                border-width: 1.5px;
                border-color: white;
            }
            // End point circle
            Rectangle {
                x: root.candidate-measurement.x2 * 1px - 4px;
                y: root.candidate-measurement.y2 * 1px - 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: #F1C40F;
                border-width: 1.5px;
                border-color: white;
            }
            // Distance label at midpoint
            Rectangle {
                x: (root.candidate-measurement.x1 + root.candidate-measurement.x2) / 2 * 1px - self.width / 2;
                y: (root.candidate-measurement.y1 + root.candidate-measurement.y2) / 2 * 1px - self.height - 6px;
                width: candidate-text.preferred-width + 14px;
                height: candidate-text.preferred-height + 6px;
                border-radius: self.height / 2;
                background: #1a1a1aee;
                border-width: 1px;
                border-color: #F1C40F80;
                drop-shadow-blur: 4px;
                drop-shadow-color: #00000066;

                candidate-text := Text {
                    x: 7px;
                    y: 3px;
                    text: root.candidate-measurement.distance-um >= 1000 ? Math.round(root.candidate-measurement.distance-um / 10) / 100 + " mm"
                        : root.candidate-measurement.distance-um > 0 ? Math.round(root.candidate-measurement.distance-um * 100) / 100 + " µm"
                        : Math.round(Math.sqrt((root.candidate-measurement.x2 - root.candidate-measurement.x1) * (root.candidate-measurement.x2 - root.candidate-measurement.x1) + (root.candidate-measurement.y2 - root.candidate-measurement.y1) * (root.candidate-measurement.y2 - root.candidate-measurement.y1)) * 10) / 10 + " px";
                    color: white;
                    font-size: 11px;
                    font-weight: 500;
                }
            }
        }
        
        // Loading indicator
        if is-loading: Rectangle {
            x: parent.width / 2 - 40px;
            y: parent.height / 2 - 40px;
            width: 80px;
            height: 80px;
            background: Theme.surface;
            border-radius: 8px;
            
            Text {
                text: "Loading...";
                color: Theme.text-primary;
                font-size: 12px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
    
    // Input handling - declared AFTER content so it's on top and captures all events
    // Declared BEFORE minimap so minimap is on top and can receive its own events
    touch := TouchArea {
        width: 100%;
        height: parent.height;
        
        property <length> drag-start-x;
        property <length> drag-start-y;
        property <bool> is-dragging: false;
        property <bool> is-tool-dragging: false;
        
        // Forward focus to keyboard handler on any click
        clicked => {
            focus-scope.focus();
        }
        
        pointer-event(e) => {
            // Request keyboard focus on any mouse down
            if e.kind == PointerEventKind.down {
                focus-scope.focus();
            }
            
            // Right mouse button: always pan regardless of tool
            if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                self.is-dragging = true;
                self.drag-start-x = self.mouse-x;
                self.drag-start-y = self.mouse-y;
                root.start-pan(self.mouse-x / 1px, self.mouse-y / 1px);
            } else if e.kind == PointerEventKind.up && e.button == PointerEventButton.right {
                self.is-dragging = false;
                root.end-pan();
            }
            // Left mouse button: tool-dependent behavior
            else if e.kind == PointerEventKind.down && e.button == PointerEventButton.left {
                if root.current-tool == ToolType.navigate {
                    // Navigate tool: LMB also pans
                    self.is-dragging = true;
                    self.drag-start-x = self.mouse-x;
                    self.drag-start-y = self.mouse-y;
                    root.start-pan(self.mouse-x / 1px, self.mouse-y / 1px);
                } else {
                    // Other tools: fire tool callback
                    self.is-tool-dragging = true;
                    root.tool-mouse-down(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            } else if e.kind == PointerEventKind.up && e.button == PointerEventButton.left {
                if root.current-tool == ToolType.navigate {
                    self.is-dragging = false;
                    root.end-pan();
                } else {
                    self.is-tool-dragging = false;
                    root.tool-mouse-up(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            }
            // Handle move events
            else if e.kind == PointerEventKind.move {
                if self.is-dragging {
                    let dx = (self.mouse-x - self.drag-start-x) / 1px;
                    let dy = (self.mouse-y - self.drag-start-y) / 1px;
                    self.drag-start-x = self.mouse-x;
                    self.drag-start-y = self.mouse-y;
                    root.pan(dx, dy);
                } else if self.is-tool-dragging || root.current-tool != ToolType.navigate {
                    root.tool-mouse-move(self.mouse-x / 1px, self.mouse-y / 1px);
                }
            }
        }
        
        scroll-event(e) => {
            let factor = e.delta-y > 0 ? 1.15 : (1.0 / 1.15);
            root.zoom(factor, touch.mouse-x / 1px, touch.mouse-y / 1px);
            return accept;
        }
    }
    
    // Minimap in bottom right - declared AFTER touch area so it receives events on top
    if show-minimap: Minimap {
        x: parent.width - self.width - 16px;
        y: parent.height - self.height - 16px;
        thumbnail: minimap-thumbnail;
        viewport-rect: minimap-rect;
        image-width: viewport-info.image-width;
        image-height: viewport-info.image-height;
        navigate(nx, ny) => { root.minimap-navigate(nx, ny); }
    }

    if show-minimap: ZoomSlider {
        x: parent.width - 16px - 150px - self.width - 8px;
        y: parent.height - self.height - 16px;
        value: root.zoom-slider-position;
        value-changed(value) => { root.zoom-slider-changed(value); }
    }
    
    // FPS overlay in top right corner (debug mode only)
    if debug-mode: Rectangle {
        x: parent.width - self.width - 8px;
        y: 8px;
        width: 70px;
        height: 24px;
        background: #000000aa;
        border-radius: 4px;
        
        Text {
            x: 8px;
            y: 4px;
            text: Math.round(fps) + " FPS";
            color: fps >= 25 ? #00ff00 : fps >= 15 ? #ffff00 : #ff0000;
            font-size: 12px;
            font-weight: 600;
        }
    }
    
    // Focus for keyboard input - zero size, receives focus via forward-focus
    focus-scope := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(e) => {
            if e.text == "w" && e.modifiers.control {
                root.close-tab();
                return accept;
            }
            if e.text == "f" || e.text == "F" {
                root.fit-to-view();
                return accept;
            }
            if e.text == Key.Escape {
                root.cancel-tool();
                return accept;
            }
            return reject;
        }
    }
}

// Home screen component - shown when no file is open or for home tabs
component HomeScreen inherits Rectangle {
    in property <[RecentFileData]> recent-files: [];
    callback open-file-requested();
    callback open-recent-file(string);
    
    background: Theme.background;
    
    // Center the content card absolutely
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: 500px;
        height: recent-files.length > 0 ? 480px : 300px;
        
        VerticalLayout {
            alignment: center;
            spacing: 0px;
            
            // Logo/Icon area
            Text {
                text: "🔬";
                font-size: 48px;
                horizontal-alignment: center;
            }
            
            Rectangle { height: 16px; }
            
            // Subtitle
            Text {
                text: "Whole Slide Image Viewer";
                color: Theme.text-secondary;
                font-size: 14px;
                horizontal-alignment: center;
            }
            
            Rectangle { height: 32px; }
            
            // Open file button - centered using HorizontalLayout
            HorizontalLayout {
                alignment: center;
                
                Rectangle {
                    width: 160px;
                    height: 40px;
                    background: open-touch.has-hover ? Theme.accent-hover : Theme.accent;
                    border-radius: 6px;
                    
                    open-touch := TouchArea {
                        clicked => { root.open-file-requested(); }
                    }
                    
                    HorizontalLayout {
                        alignment: center;
                        spacing: 8px;
                        
                        Text {
                            text: "📂";
                            font-size: 16px;
                            vertical-alignment: center;
                        }
                        
                        Text {
                            text: "Open File";
                            color: white;
                            font-size: 14px;
                            font-weight: 500;
                            vertical-alignment: center;
                        }
                    }
                }
            }
            
            // "Or drag and drop files" hint
            Rectangle { height: 16px; }
            Text {
                text: "or drag and drop WSI files";
                color: Theme.text-secondary;
                font-size: 12px;
                horizontal-alignment: center;
            }
            
            // Recent files section
            if recent-files.length > 0: Rectangle {
                height: 180px;
                
                VerticalLayout {
                    padding-top: 32px;
                    spacing: 8px;
                    
                    // Section header
                    Text {
                        text: "Recently Opened";
                        color: Theme.text-primary;
                        font-size: 13px;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }
                    
                    Rectangle { height: 8px; }
                    
                    // Recent file list
                    for file[i] in recent-files: Rectangle {
                        height: 28px;
                        background: file-touch.has-hover ? Theme.surface-hover : transparent;
                        border-radius: 4px;
                        
                        file-touch := TouchArea {
                            clicked => { root.open-recent-file(file.path); }
                        }
                        
                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            alignment: start;
                            spacing: 8px;
                            
                            Text {
                                text: "📄";
                                font-size: 12px;
                                vertical-alignment: center;
                            }
                            
                            Text {
                                text: file.name;
                                color: file-touch.has-hover ? Theme.accent : Theme.text-primary;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }
            }
            
            // Tip at bottom
            Rectangle { height: 24px; }
            Text {
                text: "Tip: Use scroll wheel to zoom, drag to pan";
                color: Theme.text-secondary;
                font-size: 11px;
                horizontal-alignment: center;
            }
        }
    }
}

// Split pane container supporting horizontal and vertical splits
component SplitPaneContainer inherits Rectangle {
    in property <[TabData]> primary-tabs;
    in property <[TabData]> secondary-tabs;
    in property <image> viewport-content;
    in property <image> secondary-viewport-content;
    in property <ViewportInfo> viewport-info;
    in property <ViewportInfo> secondary-viewport-info;
    in property <image> minimap-thumbnail;
    in property <image> secondary-minimap-thumbnail;
    in property <MinimapRect> minimap-rect;
    in property <MinimapRect> secondary-minimap-rect;
    in property <string> status-text;
    in property <bool> is-loading: false;
    in property <bool> split-enabled: false;
    in property <float> split-position: 0.5;
    in property <int> focused-pane: 0; // 0 = primary, 1 = secondary
    in property <bool> debug-mode: false;
    in property <float> fps: 0;
    in property <bool> primary-is-home-tab: false;
    in property <bool> secondary-is-home-tab: false;
    in property <[RecentFileData]> recent-files: [];
    in property <float> zoom-slider-position: 0.5;
    in property <float> secondary-zoom-slider-position: 0.5;
    in property <int> dragging-tab-id: -1;
    in property <int> drag-source-pane: -1;
    in property <int> drag-source-index: -1;
    in property <string> dragging-tab-title: "";
    in property <int> drop-target-pane: -1;
    in property <int> split-drop-side: -1;
    in property <length> drag-abs-x: -1px;
    out property <int> active-drop-index: drop-target-pane == 0 || !split-enabled
        ? primary-tab-bar.computed-drop-index
        : secondary-tab-bar.computed-drop-index;
    
    // Tool system properties
    in property <ToolType> current-tool: ToolType.navigate;
    in property <ROIRect> primary-roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in property <ROIRect> secondary-roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in property <[MeasurementLine]> primary-measurements: [];
    in property <[MeasurementLine]> secondary-measurements: [];
    in property <MeasurementLine> primary-candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    in property <MeasurementLine> secondary-candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    
    // Output viewport dimensions
    out property <length> viewport-width: split-enabled ? 
        (self.width * split-position - 3px) : self.width;
    out property <length> viewport-height: self.height - 35px;
    out property <length> secondary-viewport-width: self.width * (1 - split-position) - 3px;
    out property <length> secondary-viewport-height: self.height - 35px;
    
    callback tab-activated(int, int);
    callback tab-close-requested(int, int);
    callback tab-context-menu(int, int, length, length);
    callback new-tab-requested(int);
    callback open-file-requested();
    callback open-recent-file(string);
    callback viewport-pan(float, float);
    callback viewport-zoom(float, float, float);
    callback viewport-fit-to-view();
    callback viewport-start-pan(float, float);
    callback viewport-end-pan();
    callback minimap-navigate(float, float);
    callback file-dropped(string);
    callback pane-focused(int);
    callback split-position-changed(float);
    callback tab-drag-started(int, int, string, int, length, length); // id, pane, title, index, abs-x, abs-y
    callback tab-drag-moved(length, length);  // abs-x, abs-y
    callback tab-drag-ended(length, length);  // abs-x, abs-y
    callback move-tab-to-pane(int, int, int);
    callback split-tab-by-drop(int, int);
    callback reorder-tab(int, int, int);  // pane, tab-id, new-index
    callback clear-tab-drag();
    callback zoom-slider-changed(int, float);
    
    // Tool callbacks
    callback tool-mouse-down(float, float);
    callback tool-mouse-move(float, float);
    callback tool-mouse-up(float, float);
    callback cancel-tool();
    callback close-active-tab();
    
    background: Theme.background;
    
    HorizontalLayout {
        vertical-stretch: 1;

        primary-pane := Rectangle {
            width: root.split-enabled ? parent.width * root.split-position - 3px : parent.width;
            border-width: root.dragging-tab-id != -1 && root.drop-target-pane == 0 ? 2px : (root.focused-pane == 0 && root.split-enabled ? 2px : 0px);
            border-color: root.dragging-tab-id != -1 && root.drop-target-pane == 0 ? white : Theme.accent;
            background: root.dragging-tab-id != -1 && root.drop-target-pane == 0 ? #ffffff08 : transparent;

            VerticalLayout {
                primary-tab-bar := TabBar {
                    pane-id: 0;
                    tabs: root.primary-tabs;
                    dragging-tab-id: root.dragging-tab-id;
                    drag-source-pane: root.drag-source-pane;
                    drag-source-index: root.drag-source-index;
                    drag-abs-x: root.drag-abs-x;
                    is-drop-target: root.drop-target-pane == 0;
                    show-drop-indicator: root.split-drop-side == -1;
                    tab-activated(pane, id) => { root.tab-activated(pane, id); }
                    tab-close-requested(pane, id) => { root.tab-close-requested(pane, id); }
                    tab-context-menu(pane, id, x, y) => { root.tab-context-menu(pane, id, x, y); }
                    new-tab-requested(pane) => { root.new-tab-requested(pane); }
                    tab-drag-started(id, pane, title, index, abs-x, abs-y) => { root.tab-drag-started(id, pane, title, index, abs-x, abs-y); }
                    tab-drag-moved(abs-x, abs-y) => { root.tab-drag-moved(abs-x, abs-y); }
                    tab-drag-ended(abs-x, abs-y) => { root.tab-drag-ended(abs-x, abs-y); }
                }

                Rectangle {
                    vertical-stretch: 1;

                    if root.primary-is-home-tab || root.primary-tabs.length == 0: HomeScreen {
                        recent-files: root.recent-files;
                        open-file-requested => { root.open-file-requested(); }
                        open-recent-file(path) => { root.open-recent-file(path); }
                    }

                    if !root.primary-is-home-tab && root.primary-tabs.length > 0: Viewport {
                        content: viewport-content;
                        viewport-info: root.viewport-info;
                        minimap-thumbnail: minimap-thumbnail;
                        minimap-rect: minimap-rect;
                        status-text: root.status-text;
                        is-loading: root.is-loading;
                        current-tool: root.current-tool;
                        roi-rect: root.primary-roi-rect;
                        measurements: root.primary-measurements;
                        candidate-measurement: root.primary-candidate-measurement;
                        debug-mode: root.debug-mode;
                        fps: root.fps;
                        zoom-slider-position: root.zoom-slider-position;

                        pan(dx, dy) => { root.pane-focused(0); root.viewport-pan(dx, dy); }
                        zoom(f, x, y) => { root.pane-focused(0); root.viewport-zoom(f, x, y); }
                        fit-to-view => { root.pane-focused(0); root.viewport-fit-to-view(); }
                        start-pan(x, y) => { root.pane-focused(0); root.viewport-start-pan(x, y); }
                        end-pan => { root.viewport-end-pan(); }
                        minimap-navigate(nx, ny) => { root.pane-focused(0); root.minimap-navigate(nx, ny); }
                        zoom-slider-changed(value) => { root.pane-focused(0); root.zoom-slider-changed(0, value); }
                        file-dropped(path) => { root.file-dropped(path); }
                        tool-mouse-down(x, y) => { root.pane-focused(0); root.tool-mouse-down(x, y); }
                        tool-mouse-move(x, y) => { root.tool-mouse-move(x, y); }
                        tool-mouse-up(x, y) => { root.tool-mouse-up(x, y); }
                        cancel-tool => { root.cancel-tool(); }
                        close-tab => { root.close-active-tab(); }
                    }
                }
            }

            if root.dragging-tab-id != -1 && !root.split-enabled && root.split-drop-side != -1: Rectangle {
                x: 0px;
                y: 35px;
                width: parent.width;
                height: parent.height - 35px;
                background: #0b122080;

                Rectangle {
                    x: root.split-drop-side == 0 ? 10px : parent.width / 2 + 5px;
                    y: 10px;
                    width: parent.width / 2 - 15px;
                    height: parent.height - 20px;
                    border-radius: 8px;
                    background: #3794ff33;
                    border-width: 2px;
                    border-color: #79b8ffff;

                    Text {
                        text: root.split-drop-side == 0 ? "Create Left Pane" : "Create Right Pane";
                        color: white;
                        font-size: 18px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    x: parent.width / 2 - 1px;
                    y: 10px;
                    width: 2px;
                    height: parent.height - 20px;
                    background: #ffffff66;
                }
            }
        }

        // Splitter (collapses to 0 when split is disabled)
        Rectangle {
            width: root.split-enabled ? 6px : 0px;
            background: root.split-enabled ? (splitter-touch.has-hover || splitter-touch.pressed ? Theme.accent : Theme.border) : transparent;

            splitter-touch := TouchArea {
                property <length> drag-start-x;
                enabled: root.split-enabled;

                pointer-event(e) => {
                    if e.kind == PointerEventKind.down && e.button == PointerEventButton.left {
                        self.drag-start-x = self.mouse-x;
                    } else if e.kind == PointerEventKind.move && self.pressed {
                        let delta = (self.mouse-x - self.drag-start-x) / root.width;
                        let new-pos = (root.split-position + delta).clamp(0.2, 0.8);
                        root.split-position-changed(new-pos);
                        self.drag-start-x = self.mouse-x;
                    }
                }
                mouse-cursor: root.split-enabled ? ew-resize : default;
            }
        }

        // Secondary pane (collapses to 0 when split is disabled)
        secondary-pane := Rectangle {
            horizontal-stretch: root.split-enabled ? 1 : 0;
            max-width: root.split-enabled ? 100000px : 0px;
            clip: true;
            border-width: root.split-enabled && root.dragging-tab-id != -1 && root.drop-target-pane == 1 ? 2px : (root.split-enabled && root.focused-pane == 1 ? 2px : 0px);
            border-color: root.dragging-tab-id != -1 && root.drop-target-pane == 1 ? white : Theme.accent;
            background: root.dragging-tab-id != -1 && root.drop-target-pane == 1 ? #ffffff08 : transparent;

            VerticalLayout {
                secondary-tab-bar := TabBar {
                    pane-id: 1;
                    tabs: root.secondary-tabs;
                    dragging-tab-id: root.dragging-tab-id;
                    drag-source-pane: root.drag-source-pane;
                    drag-source-index: root.drag-source-index;
                    drag-abs-x: root.drag-abs-x;
                    is-drop-target: root.drop-target-pane == 1;
                    show-drop-indicator: root.split-drop-side == -1;
                    tab-activated(pane, id) => { root.tab-activated(pane, id); }
                    tab-close-requested(pane, id) => { root.tab-close-requested(pane, id); }
                    tab-context-menu(pane, id, x, y) => { root.tab-context-menu(pane, id, x, y); }
                    new-tab-requested(pane) => { root.new-tab-requested(pane); }
                    tab-drag-started(id, pane, title, index, abs-x, abs-y) => { root.tab-drag-started(id, pane, title, index, abs-x, abs-y); }
                    tab-drag-moved(abs-x, abs-y) => { root.tab-drag-moved(abs-x, abs-y); }
                    tab-drag-ended(abs-x, abs-y) => { root.tab-drag-ended(abs-x, abs-y); }
                }

                Rectangle {
                    vertical-stretch: 1;

                    if root.secondary-is-home-tab || root.secondary-tabs.length == 0: HomeScreen {
                        recent-files: root.recent-files;
                        open-file-requested => { root.open-file-requested(); }
                        open-recent-file(path) => { root.open-recent-file(path); }
                    }

                    if !root.secondary-is-home-tab && root.secondary-tabs.length > 0: Viewport {
                        content: secondary-viewport-content;
                        viewport-info: root.secondary-viewport-info;
                        minimap-thumbnail: secondary-minimap-thumbnail;
                        minimap-rect: secondary-minimap-rect;
                        status-text: root.status-text;
                        is-loading: false;
                        current-tool: root.current-tool;
                        roi-rect: root.secondary-roi-rect;
                        measurements: root.secondary-measurements;
                        candidate-measurement: root.secondary-candidate-measurement;
                        debug-mode: root.debug-mode;
                        fps: root.fps;
                        zoom-slider-position: root.secondary-zoom-slider-position;

                        pan(dx, dy) => { root.pane-focused(1); root.viewport-pan(dx, dy); }
                        zoom(f, x, y) => { root.pane-focused(1); root.viewport-zoom(f, x, y); }
                        fit-to-view => { root.pane-focused(1); root.viewport-fit-to-view(); }
                        start-pan(x, y) => { root.pane-focused(1); root.viewport-start-pan(x, y); }
                        end-pan => { root.viewport-end-pan(); }
                        minimap-navigate(nx, ny) => { root.pane-focused(1); root.minimap-navigate(nx, ny); }
                        zoom-slider-changed(value) => { root.pane-focused(1); root.zoom-slider-changed(1, value); }
                        file-dropped(path) => { root.file-dropped(path); }
                        tool-mouse-down(x, y) => { root.pane-focused(1); root.tool-mouse-down(x, y); }
                        tool-mouse-move(x, y) => { root.tool-mouse-move(x, y); }
                        tool-mouse-up(x, y) => { root.tool-mouse-up(x, y); }
                        cancel-tool => { root.cancel-tool(); }
                        close-tab => { root.close-active-tab(); }
                    }
                }
            }
        }
    }
}

// ============ Main Application Window ============

export component AppWindow inherits Window {
    title: "eosmol";
    no-frame: true;
    resize-border-width: 5px;
    min-width: 800px;
    min-height: 600px;
    preferred-width: 1280px;
    preferred-height: 800px;
    background: Theme.background;
    forward-focus: global-keys;
    
    // Properties
    in-out property <[TabData]> primary-tabs: [];
    in-out property <[TabData]> secondary-tabs: [];
    in-out property <image> viewport-content;
    in-out property <image> secondary-viewport-content;
    in-out property <ViewportInfo> viewport-info;
    in-out property <ViewportInfo> secondary-viewport-info;
    in-out property <image> minimap-thumbnail;
    in-out property <image> secondary-minimap-thumbnail;
    in-out property <MinimapRect> minimap-rect: { x: 0, y: 0, width: 1, height: 1 };
    in-out property <MinimapRect> secondary-minimap-rect: { x: 0, y: 0, width: 1, height: 1 };
    in-out property <string> status-text: "Ready";
    in-out property <bool> is-loading: false;
    in-out property <bool> split-enabled: false;
    in-out property <float> split-position: 0.5;
    in-out property <int> focused-pane: 0;
    in-out property <bool> primary-is-home-tab: false;
    in-out property <bool> secondary-is-home-tab: false;
    in-out property <[RecentFileData]> recent-files: [];
    in-out property <float> zoom-slider-position: 0.5;
    in-out property <float> secondary-zoom-slider-position: 0.5;
    in-out property <int> dragging-tab-id: -1;
    in-out property <int> drag-source-pane: -1;
    in-out property <int> drag-source-index: -1;
    in-out property <string> dragging-tab-title: "";
    in-out property <length> drag-abs-x: 0px;
    in-out property <length> drag-abs-y: 0px;
    in-out property <int> drop-target-pane: -1;
    in-out property <int> split-drop-side: -1;
    
    // Viewport dimensions for rendering - calculated from content area
    out property <float> viewport-width: split-enabled ? 
        (content-area.width * split-position - 3px) / 1px : content-area.width / 1px;
    out property <float> viewport-height: (content-area.height - 35px) / 1px;
    out property <float> secondary-viewport-width: (content-area.width * (1 - split-position) - 3px) / 1px;
    out property <float> secondary-viewport-height: (content-area.height - 35px) / 1px;
    
    // Context menu state
    in-out property <bool> context-menu-visible: false;
    in-out property <length> context-menu-x: 0px;
    in-out property <length> context-menu-y: 0px;
    in-out property <[ContextMenuItem]> context-menu-items: [];
    in-out property <int> context-menu-tab-id: -1;
    
    // Tool system state
    in-out property <ToolType> current-tool: ToolType.navigate;
    in-out property <ROIRect> primary-roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in-out property <ROIRect> secondary-roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in-out property <[MeasurementLine]> primary-measurements: [];
    in-out property <[MeasurementLine]> secondary-measurements: [];
    in-out property <MeasurementLine> primary-candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    in-out property <MeasurementLine> secondary-candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    
    // Debug mode
    in-out property <bool> debug-mode: false;
    in-out property <float> fps: 0;

    // Render backend
    in-out property <RenderMode> render-mode: RenderMode.cpu;
    in-out property <bool> gpu-rendering-available: false;
    
    // Callbacks
    callback open-file-requested();
    callback new-tab-requested(int);
    callback open-recent-file(string);
    callback tab-activated(int, int);
    callback tab-close-requested(int, int);
    callback close-other-tabs(int, int);
    callback close-tabs-to-right(int, int);
    callback close-all-tabs();
    callback open-containing-folder(int);
    callback copy-path(int);
    callback split-right(int, int);
    callback close-split();
    callback viewport-pan(float, float);
    callback viewport-zoom(float, float, float);
    callback viewport-fit-to-view();
    callback viewport-start-pan(float, float);
    callback viewport-end-pan();
    callback minimap-navigate(float, float);
    callback file-dropped(string);
    callback pane-focused(int);
    callback split-position-changed(float);
    callback request-render();
    
    // Tool system callbacks
    callback tool-selected(ToolType);
    callback viewport-tool-mouse-down(float, float);
    callback viewport-tool-mouse-move(float, float);
    callback viewport-tool-mouse-up(float, float);
    callback cancel-tool();
    callback render-backend-selected(RenderMode);
    callback move-tab-to-pane(int, int, int);
    callback split-tab-by-drop(int, int);
    callback reorder-tab(int, int, int);  // pane, tab-id, new-index
    callback zoom-slider-changed(int, float);
    callback close-active-tab();
    callback window-minimize();
    callback window-maximize();
    callback window-close();
    callback open-recent-menu-requested(length, length);
    callback context-menu-command(string);

    // Compute the primary pane width in window-absolute coordinates.
    // content-area starts below the 40px toolbar.
    // Primary pane occupies split-position fraction of content-area width (or all if no split).
    property <length> primary-pane-abs-width: split-enabled
        ? content-area.width * split-position - 3px
        : content-area.width;

    // Compute drop target pane from absolute cursor coordinates.
    function update-drop-target(abs-x: length, abs-y: length) {
        self.split-drop-side = -1;
        if !self.split-enabled {
            let drop-top = toolbar-rect.height + 35px;
            let drop-bottom = self.height;
            if abs-y >= drop-top && abs-y <= drop-bottom {
                let edge-width = content-area.width * 0.28;
                if abs-x <= edge-width {
                    self.split-drop-side = 0;
                } else if abs-x >= content-area.width - edge-width {
                    self.split-drop-side = 1;
                }
            }
            self.drop-target-pane = 0;
            return;
        }

        // Content area starts at x=0 of the window.
        // Primary pane starts at 0, secondary starts after primary + 6px splitter.
        self.drop-target-pane = abs-x > self.primary-pane-abs-width + 6px ? 1 : 0;
    }
    
    // Main layout
    VerticalLayout {
        // Toolbar (also serves as custom title bar)
        toolbar-rect := Rectangle {
            height: 40px;
            background: Theme.toolbar-bg;
            border-width: 0px;

            Rectangle {
                y: parent.height - 1px;
                width: 100%;
                height: 1px;
                background: Theme.border-subtle;
            }

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                
                IconButton {
                    text: "📂";
                    clicked => { root.open-file-requested(); }
                    secondary-clicked(x, y) => { root.open-recent-menu-requested(x, y); }
                }
                
                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: Theme.border;
                }
                
                // Tool buttons
                ToolButton {
                    icon: "✥";
                    tooltip-text: "Navigate (Pan)";
                    is-active: root.current-tool == ToolType.navigate;
                    clicked => { root.tool-selected(ToolType.navigate); }
                }
                
                ToolButton {
                    icon: "▢";
                    tooltip-text: "Region of Interest";
                    is-active: root.current-tool == ToolType.region-of-interest;
                    clicked => { root.tool-selected(ToolType.region-of-interest); }
                }
                
                ToolButton {
                    icon: "📏";
                    tooltip-text: "Measure Distance";
                    is-active: root.current-tool == ToolType.measure-distance;
                    clicked => { root.tool-selected(ToolType.measure-distance); }
                }
                
                Rectangle {
                    width: 1px;
                    height: 24px;
                    background: Theme.border;
                }

                ToolButton {
                    width: 40px;
                    icon: "CPU";
                    tooltip-text: "Use CPU renderer";
                    is-active: root.render-mode == RenderMode.cpu;
                    clicked => { root.render-backend-selected(RenderMode.cpu); }
                }

                ToolButton {
                    width: 40px;
                    icon: "GPU";
                    tooltip-text: root.gpu-rendering-available ? "Use GPU renderer" : "GPU renderer unavailable";
                    enabled: root.gpu-rendering-available;
                    is-active: root.render-mode == RenderMode.gpu;
                    clicked => {
                        if root.gpu-rendering-available {
                            root.render-backend-selected(RenderMode.gpu);
                        }
                    }
                }
                
                // Left spacer
                Rectangle { horizontal-stretch: 1; }
                
                // Centered app title
                Text {
                    text: "eosmol";
                    color: Theme.text-secondary;
                    font-size: 12px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                // Right spacer
                Rectangle { horizontal-stretch: 1; }

                // Window action buttons
                Rectangle {
                    width: 46px;
                    height: 32px;
                    background: minimize-touch.has-hover ? Theme.surface-hover : transparent;
                    border-radius: 0px;

                    minimize-touch := TouchArea {
                        clicked => { root.window-minimize(); }
                    }

                    Text {
                        text: "─";
                        color: Theme.text-primary;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 46px;
                    height: 32px;
                    background: maximize-touch.has-hover ? Theme.surface-hover : transparent;
                    border-radius: 0px;

                    maximize-touch := TouchArea {
                        clicked => { root.window-maximize(); }
                    }

                    Text {
                        text: "☐";
                        color: Theme.text-primary;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    width: 46px;
                    height: 32px;
                    background: close-win-touch.has-hover ? #e81123 : transparent;
                    border-radius: 0px;

                    close-win-touch := TouchArea {
                        clicked => { root.window-close(); }
                    }

                    Text {
                        text: "✕";
                        color: close-win-touch.has-hover ? white : Theme.text-primary;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
        
        // Main content area
        content-area := Rectangle {
            vertical-stretch: 1;
            
            split-pane := SplitPaneContainer {
                visible: primary-tabs.length > 0 || (split-enabled && secondary-tabs.length > 0);
                primary-tabs: root.primary-tabs;
                secondary-tabs: root.secondary-tabs;
                viewport-content: root.viewport-content;
                secondary-viewport-content: root.secondary-viewport-content;
                viewport-info: root.viewport-info;
                secondary-viewport-info: root.secondary-viewport-info;
                minimap-thumbnail: root.minimap-thumbnail;
                secondary-minimap-thumbnail: root.secondary-minimap-thumbnail;
                minimap-rect: root.minimap-rect;
                secondary-minimap-rect: root.secondary-minimap-rect;
                status-text: root.status-text;
                is-loading: root.is-loading;
                split-enabled: root.split-enabled;
                split-position: root.split-position;
                focused-pane: root.focused-pane;
                current-tool: root.current-tool;
                primary-roi-rect: root.primary-roi-rect;
                secondary-roi-rect: root.secondary-roi-rect;
                primary-measurements: root.primary-measurements;
                secondary-measurements: root.secondary-measurements;
                primary-candidate-measurement: root.primary-candidate-measurement;
                secondary-candidate-measurement: root.secondary-candidate-measurement;
                debug-mode: root.debug-mode;
                fps: root.fps;
                primary-is-home-tab: root.primary-is-home-tab;
                secondary-is-home-tab: root.secondary-is-home-tab;
                recent-files: root.recent-files;
                zoom-slider-position: root.zoom-slider-position;
                secondary-zoom-slider-position: root.secondary-zoom-slider-position;
                dragging-tab-id: root.dragging-tab-id;
                drag-source-pane: root.drag-source-pane;
                drag-source-index: root.drag-source-index;
                dragging-tab-title: root.dragging-tab-title;
                drop-target-pane: root.drop-target-pane;
                split-drop-side: root.split-drop-side;
                drag-abs-x: root.drag-abs-x;

                tab-activated(pane, id) => { root.tab-activated(pane, id); }
                tab-close-requested(pane, id) => { root.tab-close-requested(pane, id); }
                new-tab-requested(pane) => { root.new-tab-requested(pane); }
                open-file-requested => { root.open-file-requested(); }
                open-recent-file(path) => { root.open-recent-file(path); }
                tab-context-menu(pane, id, x, y) => {
                    root.context-menu-tab-id = id;
                    root.context-menu-x = x;
                    root.context-menu-y = y;
                    root.context-menu-items = [
                        { id: "close", label: "Close", shortcut: "Ctrl+W", enabled: true, separator-after: false },
                        { id: "close-others", label: "Close Others", shortcut: "", enabled: pane == 0 ? root.primary-tabs.length > 1 : root.secondary-tabs.length > 1, separator-after: false },
                        { id: "close-right", label: "Close to the Right", shortcut: "", enabled: true, separator-after: false },
                        { id: "close-all", label: "Close All", shortcut: "", enabled: true, separator-after: true },
                        { id: "open-folder", label: "Open Containing Folder", shortcut: "", enabled: true, separator-after: false },
                        { id: "copy-path", label: "Copy Path", shortcut: "", enabled: true, separator-after: true },
                        { id: "split-right", label: !root.split-enabled ? "Split Right" : pane == 0 ? "Move to Right Pane" : "Move to Left Pane", shortcut: "", enabled: true, separator-after: false },
                    ];
                    root.drag-source-pane = pane;
                    root.context-menu-visible = true;
                }
                viewport-pan(dx, dy) => { root.viewport-pan(dx, dy); }
                viewport-zoom(f, x, y) => { root.viewport-zoom(f, x, y); }
                viewport-fit-to-view => { root.viewport-fit-to-view(); }
                viewport-start-pan(x, y) => { root.viewport-start-pan(x, y); }
                viewport-end-pan => { root.viewport-end-pan(); }
                minimap-navigate(nx, ny) => { root.minimap-navigate(nx, ny); }
                file-dropped(path) => { root.file-dropped(path); }
                pane-focused(pane) => { root.pane-focused(pane); }
                split-position-changed(pos) => { root.split-position-changed(pos); }
                tab-drag-started(id, pane, title, index, abs-x, abs-y) => {
                    root.dragging-tab-id = id;
                    root.drag-source-pane = pane;
                    root.drag-source-index = index;
                    root.dragging-tab-title = title;
                    root.focused-pane = pane;
                    root.drag-abs-x = abs-x;
                    root.drag-abs-y = abs-y;
                    root.update-drop-target(abs-x, abs-y);
                }
                tab-drag-moved(abs-x, abs-y) => {
                    root.drag-abs-x = abs-x;
                    root.drag-abs-y = abs-y;
                    root.update-drop-target(abs-x, abs-y);
                }
                tab-drag-ended(abs-x, abs-y) => {
                    root.drag-abs-x = abs-x;
                    root.drag-abs-y = abs-y;
                    root.update-drop-target(abs-x, abs-y);
                    if !root.split-enabled && root.split-drop-side != -1 {
                        root.focused-pane = root.split-drop-side;
                        root.split-tab-by-drop(root.dragging-tab-id, root.split-drop-side);
                    } else if root.drop-target-pane != root.drag-source-pane {
                        root.move-tab-to-pane(root.dragging-tab-id, root.drag-source-pane, root.drop-target-pane);
                    } else if split-pane.active-drop-index >= 0 {
                        root.reorder-tab(root.drop-target-pane, root.dragging-tab-id, split-pane.active-drop-index);
                    }
                    root.dragging-tab-id = -1;
                    root.drag-source-pane = -1;
                    root.drag-source-index = -1;
                    root.dragging-tab-title = "";
                    root.drop-target-pane = -1;
                    root.split-drop-side = -1;
                }
                move-tab-to-pane(id, from, to) => {
                    root.focused-pane = to;
                    root.move-tab-to-pane(id, from, to);
                }
                split-tab-by-drop(id, to) => {
                    root.focused-pane = to;
                    root.split-tab-by-drop(id, to);
                }
                reorder-tab(pane, id, new-index) => {
                    root.reorder-tab(pane, id, new-index);
                }
                clear-tab-drag => {
                    root.dragging-tab-id = -1;
                    root.drag-source-pane = -1;
                    root.drag-source-index = -1;
                    root.dragging-tab-title = "";
                    root.drop-target-pane = -1;
                    root.split-drop-side = -1;
                }
                zoom-slider-changed(pane, value) => { root.zoom-slider-changed(pane, value); }
                tool-mouse-down(x, y) => { root.viewport-tool-mouse-down(x, y); }
                tool-mouse-move(x, y) => { root.viewport-tool-mouse-move(x, y); }
                tool-mouse-up(x, y) => { root.viewport-tool-mouse-up(x, y); }
                cancel-tool => { root.cancel-tool(); }
                close-active-tab => { root.close-active-tab(); }
            }
            
            // Empty state - show home screen when no tabs
            if primary-tabs.length == 0 && (!split-enabled || secondary-tabs.length == 0): HomeScreen {
                recent-files: root.recent-files;
                open-file-requested => { root.open-file-requested(); }
                open-recent-file(path) => { root.open-recent-file(path); }
            }
        }
    }
    
    // Context menu overlay
    ContextMenu {
        items: context-menu-items;
        is-visible: context-menu-visible;
        menu-x: context-menu-x;
        menu-y: context-menu-y;
        
        item-clicked(id) => {
            root.context-menu-visible = false;
            if id == "dismiss" {
                return;
            }

            if root.context-menu-tab-id != -1 {
                if id == "close" {
                    root.tab-close-requested(root.drag-source-pane, root.context-menu-tab-id);
                } else if id == "close-others" {
                    root.close-other-tabs(root.drag-source-pane, root.context-menu-tab-id);
                } else if id == "close-right" {
                    root.close-tabs-to-right(root.drag-source-pane, root.context-menu-tab-id);
                } else if id == "close-all" {
                    root.close-all-tabs();
                } else if id == "open-folder" {
                    root.open-containing-folder(root.context-menu-tab-id);
                } else if id == "copy-path" {
                    root.copy-path(root.context-menu-tab-id);
                } else if id == "split-right" {
                    root.split-right(root.drag-source-pane, root.context-menu-tab-id);
                }
            } else {
                root.context-menu-command(id);
            }
        }
    }

    // Floating drag indicator at window level.
    // Uses window-absolute coordinates directly (AppWindow origin IS window origin).
    if root.dragging-tab-id != -1: Rectangle {
        x: root.drag-abs-x - 70px;
        y: root.drag-abs-y - 18px;
        width: 140px;
        height: 28px;
        border-radius: 4px;
        background: #252526ee;
        border-width: 1px;
        border-color: Theme.accent;

        Text {
            x: 10px;
            y: 6px;
            width: parent.width - 20px;
            text: root.dragging-tab-title;
            color: Theme.text-primary;
            font-size: 12px;
            overflow: elide;
        }
    }

    // Global keyboard handler for window-level shortcuts
    global-keys := FocusScope {
        width: 0px;
        height: 0px;

        key-pressed(e) => {
            if (e.text == "w" || e.text == "W") && e.modifiers.control && e.modifiers.shift {
                root.window-close();
                return accept;
            }
            if e.text == "w" && e.modifiers.control {
                root.close-active-tab();
                return accept;
            }
            return reject;
        }
    }
}
