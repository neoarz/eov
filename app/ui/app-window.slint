// EOV WSI Viewer - Main Application Window

import { Theme } from "theme.slint";
import {
    ContextMenuItem,
    DatasetExportProgress,
    DatasetExportSettings,
    ExportPreviewInfo,
    ExportSettings,
    FilteringMode,
    MeasurementLine,
    MeasurementUnit,
    MetadataItem,
    MinimapRect,
    StainNormalization,
    PaneViewData,
    RecentFileData,
    RenderMode,
    ROIRect,
    TabData,
    ToolType,
    ViewportInfo,
} from "types.slint";
import { ContextMenu } from "tab-controls.slint";
import {
    DatasetExportDialog,
    DatasetExportProgressDialog,
} from "dataset-export-dialog.slint";
import { ExportDialog } from "export-dialog.slint";
import { HomeScreen } from "home-screen.slint";
import { SplitPaneContainer } from "panes.slint";
import { WindowToolbar } from "window-toolbar.slint";

export component AppWindow inherits Window {
    title: "eov";
    icon: @image-url("../../images/logo_full.png");
    in property <bool> use-native-window-controls: false;
    no-frame: !use-native-window-controls;
    resize-border-width: 5px;
    min-width: 800px;
    min-height: 600px;
    preferred-width: 1280px;
    preferred-height: 800px;
    background: Theme.background;
    forward-focus: global-keys;

    in-out property <[PaneViewData]> panes: [];
    in-out property <[TabData]> primary-tabs: [];
    in-out property <[TabData]> secondary-tabs: [];
    in-out property <image> viewport-content;
    in-out property <image> secondary-viewport-content;
    in-out property <ViewportInfo> viewport-info;
    in-out property <ViewportInfo> secondary-viewport-info;
    in-out property <image> minimap-thumbnail;
    in-out property <image> secondary-minimap-thumbnail;
    in-out property <MinimapRect> minimap-rect: { x: 0, y: 0, width: 1, height: 1 };
    in-out property <MinimapRect> secondary-minimap-rect: { x: 0, y: 0, width: 1, height: 1 };
    in-out property <string> status-text: "Ready";
    in-out property <bool> is-loading: false;
    in-out property <bool> split-enabled: false;
    in-out property <float> split-position: 0.5;
    in-out property <int> focused-pane: 0;
    in-out property <bool> primary-is-home-tab: false;
    in-out property <bool> secondary-is-home-tab: false;
    in-out property <[RecentFileData]> recent-files: [];
    in-out property <float> zoom-slider-position: 0.5;
    in-out property <float> secondary-zoom-slider-position: 0.5;
    in-out property <int> dragging-tab-id: -1;
    in-out property <int> drag-source-pane: -1;
    in-out property <int> drag-source-index: -1;
    in-out property <string> dragging-tab-title: "";
    in-out property <length> drag-abs-x: 0px;
    in-out property <length> drag-abs-y: 0px;
    in-out property <int> drop-target-pane: -1;
    in-out property <int> split-drop-side: -1;
    in-out property <int> os-file-hover-pane: -1;
    in-out property <int> os-file-hover-side: -1;
    out property <float> content-area-width: content-area.width / 1px;
    out property <float> content-area-height: content-area.height / 1px;
    out property <float> viewport-width: split-enabled ? (content-area.width * split-position - 3px) / 1px : content-area.width / 1px;
    out property <float> viewport-height: (content-area.height - 35px) / 1px;
    out property <float> secondary-viewport-width: (content-area.width * (1 - split-position) - 3px) / 1px;
    out property <float> secondary-viewport-height: (content-area.height - 35px) / 1px;
    out property <float> toolbar-action-width: toolbar.action-cluster-width;

    in-out property <bool> context-menu-visible: false;
    in-out property <length> context-menu-x: 0px;
    in-out property <length> context-menu-y: 0px;
    in-out property <[ContextMenuItem]> context-menu-items: [];
    in-out property <int> context-menu-tab-id: -1;
    in-out property <bool> toast-visible: false;
    in-out property <string> toast-text: "";

    in-out property <bool> filter-popup-visible: false;
    in-out property <bool> lanczos-confirm-visible: false;
    in-out property <bool> lanczos-confirm-from-backend-switch: false;

    callback lanczos-confirm-accepted();
    callback lanczos-confirm-cancelled();
    callback lanczos-confirm-use-trilinear();

    // Export dialog
    in-out property <bool> export-dialog-visible: false;
    in-out property <ExportSettings> export-settings;
    in-out property <ExportPreviewInfo> export-preview-info;
    callback export-dialog-settings-changed(ExportSettings);
    callback export-dialog-export-requested();
    callback export-dialog-cancel-requested();
    callback export-dialog-reset-requested();
    callback export-dialog-request-preview();

    // Dataset export dialog
    in-out property <bool> dataset-export-dialog-visible: false;
    in-out property <DatasetExportSettings> dataset-export-settings;
    in-out property <bool> dataset-export-progress-visible: false;
    in-out property <DatasetExportProgress> dataset-export-progress;
    callback dataset-export-requested();
    callback dataset-export-open-dialog();
    callback dataset-export-cancel-requested();
    callback dataset-export-add-input();
    callback dataset-export-remove-input(int);
    callback dataset-export-change-output-dir();
    callback dataset-export-cancel-progress();
    callback dataset-export-settings-changed(DatasetExportSettings);

    in-out property <ToolType> current-tool: ToolType.navigate;
    in-out property <ROIRect> primary-roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in-out property <ROIRect> secondary-roi-rect: { x: 0, y: 0, width: 0, height: 0, visible: false };
    in-out property <[MeasurementLine]> primary-measurements: [];
    in-out property <[MeasurementLine]> secondary-measurements: [];
    in-out property <MeasurementLine> primary-candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };
    in-out property <MeasurementLine> secondary-candidate-measurement: { x1: 0, y1: 0, x2: 0, y2: 0, distance-um: 0, visible: false };

    in-out property <bool> debug-mode: false;
    in-out property <float> fps: 0;
    in-out property <RenderMode> render-mode: RenderMode.cpu;
    in-out property <bool> gpu-rendering-available: false;
    in-out property <FilteringMode> filtering-mode: FilteringMode.trilinear;
    in-out property <bool> show-minimap: true;
    in-out property <bool> show-metadata: false;

    callback open-file-requested();
    callback new-tab-requested(int);
    callback open-recent-file(string);
    callback toggle-minimap-requested();
    callback toggle-metadata-requested();
    callback tab-activated(int, int);
    callback tab-close-requested(int, int);
    callback close-other-tabs(int, int);
    callback close-tabs-to-right(int, int);
    callback close-all-tabs();
    callback open-containing-folder(int);
    callback copy-path(int);
    callback split-right(int, int);
    callback close-split();
    callback viewport-pan(float, float);
    callback viewport-zoom(float, float, float);
    callback viewport-fit-to-view();
    callback viewport-start-pan(float, float);
    callback viewport-end-pan();
    callback viewport-context-menu(int, length, length);
    callback minimap-navigate(float, float);
    callback file-dropped(string);
    callback pane-focused(int);
    callback split-position-changed(float);
    callback request-render();
    callback tool-selected(ToolType);
    callback viewport-tool-mouse-down(float, float);
    callback viewport-tool-mouse-move(float, float);
    callback viewport-tool-mouse-up(float, float);
    callback cancel-tool();
    callback render-backend-selected(RenderMode);
    callback filtering-mode-selected(FilteringMode);
    callback move-tab-to-pane(int, int, int);
    callback split-tab-by-drop(int, int);
    callback reorder-tab(int, int, int);
    callback zoom-slider-changed(int, float);
    callback close-active-tab();
    callback window-minimize();
    callback window-maximize();
    callback window-close();
    callback open-recent-menu-requested(length, length);
    callback context-menu-command(string);
    callback os-file-drop(/* pane */ int, /* side: -1=center, 0=left, 1=right */ int, /* path */ string);
    callback hud-toggle-scale-bar(int);
    callback hud-toggle-dropdown(int);
    callback hud-sharpness-changed(int, float);
    callback hud-gamma-changed(int, float);
    callback hud-brightness-changed(int, float);
    callback hud-contrast-changed(int, float);
    callback hud-measurement-unit-changed(int, MeasurementUnit);
    callback hud-stain-normalization-changed(int, StainNormalization);
    callback hud-reset-adjustments(int);
    callback hud-zoom-input(int, float);
    callback hud-zoom-in(int);
    callback hud-zoom-out(int);
    callback hud-deconv-h-intensity-changed(int, float);
    callback hud-deconv-e-intensity-changed(int, float);
    callback hud-deconv-h-visibility-toggled(int);
    callback hud-deconv-e-visibility-toggled(int);
    callback hud-deconv-h-view-toggled(int);
    callback hud-deconv-e-view-toggled(int);

    property <length> toolbar-height: 40px;
    property <length> pane-gap: 6px;
    property <int> pane-count: max(1, panes.length);
    property <length> pane-width: (content-area.width - max(0px, (pane-count - 1) * pane-gap)) / pane-count;
    property <length> pane-stride: pane-width + pane-gap;

    property <bool> tab-tooltip-visible: false;
    property <string> tab-tooltip-text: "";
    property <length> tab-tooltip-x: 0px;
    property <length> tab-tooltip-y: 0px;

    function update-drop-target(abs-x: length, abs-y: length) {
        if panes.length == 0 {
            self.drop-target-pane = -1;
            self.split-drop-side = -1;
            return;
        }
        let raw-pane = Math.floor(abs-x / self.pane-stride);
        self.drop-target-pane = Math.max(0, Math.min(self.panes.length - 1, raw-pane));
        self.split-drop-side = -1;
        let drop-top = toolbar-height + 35px;
        let drop-bottom = self.height;
        if abs-y >= drop-top && abs-y <= drop-bottom {
            let local-x = abs-x - self.drop-target-pane * self.pane-stride;
            let edge-width = self.pane-width * 0.28;
            if local-x <= edge-width {
                self.split-drop-side = 0;
            } else if local-x >= self.pane-width - edge-width {
                self.split-drop-side = 1;
            }
        }
    }

    public function update-os-file-hover(abs-x: float, abs-y: float) {
        if panes.length == 0 {
            self.os-file-hover-pane = -1;
            self.os-file-hover-side = -1;
            return;
        }
        let raw-pane = Math.floor(abs-x * 1px / self.pane-stride);
        self.os-file-hover-pane = Math.max(0, Math.min(self.panes.length - 1, raw-pane));
        self.os-file-hover-side = -1;
        let drop-top = (toolbar-height + 35px) / 1px;
        let drop-bottom = self.height / 1px;
        if abs-y >= drop-top && abs-y <= drop-bottom {
            let local-x = abs-x - self.os-file-hover-pane * self.pane-stride / 1px;
            let edge-width = self.pane-width / 1px * 0.20;
            if local-x <= edge-width {
                self.os-file-hover-side = 0;
            } else if local-x >= self.pane-width / 1px - edge-width {
                self.os-file-hover-side = 1;
            }
        }
    }

    public function clear-os-file-hover() {
        self.os-file-hover-pane = -1;
        self.os-file-hover-side = -1;
    }

    public function focus-keyboard() {
        global-keys.focus();
    }

    VerticalLayout {
        toolbar := WindowToolbar {
            current-tool: root.current-tool;
            render-mode: root.render-mode;
            gpu-rendering-available: root.gpu-rendering-available;
            filtering-mode: root.filtering-mode;
            filter-popup-visible <=> root.filter-popup-visible;
            show-minimap: root.show-minimap;
            show-metadata: root.show-metadata;
            use-native-window-controls: root.use-native-window-controls;
            open-file-requested => {
                root.open-file-requested();
            }
            open-recent-menu-requested(x, y) => {
                root.open-recent-menu-requested(x, y);
            }
            toggle-minimap-requested => {
                root.toggle-minimap-requested();
            }
            toggle-metadata-requested => {
                root.toggle-metadata-requested();
            }
            tool-selected(tool) => {
                root.tool-selected(tool);
            }
            render-backend-selected(mode) => {
                root.render-backend-selected(mode);
            }
            filtering-mode-selected(mode) => {
                root.filtering-mode-selected(mode);
            }
            dataset-export-requested => {
                root.dataset-export-open-dialog();
            }
            window-minimize => {
                root.window-minimize();
            }
            window-maximize => {
                root.window-maximize();
            }
            window-close => {
                root.window-close();
            }
        }

        content-area := Rectangle {
            vertical-stretch: 1;

            split-pane := SplitPaneContainer {
                visible: root.panes.length > 0;
                panes: root.panes;
                status-text: root.status-text;
                show-minimap: root.show-minimap;
                show-metadata: root.show-metadata;
                split-enabled: root.split-enabled;
                focused-pane: root.focused-pane;
                current-tool: root.current-tool;
                debug-mode: root.debug-mode;
                fps: root.fps;
                recent-files: root.recent-files;
                dragging-tab-id: root.dragging-tab-id;
                drag-source-pane: root.drag-source-pane;
                drag-source-index: root.drag-source-index;
                dragging-tab-title: root.dragging-tab-title;
                drop-target-pane: root.drop-target-pane;
                split-drop-side: root.split-drop-side;
                drag-abs-x: root.drag-abs-x;
                os-file-hover-pane: root.os-file-hover-pane;
                os-file-hover-side: root.os-file-hover-side;

                tab-activated(pane, id) => {
                    root.tab-activated(pane, id);
                }
                tab-close-requested(pane, id) => {
                    root.tab-close-requested(pane, id);
                }
                new-tab-requested(pane) => {
                    root.new-tab-requested(pane);
                }
                open-file-requested => {
                    root.open-file-requested();
                }
                open-recent-file(path) => {
                    root.open-recent-file(path);
                }
                tab-context-menu(pane, id, x, y) => {
                    root.context-menu-tab-id = id;
                    root.context-menu-x = x;
                    root.context-menu-y = y;
                    root.context-menu-items = [
                        {
                            id: "close",
                            label: "Close",
                            icon: "",
                            shortcut: "Ctrl+W",
                            enabled: true,
                            separator-after: false
                        },
                        {
                            id: "close-others",
                            label: "Close Others",
                            icon: "",
                            shortcut: "",
                            enabled: pane >= 0 && pane < root.panes.length ? root.panes[pane].tabs.length > 1 : false,
                            separator-after: false
                        },
                        {
                            id: "close-right",
                            label: "Close to the Right",
                            icon: "",
                            shortcut: "",
                            enabled: true,
                            separator-after: false
                        },
                        {
                            id: "close-all",
                            label: "Close All",
                            icon: "",
                            shortcut: "",
                            enabled: true,
                            separator-after: true
                        },
                        {
                            id: "open-folder",
                            label: "Open Containing Folder",
                            icon: "",
                            shortcut: "",
                            enabled: true,
                            separator-after: false
                        },
                        {
                            id: "copy-path",
                            label: "Copy Path",
                            icon: "",
                            shortcut: "",
                            enabled: true,
                            separator-after: true
                        },
                        {
                            id: "split-right",
                            label: "Split Right",
                            icon: "",
                            shortcut: "",
                            enabled: true,
                            separator-after: false
                        },
                    ];
                    root.drag-source-pane = pane;
                    root.context-menu-visible = true;
                }
                viewport-pan(dx, dy) => {
                    root.viewport-pan(dx, dy);
                }
                viewport-zoom(f, x, y) => {
                    root.viewport-zoom(f, x, y);
                }
                viewport-fit-to-view => {
                    root.viewport-fit-to-view();
                }
                viewport-start-pan(x, y) => {
                    root.viewport-start-pan(x, y);
                }
                viewport-end-pan => {
                    root.viewport-end-pan();
                }
                viewport-context-menu(pane, x, y) => {
                    root.context-menu-tab-id = -1;
                    root.drag-source-pane = pane;
                    root.context-menu-x = x;
                    root.context-menu-y = y;
                    root.context-menu-items = [
                        {
                            id: "viewport-copy-image",
                            label: "Copy Image",
                            icon: "copy",
                            shortcut: "",
                            enabled: true,
                            separator-after: false
                        },
                        {
                            id: "viewport-export-image",
                            label: "Export Image",
                            icon: "export",
                            shortcut: "",
                            enabled: true,
                            separator-after: false
                        },
                    ];
                    root.context-menu-visible = true;
                }
                minimap-navigate(nx, ny) => {
                    root.minimap-navigate(nx, ny);
                }
                file-dropped(path) => {
                    root.file-dropped(path);
                }
                pane-focused(pane) => {
                    root.pane-focused(pane);
                }
                split-position-changed(pos) => {
                    root.split-position-changed(pos);
                }
                tab-drag-started(id, pane, title, index, abs-x, abs-y) => {
                    root.dragging-tab-id = id;
                    root.drag-source-pane = pane;
                    root.drag-source-index = index;
                    root.dragging-tab-title = title;
                    root.focused-pane = pane;
                    root.drag-abs-x = abs-x;
                    root.drag-abs-y = abs-y;
                    root.update-drop-target(abs-x, abs-y);
                }
                tab-drag-moved(abs-x, abs-y) => {
                    root.drag-abs-x = abs-x;
                    root.drag-abs-y = abs-y;
                    root.update-drop-target(abs-x, abs-y);
                }
                tab-drag-ended(abs-x, abs-y) => {
                    root.drag-abs-x = abs-x;
                    root.drag-abs-y = abs-y;
                    root.update-drop-target(abs-x, abs-y);
                    if root.drop-target-pane != -1 && root.split-drop-side != -1 {
                        let insert-at = root.split-drop-side == 0 ? root.drop-target-pane : root.drop-target-pane + 1;
                        root.focused-pane = insert-at;
                        root.split-tab-by-drop(root.dragging-tab-id, insert-at);
                    } else if root.drop-target-pane != root.drag-source-pane {
                        root.move-tab-to-pane(root.dragging-tab-id, root.drag-source-pane, root.drop-target-pane);
                    } else if split-pane.active-drop-index >= 0 {
                        root.reorder-tab(root.drop-target-pane, root.dragging-tab-id, split-pane.active-drop-index);
                    }
                    root.dragging-tab-id = -1;
                    root.drag-source-pane = -1;
                    root.drag-source-index = -1;
                    root.dragging-tab-title = "";
                    root.drop-target-pane = -1;
                    root.split-drop-side = -1;
                }
                move-tab-to-pane(id, from, to) => {
                    root.focused-pane = to;
                    root.move-tab-to-pane(id, from, to);
                }
                split-tab-by-drop(id, to) => {
                    root.focused-pane = to;
                    root.split-tab-by-drop(id, to);
                }
                reorder-tab(pane, id, new-index) => {
                    root.reorder-tab(pane, id, new-index);
                }
                clear-tab-drag => {
                    root.dragging-tab-id = -1;
                    root.drag-source-pane = -1;
                    root.drag-source-index = -1;
                    root.dragging-tab-title = "";
                    root.drop-target-pane = -1;
                    root.split-drop-side = -1;
                }
                zoom-slider-changed(pane, value) => {
                    root.zoom-slider-changed(pane, value);
                }
                tool-mouse-down(x, y) => {
                    root.viewport-tool-mouse-down(x, y);
                }
                tool-mouse-move(x, y) => {
                    root.viewport-tool-mouse-move(x, y);
                }
                tool-mouse-up(x, y) => {
                    root.viewport-tool-mouse-up(x, y);
                }
                cancel-tool => {
                    root.cancel-tool();
                }
                close-active-tab => {
                    root.close-active-tab();
                }
                tab-tooltip-changed(visible, text, cx, ty) => {
                    root.tab-tooltip-visible = visible;
                    root.tab-tooltip-text = text;
                    root.tab-tooltip-x = cx;
                    root.tab-tooltip-y = ty;
                }
                hud-toggle-scale-bar(pane) => {
                    root.hud-toggle-scale-bar(pane);
                }
                hud-toggle-dropdown(pane) => {
                    root.hud-toggle-dropdown(pane);
                }
                hud-sharpness-changed(pane, v) => {
                    root.hud-sharpness-changed(pane, v);
                }
                hud-gamma-changed(pane, v) => {
                    root.hud-gamma-changed(pane, v);
                }
                hud-brightness-changed(pane, v) => {
                    root.hud-brightness-changed(pane, v);
                }
                hud-contrast-changed(pane, v) => {
                    root.hud-contrast-changed(pane, v);
                }
                hud-measurement-unit-changed(pane, u) => {
                    root.hud-measurement-unit-changed(pane, u);
                }
                hud-stain-normalization-changed(pane, s) => {
                    root.hud-stain-normalization-changed(pane, s);
                }
                hud-reset-adjustments(pane) => {
                    root.hud-reset-adjustments(pane);
                }
                hud-zoom-input(pane, v) => {
                    root.hud-zoom-input(pane, v);
                }
                hud-zoom-in(pane) => {
                    root.hud-zoom-in(pane);
                }
                hud-zoom-out(pane) => {
                    root.hud-zoom-out(pane);
                }
                hud-deconv-h-intensity-changed(pane, v) => {
                    root.hud-deconv-h-intensity-changed(pane, v);
                }
                hud-deconv-e-intensity-changed(pane, v) => {
                    root.hud-deconv-e-intensity-changed(pane, v);
                }
                hud-deconv-h-visibility-toggled(pane) => {
                    root.hud-deconv-h-visibility-toggled(pane);
                }
                hud-deconv-e-visibility-toggled(pane) => {
                    root.hud-deconv-e-visibility-toggled(pane);
                }
                hud-deconv-h-view-toggled(pane) => {
                    root.hud-deconv-h-view-toggled(pane);
                }
                hud-deconv-e-view-toggled(pane) => {
                    root.hud-deconv-e-view-toggled(pane);
                }
            }

            if panes.length == 0: HomeScreen {
                recent-files: root.recent-files;
                open-file-requested => {
                    root.open-file-requested();
                }
                open-recent-file(path) => {
                    root.open-recent-file(path);
                }
            }
        }
    }

    if toolbar.hovered-tooltip-visible: Rectangle {
        x: max(4px, min(root.width - self.width - 4px, toolbar.hovered-tooltip-center-x - self.width / 2));
        y: toolbar.hovered-tooltip-top-y;
        width: toolbar-tooltip.preferred-width + 12px;
        height: toolbar-tooltip.preferred-height + 6px;
        background: #111111ee;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.border;

        toolbar-tooltip := Text {
            x: 6px;
            y: 3px;
            text: toolbar.hovered-tooltip-text;
            color: white;
            font-size: 11px;
        }
    }

    Rectangle {
        opacity: root.tab-tooltip-visible && !root.context-menu-visible ? 1.0 : 0.0;
        animate opacity { duration: 200ms; }
        x: max(4px, min(root.width - self.width - 4px, root.tab-tooltip-x - self.width / 2));
        y: root.tab-tooltip-y;
        width: tab-path-tooltip.preferred-width + 12px;
        height: tab-path-tooltip.preferred-height + 6px;
        background: #111111ee;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.border;

        tab-path-tooltip := Text {
            x: 6px;
            y: 3px;
            text: root.tab-tooltip-text;
            color: white;
            font-size: 11px;
        }
    }

    ContextMenu {
        items: context-menu-items;
        is-visible: context-menu-visible;
        menu-x: context-menu-x;
        menu-y: context-menu-y;

        item-clicked(id) => {
            root.context-menu-visible = false;
            if id == "dismiss" {
                return;
            }
            if root.context-menu-tab-id != -1 {
                if id == "close" {
                    root.tab-close-requested(root.drag-source-pane, root.context-menu-tab-id);
                } else if id == "close-others" {
                    root.close-other-tabs(root.drag-source-pane, root.context-menu-tab-id);
                } else if id == "close-right" {
                    root.close-tabs-to-right(root.drag-source-pane, root.context-menu-tab-id);
                } else if id == "close-all" {
                    root.close-all-tabs();
                } else if id == "open-folder" {
                    root.open-containing-folder(root.context-menu-tab-id);
                } else if id == "copy-path" {
                    root.copy-path(root.context-menu-tab-id);
                } else if id == "split-right" {
                    root.split-right(root.drag-source-pane, root.context-menu-tab-id);
                }
            } else {
                root.context-menu-command(id);
            }
        }
    }

    Rectangle {
        opacity: root.toast-visible ? 1.0 : 0.0;
        y: root.toast-visible ? root.height - self.height - 20px : root.height + 12px;
        x: root.width / 2 - self.width / 2;
        width: toast-label.preferred-width + 28px;
        height: toast-label.preferred-height + 14px;
        background: #111111ee;
        border-radius: self.height / 2;
        border-width: 1px;
        border-color: Theme.border;
        animate opacity { duration: 180ms; }
        animate y { duration: 220ms; }

        toast-label := Text {
            x: 14px;
            y: 7px;
            text: root.toast-text;
            color: white;
            font-size: 12px;
        }
    }

    // Dismiss overlay for filtering popup
    if root.filter-popup-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: transparent;

        TouchArea {
            clicked => {
                root.filter-popup-visible = false;
            }
        }
    }

    // Floating filtering dropdown (rendered above all content)
    if root.filter-popup-visible: Rectangle {
        x: toolbar.filter-combo-abs-x;
        y: toolbar.filter-combo-abs-y;
        width: toolbar.filter-combo-width + 74px;
        height: 3 * 26px + 4px;
        background: Theme.context-menu-bg;
        border-radius: 4px;
        border-width: 1px;
        border-color: Theme.border;

        VerticalLayout {
            padding: 2px;

            Rectangle {
                height: 26px;
                background: bilinear-touch.has-hover ? Theme.context-menu-hover : transparent;
                border-radius: 2px;

                bilinear-touch := TouchArea {
                    clicked => {
                        root.filter-popup-visible = false;
                        root.filtering-mode-selected(FilteringMode.bilinear);
                    }
                }

                HorizontalLayout {
                    padding-left: 8px;
                    Text {
                        text: root.filtering-mode == FilteringMode.bilinear ? "✓ Bilinear (Low Quality)" : "   Bilinear (Low Quality)";
                        color: Theme.text-primary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                height: 26px;
                background: trilinear-touch.has-hover ? Theme.context-menu-hover : transparent;
                border-radius: 2px;

                trilinear-touch := TouchArea {
                    clicked => {
                        root.filter-popup-visible = false;
                        root.filtering-mode-selected(FilteringMode.trilinear);
                    }
                }

                HorizontalLayout {
                    padding-left: 8px;
                    Text {
                        text: root.filtering-mode == FilteringMode.trilinear ? "✓ Trilinear (Balanced)" : "   Trilinear (Balanced)";
                        color: Theme.text-primary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }

            Rectangle {
                height: 26px;
                background: lanczos3-touch.has-hover ? Theme.context-menu-hover : transparent;
                border-radius: 2px;

                lanczos3-touch := TouchArea {
                    clicked => {
                        root.filter-popup-visible = false;
                        root.filtering-mode-selected(FilteringMode.lanczos3);
                    }
                }

                HorizontalLayout {
                    padding-left: 8px;
                    Text {
                        text: root.filtering-mode == FilteringMode.lanczos3 ? "✓ Lanczos-3 (High Quality)" : "   Lanczos-3 (High Quality)";
                        color: Theme.text-primary;
                        font-size: 11px;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }

    // Lanczos CPU confirmation dialog (centered modal)
    if root.lanczos-confirm-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: #00000088;

        TouchArea {
            clicked => {
                root.lanczos-confirm-visible = false;
                root.lanczos-confirm-cancelled();
                root.lanczos-confirm-from-backend-switch = false;
            }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 420px;
            height: 200px;
            background: Theme.surface;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;

            // Block clicks from dismissing through the card
            TouchArea { }

            VerticalLayout {
                padding: 20px;
                spacing: 12px;

                Text {
                    text: "Lanczos Filtering (CPU)";
                    color: Theme.text-primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: left;
                }

                Text {
                    text: "Lanczos-3 filtering on the CPU renderer is very slow and will significantly degrade rendering performance. It is highly recommended to use Trilinear filtering on CPU.\n\nAre you sure you want to enable it?";
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Rectangle {
                        width: 72px;
                        height: 28px;
                        border-radius: 4px;
                        background: cancel-touch.has-hover ? Theme.surface-hover : Theme.surface;
                        border-width: 1px;
                        border-color: Theme.border;

                        cancel-touch := TouchArea {
                            clicked => {
                                root.lanczos-confirm-visible = false;
                                root.lanczos-confirm-cancelled();
                                root.lanczos-confirm-from-backend-switch = false;
                            }
                        }

                        Text {
                            text: "Cancel";
                            color: Theme.text-primary;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        min-width: use-trilinear-text.preferred-width + 16px;
                        height: 28px;
                        border-radius: 4px;
                        background: use-trilinear-touch.has-hover ? Theme.surface-hover : Theme.surface;
                        border-width: 1px;
                        border-color: Theme.border;

                        use-trilinear-touch := TouchArea {
                            clicked => {
                                root.lanczos-confirm-visible = false;
                                root.lanczos-confirm-use-trilinear();
                                root.lanczos-confirm-from-backend-switch = false;
                            }
                        }

                        use-trilinear-text := Text {
                            text: "Use Trilinear";
                            color: Theme.text-primary;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 72px;
                        height: 28px;
                        border-radius: 4px;
                        background: confirm-touch.has-hover ? #1177bb : Theme.accent;

                        confirm-touch := TouchArea {
                            clicked => {
                                root.lanczos-confirm-visible = false;
                                root.lanczos-confirm-accepted();
                                root.lanczos-confirm-from-backend-switch = false;
                            }
                        }

                        Text {
                            text: "Confirm";
                            color: white;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    // Export image dialog overlay
    if root.export-dialog-visible: ExportDialog {
        visible-state: root.export-dialog-visible;
        settings <=> root.export-settings;
        preview-info: root.export-preview-info;
        toolbar-height: root.toolbar-height;
        settings-changed(s) => {
            root.export-dialog-settings-changed(s);
        }
        request-preview => {
            root.export-dialog-request-preview();
        }
        export-requested => {
            root.export-dialog-export-requested();
        }
        cancel-requested => {
            root.export-dialog-visible = false;
            root.export-dialog-cancel-requested();
        }
        reset-requested => {
            root.export-dialog-reset-requested();
        }
    }

    // Dataset export configuration dialog
    if root.dataset-export-dialog-visible: DatasetExportDialog {
        visible-state: root.dataset-export-dialog-visible;
        settings <=> root.dataset-export-settings;
        toolbar-height: root.toolbar-height;
        export-requested => {
            root.dataset-export-requested();
        }
        cancel-requested => {
            root.dataset-export-dialog-visible = false;
            root.dataset-export-cancel-requested();
        }
        add-input-requested => {
            root.dataset-export-add-input();
        }
        remove-input-requested(idx) => {
            root.dataset-export-remove-input(idx);
        }
        change-output-dir-requested => {
            root.dataset-export-change-output-dir();
        }
        settings-changed(s) => {
            root.dataset-export-settings-changed(s);
        }
    }

    // Dataset export progress dialog
    if root.dataset-export-progress-visible: DatasetExportProgressDialog {
        progress: root.dataset-export-progress;
        cancel-requested => {
            root.dataset-export-cancel-progress();
        }
    }

    if root.dragging-tab-id != -1: Rectangle {
        x: root.drag-abs-x - 70px;
        y: root.drag-abs-y - 18px;
        width: 140px;
        height: 28px;
        border-radius: 4px;
        background: #252526ee;
        border-width: 1px;
        border-color: Theme.accent;

        Text {
            x: 10px;
            y: 6px;
            width: parent.width - 20px;
            text: root.dragging-tab-title;
            color: Theme.text-primary;
            font-size: 12px;
            overflow: elide;
        }
    }

    global-keys := FocusScope {
        width: 0px;
        height: 0px;

        key-pressed(e) => {
            if e.text == Key.Escape && root.dataset-export-progress-visible {
                root.dataset-export-cancel-progress();
                accept
            }
            if e.text == Key.Escape && root.dataset-export-dialog-visible {
                root.dataset-export-dialog-visible = false;
                root.dataset-export-cancel-requested();
                accept
            }
            if e.text == Key.Escape && root.export-dialog-visible {
                root.export-dialog-visible = false;
                root.export-dialog-cancel-requested();
                accept
            }
            if (e.text == "w" || e.text == "W") && e.modifiers.control && e.modifiers.shift {
                root.window-close();
                accept
            }
            if e.text == "w" && e.modifiers.control {
                root.close-active-tab();
                accept
            }
            reject
        }
    }
}
